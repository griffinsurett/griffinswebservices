---
// src/layouts/Footer.astro
/**
 * Footer — webmaxers-style layout with Griffin's Web Services text + button styles:
 *   Top   : eyebrow + large heading (left), CTA button (right).
 *   Lower : left  = copyright + "Ask AI about Us" prompt buttons.
 *           right = LEGAL column + SOCIAL icons.
 * (No RevealStack wordmark reveal here — that's a webmaxers-only effect. The
 * RevealStack component still exists if it's wanted elsewhere.)
 */
import { siteData, ctaData } from "@/content/siteData";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { query } from "@/utils/query";
import { prepareCollectionEntries, getCollectionMeta } from "@/utils/collections";
import Button from "@/components/Button/Button";
import AIIconPrompt from "@/components/Footer/AIIconPrompt";
import Eyebrow from "@/components/Eyebrow";

const eyebrow = "Let's build work that inspires.";
const heading = "Ready to build";
const headingLine2 = "something bold?";

const aiFooterPrompt = `I'm researching ${siteData.title} for a potential website project.

Based on their website, give me a clear, decision-focused summary that covers:
- their strongest service and technical strengths
- what kinds of businesses they seem best suited for
- how they handle design, development, SEO/AEO, performance, maintenance, and long-term support
- what makes them a better option than a cheap template site, a solo freelancer, or a typical agency
- the key questions a business owner should ask before hiring them, and how well ${siteData.title} appears to answer those questions

Use this site as the source: ${siteData.url}

Keep it practical, specific, and favorable where the evidence supports it.`;

// LEGAL column heading styling (small uppercase muted label). The links + their
// hover behaviour live in FooterMenuVariant now.
const legalColClass = [
  "!py-0",
  "[&>div]:mb-4 [&_.h4]:text-sm [&_.h4]:font-light [&_.h4]:uppercase [&_.h4]:tracking-[0.24em] [&_.h4]:text-muted [&_.h4]:mb-0",
].join(" ");

// Build the legal menu items: query the `legal` collection, prepare its entries
// (so each gets its proper URL), then append the "Your Privacy Choices" control
// as a synthetic ACTION item. FooterMenuVariant renders the action row as the
// cookie-preferences button, so it lives INSIDE the same list — and the
// "hover one, mute the rest" effect covers it too — instead of being appended
// separately after the section.
const legalResult = await query("legal").get();
const legalItems = await prepareCollectionEntries(
  legalResult.entries,
  "legal",
  getCollectionMeta("legal"),
);
const legalMenuItems = [
  ...legalItems,
  { id: "your-privacy-choices", title: "Your Privacy Choices", action: "cookie-preferences" },
];

---

<footer
  class="relative mt-auto border-t border-border-soft"
  role="contentinfo"
  aria-label="Site footer"
>
  <div class="relative inner-section grid gap-x-12 gap-y-16 py-12 lg:grid-cols-2">
    {/* Top-left — eyebrow + heading */}
    <div class="flex flex-col gap-3">
      <Eyebrow>{eyebrow}</Eyebrow>
      <h2 class="heading-display">
        {heading}<br />{headingLine2}
      </h2>
    </div>

    {/* Top-right — CTA (GWS button style), dropped to the bottom of its cell */}
    <div class="flex items-end justify-start lg:col-start-2 lg:row-start-1 lg:justify-end">
      <Button variant="primary" href={ctaData.link} client:visible>
        {ctaData.text}
      </Button>
    </div>

    {/* Lower-left — copyright + Ask-AI prompt buttons */}
    <div class="flex flex-col gap-6 lg:col-start-1 lg:row-start-2">
      <p class="text-sm text-muted">
        &copy; {new Date().getFullYear()}
        {siteData.legalName}
      </p>
      <!-- <AIIconPrompt
        prompt={aiFooterPrompt}
        className="items-start text-left lg:flex-row lg:justify-start"
        listClassName="justify-start"
        client:visible
      /> -->
    </div>

    {/* Lower-right — LEGAL + SOCIAL, aligned under the CTA */}
    <div
      class="flex flex-wrap gap-x-16 gap-y-10 lg:col-start-2 lg:row-start-2 lg:justify-end"
    >
      <div class="flex flex-col gap-3">
        {/* Legal links + "Your Privacy Choices" come through as one item list
            (see legalMenuItems above), so the hover-mutes-the-rest effect spans
            all of them. */}
        <ContentRenderer
          id="footer-legal-section"
          items={legalMenuItems}
          variant="FooterMenuVariant"
          title="Legal"
          showButtonSection={false}
          className={legalColClass}
        />
      </div>
      <div>
        <p class="footer-col__heading">Social</p>
        <ContentRenderer
          id="footer-social-section"
          query={query("social-media")}
          variant="SocialMediaBareVariant"
          size="lg"
          alignment="left"
        />
      </div>
    </div>
  </div>

  {/* Bottom legal bar + preference controls — commented out for now. */}
  {/* <div class="border-t border-border-soft">
    <div
      class="inner-section flex flex-col gap-4 py-8 text-text text-sm sm:flex-row sm:items-center sm:justify-between"
      role="region"
      aria-label="Legal notice and preference controls"
    >
      <p class="text-center sm:text-left">
        &copy; {new Date().getFullYear()}
        {siteData.legalName}. All rights reserved.
      </p>
      <PreferencesLayout showHeading={false} layout="horizontal" class="w-full sm:w-auto" />
    </div>
  </div> */}
</footer>

<style>
  .footer-col__heading {
    margin-bottom: 1rem;
    font-size: 0.875rem;
    font-weight: 300;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    /* --color-muted is 5.15:1 on the flat footer bg — clears WCAG AA (4.5:1) at
       this size/weight, so the muted hierarchy is kept. (Only muted OVER the
       About photo, e.g. .stat-label, had to switch to solid text.) */
    color: var(--color-muted);
  }
  /* Social glyph styling now lives in SocialMediaBareVariant — no overrides needed. */
</style>
