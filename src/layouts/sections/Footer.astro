---
// src/layouts/Footer.astro
/**
 * Footer Component
 *
 * Site-wide footer with:
 * - Copyright notice
 * - Social media links
 * - Legal links (Privacy Policy, Cookie Policy)
 * - Cookie preferences button (client-side)
 * - Reading preferences button (client-side)
 */
import { siteData, ctaData } from "@/content/siteData";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { query } from "@/utils/query";
import PreferencesLayout from "@/layouts/PreferencesLayout.astro";
import Section from "@/components/Section.astro";
import { roots, related } from "@/utils/query/snippets";
import Logo from "@/components/Logo/Logo.astro";
import Button from "@/components/Button/Button";
---

<Section
  tag="footer"
  class="mt-auto relative"
  role="contentinfo"
  aria-label="Site footer"
>
  <div class="mx-auto w-full relative">
    <div class="section-dim-border"></div>

    <div class="relative">
      <nav
        aria-label="Footer navigation"
        class="inner-section py-12 text-left"
      >
        <div class="flex flex-col gap-10 xl:flex-row xl:items-start xl:justify-between">
          <div class="flex max-w-lg flex-col items-start gap-6 text-sm xl:flex-[0_0_min(32rem,34%)]">
            <Logo
              loading="lazy"
              trigger="visible"
              animateOutText={false}
              loop={false}
              class="gap-2"
              logoMediaClass="block w-[64px] h-[64px] lg:w-[70px] lg:h-[70px] object-contain"
              logoWidths={[70, 120, 150]}
              logoSizes="(min-width: 1024px) 68px, 60px"
              titleFirstClass="text-4xl lg:text-5xl -ml-[0.1rem] leading-tight no-translate"
              titleRestClass="font-light emphasized-text uppercase text-sm md:text-base lg:text-lg p-0 m-0 tracking-[0.25em]"
              altContext="Footer"
            />
            <p class="text-lg md:text-xl text-text">
              {
                siteData?.tagline ??
                  "Ready to give your business the fast, secure website it deserves?"
              }
            </p>
            <ContentRenderer
              query={related("menu-items", "menu", "footer-menu")}
              variant="ListVariant"
              title="Legal Links"
              className="text-bg flex flex-col items-start justify-center"
              showHeadingDivider
            />
          </div>

          <div class="flex flex-1 flex-col items-start gap-8">
            <ContentRenderer
              query={query("social-media")}
              variant="SocialMediaVariant"
              title="Follow Us"
              alignment="left"
            />

            <div class="flex w-full flex-col gap-8 lg:flex-row lg:flex-wrap lg:items-start lg:justify-between">
              <div class="flex-1 min-w-[12rem]">
                <ContentRenderer
                  query={roots("industries")}
                  variant="ListVariant"
                  showButtonSection={false}
                  showHeadingDivider
                />
              </div>

              <div class="flex-1 min-w-[12rem]">
                <ContentRenderer
                  query={roots("capabilities")}
                  variant="ListVariant"
                  showButtonSection={false}
                  showHeadingDivider
                />
              </div>

              <div class="flex-1 min-w-[12rem]">
                <ContentRenderer
                  query={roots("solutions")}
                  variant="ListVariant"
                  title="Solutions"
                  showButtonSection={false}
                  showHeadingDivider
                />
              </div>
            </div>
          </div>
        </div>
      </nav>
    </div>

    <div class="relative">
      <div class="section-dim-border"></div>
      <div
        class="inner-section flex flex-col gap-4 text-text text-sm py-6 sm:flex-row sm:items-center sm:justify-between"
        role="region"
        aria-label="Legal notice and preference controls"
      >
        <p class="text-center sm:text-right">
          &copy; {new Date().getFullYear()}
          {siteData.legalName}. All rights reserved.
        </p>
        <PreferencesLayout
          showHeading={false}
          layout="horizontal"
          class="w-full sm:w-auto"
        />
      </div>
    </div>
  </div>
</Section>
