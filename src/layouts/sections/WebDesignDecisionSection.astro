---
import CapabilityTopicShowcaseSection from "@/layouts/sections/CapabilityTopicShowcaseSection.astro";
import { pricingCtaData } from "@/content/siteData";

const decisionCards = [
  {
    icon: "lucide:sparkles",
    title: "Starting From Scratch",
    description:
      "Need a brand-new website? Go to pricing to compare the website options built for fresh launches.",
    url: pricingCtaData.link,
  },
  {
    icon: "fa6-solid:pen-ruler",
    title: "Working With An Existing Site",
    description:
      "Already have a website? Go to the redesign path instead of starting with new-build pricing.",
    url: "/website-redesign",
  },
];
---

<CapabilityTopicShowcaseSection
  title="Choose Your Path"
  heading="Starting from scratch or redesigning what you already have?"
  description="Pick the path that matches the project now so the next step feels more direct and less confusing."
  cards={decisionCards}
  className="web-design-decision-showcase"
  sectionMinHeightClass="lg:min-h-[72svh]"
>
  <Fragment slot="content">
    <p>A new website and an existing-site redesign are not the same starting point, so they should not force people through the same path.</p>
    <p>This keeps the decision simple: new build to pricing, existing site to the redesign route.</p>
  </Fragment>

  <div slot="demo" class="web-design-decision-demo-shell" aria-hidden="true"></div>
</CapabilityTopicShowcaseSection>

<style>
  .web-design-decision-demo-shell {
    width: 100%;
    min-height: 22rem;
    border-radius: 2rem;
    border: 1px dashed color-mix(in srgb, var(--color-primary-light) 18%, transparent);
    background:
      radial-gradient(circle at top left, color-mix(in srgb, var(--color-primary) 14%, transparent), transparent 42%),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-primary) 7%, transparent) 0%,
        transparent 100%
      );
  }

  @media (min-width: 1024px) {
    .web-design-decision-demo-shell {
      min-height: 28rem;
    }
  }
</style>
