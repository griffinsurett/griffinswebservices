---
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";

interface Item {
  title: string;
  description: string;
  eyebrow?: string;
}

interface Props {
  title?: string;
  heading?: string | Record<string, unknown>;
  description?: string;
  items?: Item[];
}

const {
  title,
  heading,
  description,
  items = [],
} = Astro.props as Props;
---

<ContentRenderer
  items={items}
  variant="SplitHighlightsVariant"
  title={title}
  heading={heading}
  description={description}
/>
