---
import koiDesktop from "@/assets/projects/koiroofingandsolar.com.jpg";
import koiMobile from "@/assets/projects/koiroofingandsolar.com-mobile-old.jpg";
import prontoDesktop from "@/assets/projects/pronto-junk-removal.jpg";
import prontoDesktopAlt from "@/assets/projects/pronto-junk-removal2.jpg";
import roonysDesktop from "@/assets/projects/roonys-marketing.jpg";
import beyondDesktop from "@/assets/projects/beyond-strength.jpg";
import tsfDesktop from "@/assets/projects/tsf.jpg";
import cbcDesktopAlt from "@/assets/projects/CBC copy.jpg";

interface Props {
  className?: string;
  id?: string;
}

const { className = "", id = "web-design-showcase" } = Astro.props as Props;

const cards = [
  {
    title: "Faria's Demolition alternate desktop website preview",
    src: "/project-images-and-videos/fariasdemolition.com/images/fariasdemolition.com-desktop copy.jpg",
    cardClass:
      "relative overflow-hidden border border-[color-mix(in_srgb,var(--color-heading)_24%,transparent)] shadow-[0_24px_60px_rgba(0,0,0,0.32),inset_0_1px_0_rgba(255,255,255,0.06)] hidden lg:col-start-1 lg:row-start-1 lg:row-span-2 lg:block",
    imageClass: "object-top",
  },
  {
    title: "Tok Secret Formula desktop website preview",
    src: tsfDesktop,
    cardClass:
      "relative overflow-hidden border border-[color-mix(in_srgb,var(--color-heading)_24%,transparent)] shadow-[0_24px_60px_rgba(0,0,0,0.32),inset_0_1px_0_rgba(255,255,255,0.06)] hidden lg:col-start-2 lg:row-start-1 lg:row-span-2 lg:block",
    imageClass: "object-top",
  },
  {
    title: "Koi Roofing and Solar desktop website preview",
    src: koiDesktop,
    cardClass:
      "relative overflow-hidden border border-[color-mix(in_srgb,var(--color-heading)_24%,transparent)] shadow-[0_24px_60px_rgba(0,0,0,0.32),inset_0_1px_0_rgba(255,255,255,0.06)] lg:col-start-3 lg:row-start-1",
    imageClass: "object-top",
  },
  {
    title: "Roony's Marketing desktop website preview",
    src: roonysDesktop,
    cardClass:
      "relative overflow-hidden border border-[color-mix(in_srgb,var(--color-heading)_24%,transparent)] shadow-[0_24px_60px_rgba(0,0,0,0.32),inset_0_1px_0_rgba(255,255,255,0.06)] lg:col-start-3 lg:row-start-2",
    imageClass: "object-top",
  },
  {
    title: "Koi Roofing and Solar mobile website preview",
    src: koiMobile,
    cardClass:
      "relative overflow-hidden border border-[color-mix(in_srgb,var(--color-heading)_24%,transparent)] shadow-[0_24px_60px_rgba(0,0,0,0.32),inset_0_1px_0_rgba(255,255,255,0.06)] lg:col-start-4 lg:row-start-1 lg:row-span-2",
    imageClass: "object-[78%_top]",
  },
  {
    title: "Pronto Junk Removal desktop website preview",
    src: prontoDesktop,
    cardClass:
      "relative overflow-hidden border border-[color-mix(in_srgb,var(--color-heading)_24%,transparent)] shadow-[0_24px_60px_rgba(0,0,0,0.32),inset_0_1px_0_rgba(255,255,255,0.06)] lg:col-start-5 lg:row-start-1",
    imageClass: "object-top",
  },
  {
    title: "Beyond Strength Fitness desktop website preview",
    src: beyondDesktop,
    cardClass:
      "relative overflow-hidden border border-[color-mix(in_srgb,var(--color-heading)_24%,transparent)] shadow-[0_24px_60px_rgba(0,0,0,0.32),inset_0_1px_0_rgba(255,255,255,0.06)] lg:col-start-5 lg:row-start-2",
    imageClass: "object-top",
  },
  {
    title: "Pronto Junk Removal alternate desktop website preview",
    src: prontoDesktopAlt,
    cardClass:
      "relative overflow-hidden border border-[color-mix(in_srgb,var(--color-heading)_24%,transparent)] shadow-[0_24px_60px_rgba(0,0,0,0.32),inset_0_1px_0_rgba(255,255,255,0.06)] hidden lg:col-start-6 lg:row-start-1 lg:row-span-2 lg:block",
    imageClass: "object-top",
  },
  {
    title: "Certified Bag Chasers alternate desktop website preview",
    src: cbcDesktopAlt,
    cardClass:
      "relative overflow-hidden border border-[color-mix(in_srgb,var(--color-heading)_24%,transparent)] shadow-[0_24px_60px_rgba(0,0,0,0.32),inset_0_1px_0_rgba(255,255,255,0.06)] hidden lg:col-start-7 lg:row-start-1 lg:row-span-2 lg:block",
    imageClass: "object-top",
  },
] as const;

const mobileCards = [
  {
    title: "Faria's Demolition desktop website preview",
    src: "/project-images-and-videos/fariasdemolition.com/images/fariasdemolition.com-desktop.jpg",
    cardClass:
      "relative h-screen w-[18rem] shrink-0 overflow-hidden border border-[color-mix(in_srgb,var(--color-heading)_24%,transparent)] shadow-[0_18px_40px_rgba(0,0,0,0.28),inset_0_1px_0_rgba(255,255,255,0.05)]",
  },
  {
    title: "Tok Secret Formula alternate mobile website preview",
    src: "/project-images-and-videos/ttsf/tsf-demo.vercel.app-2026-03-15T22-00-01-884Z-mobile.jpg",
    cardClass:
      "relative h-screen w-[18rem] shrink-0 overflow-hidden border border-[color-mix(in_srgb,var(--color-heading)_24%,transparent)] shadow-[0_18px_40px_rgba(0,0,0,0.28),inset_0_1px_0_rgba(255,255,255,0.05)]",
  },
  {
    title: "Pronto Junk Removal desktop website preview",
    src: prontoDesktop,
    cardClass:
      "relative h-screen w-[18rem] shrink-0 overflow-hidden border border-[color-mix(in_srgb,var(--color-heading)_24%,transparent)] shadow-[0_18px_40px_rgba(0,0,0,0.28),inset_0_1px_0_rgba(255,255,255,0.05)]",
  },
  {
    title: "Koi Roofing and Solar mobile website preview",
    src: "/project-images-and-videos/koiroofingandsolar.com/images/koiroofingandsolar.com-2026-03-15T06-25-07-528Z-mobile.jpg",
    cardClass:
      "relative h-screen w-[18rem] shrink-0 overflow-hidden border border-[color-mix(in_srgb,var(--color-heading)_24%,transparent)] shadow-[0_18px_40px_rgba(0,0,0,0.28),inset_0_1px_0_rgba(255,255,255,0.05)]",
  },
  {
    title: "Beyond Strength Fitness desktop website preview",
    src: beyondDesktop,
    cardClass:
      "relative h-screen w-[18rem] shrink-0 overflow-hidden border border-[color-mix(in_srgb,var(--color-heading)_24%,transparent)] shadow-[0_18px_40px_rgba(0,0,0,0.28),inset_0_1px_0_rgba(255,255,255,0.05)]",
  },
  {
    title: "Tok Secret Formula mobile website preview",
    src: "/project-images-and-videos/toksecretformula.com/images/tsf-mobile.jpg",
    cardClass:
      "relative h-screen w-[18rem] shrink-0 overflow-hidden border border-[color-mix(in_srgb,var(--color-heading)_24%,transparent)] shadow-[0_18px_40px_rgba(0,0,0,0.28),inset_0_1px_0_rgba(255,255,255,0.05)]",
  },
] as const;
---

<section
  id={id}
  class={`relative isolate overflow-visible p-4 ${className}`.trim()}
  aria-label="Selected web design portfolio showcase"
>
  <div class="bottom-image-fade hidden w-max max-w-none gap-2 lg:grid lg:h-[100svh] lg:[grid-template-columns:clamp(17rem,20vw,23rem)_clamp(17rem,20vw,23rem)_clamp(17rem,20vw,23rem)_clamp(11rem,13vw,14rem)_clamp(17rem,20vw,23rem)_clamp(17rem,20vw,23rem)_clamp(17rem,20vw,23rem)] lg:[grid-template-rows:minmax(0,1fr)_minmax(0,1fr)] lg:-translate-x-[clamp(7rem,10vw,12rem)]">
    {cards.map((card, index) => (
      <article class={card.cardClass}>
        <img
          src={typeof card.src === "string" ? card.src : card.src.src}
          alt={card.title}
          width={typeof card.src === "string" ? undefined : card.src.width}
          height={typeof card.src === "string" ? undefined : card.src.height}
          loading={index < 2 ? "eager" : "lazy"}
          class={`block size-full object-cover scale-[1.01] ${card.imageClass}`.trim()}
        />
      </article>
    ))}
  </div>

  <div class="bottom-image-fade flex h-screen w-max max-w-none items-start gap-2 -translate-x-16 lg:hidden">
    {mobileCards.map((card, index) => (
      <article class={card.cardClass}>
        <img
          src={typeof card.src === "string" ? card.src : card.src.src}
          alt={card.title}
          width={typeof card.src === "string" ? undefined : card.src.width}
          height={typeof card.src === "string" ? undefined : card.src.height}
          loading={index < 2 ? "eager" : "lazy"}
          class="block h-full w-full bg-[rgb(10,10,12)] object-contain object-top"
        />
      </article>
    ))}
  </div>
</section>
