---
import Section from "@/components/Section.astro";
import CapabilityQuoteForm from "@/components/Form/forms/CapabilityQuoteForm.astro";
import Icon from "@/components/Icon";
import SectionHeader from "@/components/SectionHeader.astro";

interface Props {
  title?: string;
  capabilityTitle?: string;
  heading?: string;
  description?: string;
  className?: string;
}

const {
  title,
  capabilityTitle,
  heading = "Thinking about your next website move?",
  description = "Share the basics here and we will review the scope, the budget range, and the clearest next step for your website.",
  className = "",
} = Astro.props as Props;

const resolvedCapabilityTitle = capabilityTitle ?? title ?? "Capability";

const highlights = [
  {
    icon: "lucide:scan-search",
    title: "Clear next step",
    description: "We look at the real scope first, then tell you whether this is a refresh, a rebuild, or something more custom.",
  },
  {
    icon: "lucide:rocket",
    title: "Budget alignment",
    description: "A rough budget range helps us recommend the right path without wasting time on the wrong solution.",
  },
  {
    icon: "lucide:messages-square",
    title: "Built around your business",
    description: "The conversation starts with your goals, your pages, and what the website actually needs to handle.",
  },
];
---

<Section class={`outer-section ${className}`.trim()}>
  <div class="inner-section">
    <div class="capability-quote-layout">
      <div class="capability-quote-copy">
        <SectionHeader
          title="Request a Quote"
          heading={heading}
          description={`If you are planning ${resolvedCapabilityTitle.toLowerCase()} work, ${description.toLowerCase()}`}
          className="text-left"
          headingClassName="h2 mb-6 text-heading"
          emphasisClassName="text-heading"
          descriptionClassName="large-text max-w-2xl"
        />

        <ul class="capability-quote-highlights">
          {highlights.map((item) => (
            <li class="capability-quote-highlight">
              <span class="capability-quote-icon" aria-hidden="true">
                <Icon icon={item.icon} size="sm" />
              </span>
              <div class="space-y-1">
                <p class="capability-quote-highlight-title">{item.title}</p>
                <p class="capability-quote-highlight-text">{item.description}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div class="capability-quote-card section-box card-bg">
        <div class="capability-quote-card__header">
          <h3 class="capability-quote-card__title">Start your quote</h3>
          <p class="capability-quote-card__description">
            Send the basics and we will follow up with the right recommendation for your website.
          </p>
        </div>
        <CapabilityQuoteForm capabilityTitle={resolvedCapabilityTitle} />
      </div>
    </div>
  </div>
</Section>

<style>
  .capability-quote-layout {
    display: grid;
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
  }

  .capability-quote-copy {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .capability-quote-highlights {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
  }

  .capability-quote-highlight {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
  }

  .capability-quote-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 999px;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-primary) 18%, transparent);
    flex-shrink: 0;
  }

  .capability-quote-highlight-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-heading);
  }

  .capability-quote-highlight-text {
    margin: 0;
    max-width: 30rem;
    line-height: 1.55;
    color: color-mix(in srgb, var(--color-text) 74%, transparent);
  }

  .capability-quote-card {
    position: relative;
    overflow: hidden;
    box-shadow: 0 35px 90px -48px rgba(0, 0, 0, 0.55);
  }

  .capability-quote-card__header {
    margin-bottom: 1.5rem;
  }

  .capability-quote-card__title {
    margin: 0;
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--color-heading);
  }

  .capability-quote-card__description {
    margin: 0.65rem 0 0;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-text) 74%, transparent);
  }

  .capability-quote-card :global(form > .mt-6) {
    display: flex;
    justify-content: flex-start;
  }

  .capability-quote-card :global(form > .mt-6 > span) {
    width: auto !important;
    justify-content: flex-start;
  }

  .capability-quote-card :global(form > .mt-6 > span > a),
  .capability-quote-card :global(form > .mt-6 > span > button) {
    width: auto !important;
  }

  @media (min-width: 1024px) {
    .capability-quote-layout {
      grid-template-columns: minmax(0, 1fr) minmax(22rem, 0.95fr);
    }
  }
</style>
