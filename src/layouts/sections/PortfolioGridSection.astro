---
import PortfolioMediaTile from "@/components/LoopComponents/Portfolio/PortfolioMediaTile.astro";
import { animationProps } from "@/integrations/scroll-animations/props";
import { query, sortByOrder } from "@/utils/query";

interface Props {
  className?: string;
  id?: string;
  limit?: number;
}

const {
  className = "",
  id = "portfolio-grid",
  limit,
} = Astro.props as Props;

const projectsQuery = query("projects").orderBy(sortByOrder());
const items =
  typeof limit === "number" ? await projectsQuery.limit(limit).all() : await projectsQuery.all();
---

<section
  id={id}
  class={`inner-section py-6 lg:py-10 ${className}`.trim()}
  {...animationProps("fade-in-up", { once: false, threshold: 0.15 })}
>
  <div class="grid items-stretch gap-6 md:grid-cols-2 lg:grid-cols-3">
    {
      items.map((item) => (
        <PortfolioMediaTile item={item} />
      ))
    }
  </div>
</section>
