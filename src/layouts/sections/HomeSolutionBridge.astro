---
import { Image } from "astro:assets";
import Section from "@/components/Section.astro";
import BackgroundMediaFrame from "@/components/BackgroundMediaFrame.astro";
import Button from "@/components/Button/Button";
import FacebookStars from "@/components/FacebookStars";
import Icon from "@/components/Icon";
import Counter from "@/components/Counter.astro";
import FloatingLogoBadge from "@/components/FloatingLogoBadge.astro";
import { contactCtaData, pricingCtaData } from "@/content/siteData";
import { byItemKeys } from "@/utils/query/snippets";
import { animationProps } from "@/integrations/scroll-animations/props";
import performanceImg from "@/assets/100performance.png";
import meoncompImg from "@/assets/meoncomp.jpg";

interface Props {
  primaryCtaText?: string;
  primaryCtaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
}

const {
  primaryCtaText = contactCtaData.text,
  primaryCtaLink = contactCtaData.link,
  secondaryCtaText = "See Pricing",
  secondaryCtaLink = pricingCtaData.link,
} = Astro.props as Props;

const proofEntry = await byItemKeys("about-us", "our-proof").first();

const bridgeHeading =
  typeof proofEntry?.data.heading === "string"
    ? proofEntry.data.heading
    : "We build websites that help people trust you and take the next step.";

const bridgeDescription =
  proofEntry?.data.description ??
  "We build your site on a strong base so it stays fast, clear, and easy to use. We also set it up so Google and AI tools can understand it better. The goal is simple: help more people find you, trust you, and contact you.";

const facebookReviewsLink =
  proofEntry?.data.reviewLink ??
  "https://www.facebook.com/profile.php?id=61588357260507&sk=reviews";

const reviewLabel =
  proofEntry?.data.reviewLabel ?? "Across the businesses we work with";

const statValue = proofEntry?.data.statValue ?? 3.5;
const statPrefix = proofEntry?.data.statPrefix ?? "$";
const statSuffix = proofEntry?.data.statSuffix ?? "M+";
const statDescription =
  proofEntry?.data.statDescription ?? "in combined annual revenue.";

const features =
  proofEntry?.data.featureItems?.length
    ? proofEntry.data.featureItems
    : [
        {
          icon: "lu:badge-check",
          text: "Built To Win Trust",
        },
        {
          icon: "lu:rocket",
          text: "Fast Turnaround",
        },
        {
          icon: "lu:shield-check",
          text: "Support That Stays",
        },
      ];

const performanceImageSrc = performanceImg;
const performanceImageAlt = "100 performance score graphic";
const bridgeBackgroundImage = meoncompImg;

---

<Section class="outer-section">
  <div class="inner-section">
    <div
      class="bridge-roll-shell relative flex flex-col gap-5"
      {...animationProps("fade-in-up", { once: true, threshold: 0.1 })}
    >
      <div
        class="pointer-events-none absolute left-8 top-8 z-20 w-64 overflow-hidden rounded-[1.4rem] border border-text/10 bg-bg/85 shadow-2xl backdrop-blur-xl max-lg:left-5 max-lg:top-0 max-lg:w-44 max-lg:-translate-y-[28%]"
      >
        <Image
          src={performanceImageSrc}
          alt={performanceImageAlt}
          widths={[320, 480, 640]}
          sizes="(min-width: 1024px) 16rem, 11rem"
          class="block aspect-[16/10] w-full object-cover"
        />
      </div>

      <FloatingLogoBadge
        class="bridge-roll-logo-track pointer-events-none absolute inset-x-0 top-[-2.25rem] z-30 h-[4.75rem] overflow-visible max-lg:top-[-1.75rem] max-lg:h-14"
        badgeClassName="bridge-roll-logo"
        imageClassName="block h-14 w-14 object-contain drop-shadow-[0_14px_30px_rgba(0,0,0,0.35)] lg:h-[4.5rem] lg:w-[4.5rem]"
      />

      <BackgroundMediaFrame
        imageSrc={bridgeBackgroundImage}
        imageClass="w-full h-full min-h-[41rem] object-cover max-lg:min-h-[54rem]"
        imageMaxWidth={1600}
        mediaOverlayClass="bg-bg/70"
        className="min-h-[41rem] max-lg:min-h-[54rem]"
      >

        <div
          aria-hidden="true"
          class="absolute inset-0 z-0 bg-[linear-gradient(90deg,rgba(10,11,18,0.78)_0%,rgba(10,11,18,0.18)_36%,rgba(10,11,18,0.78)_100%),linear-gradient(0deg,rgba(10,11,18,0.9)_0%,rgba(10,11,18,0.16)_32%,rgba(10,11,18,0.12)_100%)]"
        ></div>

        <div
          class="absolute bottom-[8.6rem] left-[3.25rem] z-10 max-w-[31rem] p-0 max-lg:hidden"
        >
          <div class="mb-3">
            <FacebookStars href={facebookReviewsLink} />
          </div>

          <p class="mb-2 text-[clamp(1.15rem,1.4vw,1.8rem)] leading-[1.2] text-white/82">
            {reviewLabel}
          </p>

          <h2 class="mb-2 text-white text-[clamp(2.6rem,4vw,5rem)] leading-[1.02] tracking-[-0.04em]">
            <Counter prefix={statPrefix} end={statValue} suffix={statSuffix} class="!gap-[0.01em]" />
          </h2>

          <p class="text-[clamp(1.15rem,1.4vw,1.8rem)] leading-[1.2] text-white/82">
            {statDescription}
          </p>
        </div>

        <div
          class="absolute right-[3.25rem] top-[5.4rem] z-10 w-[min(38rem,45%)] max-lg:hidden"
        >
          <h2
            class="m-0 font-inherit text-white text-[clamp(2.15rem,3.2vw,3.9rem)] leading-[0.98] tracking-[-0.06em] text-balance"
          >
            {bridgeHeading}
          </h2>

          <p
            class="mt-6 max-w-[31rem] font-inherit text-[1.05rem] leading-[1.55] text-white/84"
          >
            {bridgeDescription}
          </p>
        </div>

        <div class="relative z-10 flex min-h-[54rem] flex-col px-6 pb-6 pt-[10.5rem] lg:hidden">
          <div class="max-w-[20rem]">
            <h2 class="m-0 font-inherit text-[clamp(2.1rem,8.6vw,3.4rem)] leading-[0.98] tracking-[-0.06em] text-white">
              {bridgeHeading}
            </h2>

            <p class="mt-6 max-w-[20rem] font-inherit text-[1rem] leading-[1.52] text-white/84">
              {bridgeDescription}
            </p>
          </div>

          <div class="mt-5 w-fit">
            <FacebookStars href={facebookReviewsLink} />
          </div>

          <div class="mt-5 max-w-[22rem]">
            <p class="mb-2 text-[1.1rem] leading-[1.2] text-white/82">
              {reviewLabel}
            </p>

            <h2 class="mb-2 text-[clamp(2.9rem,11vw,4rem)] leading-[1.02] tracking-[-0.04em] text-white">
              <Counter prefix={statPrefix} end={statValue} suffix={statSuffix} class="!gap-[0.01em]" />
            </h2>

            <p class="text-[1.1rem] leading-[1.2] text-white/82">
              {statDescription}
            </p>
          </div>

          <ul class="mt-5 grid list-none grid-cols-1 gap-2" aria-label="Website outcomes">
            {features.map((feature) => (
              <li class="flex min-h-0 items-center justify-start gap-3 text-left text-[0.84rem] font-semibold uppercase tracking-[0.14em] text-white/94">
                <span
                  class="inline-flex h-[2.2rem] w-[2.2rem] shrink-0 items-center justify-center rounded-full border border-white/32 bg-bg/40 text-white backdrop-blur-xl"
                  aria-hidden="true"
                >
                  <Icon icon={feature.icon} size="md" className="text-current" />
                </span>
                <span>{feature.text}</span>
              </li>
            ))}
          </ul>
        </div>

        <ul
          class="absolute inset-x-0 bottom-0 z-10 grid list-none grid-cols-3 gap-3 px-6 pb-7 pt-5 max-lg:hidden"
          aria-label="Website outcomes"
        >
          {features.map((feature) => (
            <li
              class="flex min-h-16 items-center justify-center gap-3 text-center text-[0.94rem] font-semibold uppercase tracking-[0.16em] text-white/94 max-lg:min-h-0 max-lg:justify-start max-lg:text-left max-lg:text-[0.84rem] max-lg:tracking-[0.14em]"
            >
              <span
                class="inline-flex h-[2.2rem] w-[2.2rem] shrink-0 items-center justify-center rounded-full border border-white/32 bg-bg/40 text-white backdrop-blur-xl"
                aria-hidden="true"
              >
                <Icon icon={feature.icon} size="md" className="text-current" />
              </span>
              <span>{feature.text}</span>
            </li>
          ))}
        </ul>
      </BackgroundMediaFrame>

      <div class="mx-auto grid w-full max-w-[42rem] grid-cols-2 gap-6 px-4 lg:px-0 max-lg:grid-cols-1 max-lg:gap-4">
        <div class="flex">
          <Button
            href={primaryCtaLink}
            variant="primary"
            size="lg"
            rightIcon="lu:arrow-up-right"
            fullWidth={true}
            className="whitespace-nowrap justify-center"
            buttonWrapperClasses="w-full"
          >
            {primaryCtaText}
          </Button>
        </div>

        <div class="flex">
          <Button
            client:visible
            href={secondaryCtaLink}
            variant="secondary"
            size="lg"
            rightIcon="lu:arrow-right"
            fullWidth={true}
            className="whitespace-nowrap justify-center"
            buttonWrapperClasses="w-full"
          >
            {secondaryCtaText}
          </Button>
        </div>
      </div>
    </div>
  </div>
</Section>

<style>
  :global(.bridge-roll-logo) {
    position: absolute;
    left: 0;
    top: 0;
    transform: translateX(-50%) rotate(0deg);
    will-change: left, transform;
  }

  @supports (animation-timeline: view()) {
    .bridge-roll-shell {
      view-timeline-name: --bridge-roll-progress;
      view-timeline-axis: block;
    }

    :global(.bridge-roll-logo) {
      animation: bridge-logo-scroll linear both;
      animation-timeline: --bridge-roll-progress;
      animation-range: entry 0% cover 70%;
    }
  }

  @keyframes bridge-logo-scroll {
    from {
      left: 0%;
      transform: translateX(-50%) rotate(0deg);
    }

    to {
      left: 100%;
      transform: translateX(-50%) rotate(1440deg);
    }
  }

  @media (max-width: 1023px) {
    :global(.bridge-roll-logo) {
      transform: translateX(-50%) rotate(0deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.bridge-roll-logo) {
      left: 50%;
      transform: rotate(0deg);
    }
  }
</style>
