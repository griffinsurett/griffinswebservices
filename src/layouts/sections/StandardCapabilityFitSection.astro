---
import Icon from "@/components/Icon";
import Section from "@/components/Section.astro";
import SectionHeader from "@/components/SectionHeader.astro";

interface FitItem {
  title: string;
  description?: string;
}

interface Column {
  title: string;
  items: FitItem[];
  icon?: string;
}

interface Props {
  title?: string;
  heading?: string | Record<string, unknown>;
  description?: string;
  left: Column;
  right: Column;
  className?: string;
}

const {
  title,
  heading,
  description,
  left,
  right,
  className = "",
} = Astro.props as Props;

const columns = [left, right];
---

<Section class={`outer-section relative ${className}`.trim()}>
  <div class="inner-section">
    <SectionHeader
      title={title}
      heading={heading}
      description={description}
      className="mx-auto max-w-5xl text-center"
      headingClassName="h2 mb-6 text-heading"
      descriptionClassName="large-text mx-auto max-w-4xl"
    />

    <div class="standard-capability-fit-grid mt-10">
      {columns.map((column) => (
        <article class="standard-capability-fit-card card-bg">
          <div class="standard-capability-fit-card__top">
            <span class="standard-capability-fit-card__icon" aria-hidden="true">
              <Icon icon={column.icon ?? "lucide:check"} size="sm" />
            </span>
            <h3 class="standard-capability-fit-card__title">{column.title}</h3>
          </div>

          <ul class="standard-capability-fit-card__list">
            {column.items.map((item) => (
              <li class="standard-capability-fit-card__item">
                <p class="standard-capability-fit-card__item-title">{item.title}</p>
                {item.description && (
                  <p class="standard-capability-fit-card__item-description">{item.description}</p>
                )}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</Section>

<style>
  .standard-capability-fit-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  .standard-capability-fit-card {
    padding: 1.6rem;
    border-radius: 1.8rem;
    border: 1px solid color-mix(in srgb, var(--color-primary-light) 14%, transparent);
  }

  .standard-capability-fit-card__top {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .standard-capability-fit-card__icon {
    display: inline-flex;
    width: 2.6rem;
    height: 2.6rem;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    color: var(--color-primary-light);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-primary-light) 18%, transparent);
    flex-shrink: 0;
  }

  .standard-capability-fit-card__title {
    margin: 0;
    color: var(--color-heading);
    font-size: clamp(1.4rem, 1.8vw, 1.85rem);
    line-height: 1.1;
    letter-spacing: -0.04em;
  }

  .standard-capability-fit-card__list {
    display: grid;
    gap: 1rem;
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
  }

  .standard-capability-fit-card__item {
    padding-top: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--color-primary-light) 10%, transparent);
  }

  .standard-capability-fit-card__item-title {
    margin: 0;
    color: var(--color-heading);
    font-size: 1rem;
    line-height: 1.4;
    font-weight: 600;
  }

  .standard-capability-fit-card__item-description {
    margin: 0.35rem 0 0;
    color: var(--color-text);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (min-width: 900px) {
    .standard-capability-fit-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
