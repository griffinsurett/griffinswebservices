---
import Section from "@/components/Section.astro";
import QuoteForm from "@/components/Form/forms/QuoteForm.astro";
import Icon from "@/components/Icon";
import SectionHeader from "@/components/SectionHeader.astro";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { query } from "@/utils/query";

interface Props {
  id?: string;
  className?: string;
  eyebrowTitle?: string;
  showEyebrow?: boolean;
  formComponent?: any;
  formProps?: Record<string, any>;
}

const {
  id = "contact-quote",
  className = "",
  eyebrowTitle = "Request a Quote",
  showEyebrow = true,
  formComponent: FormComponent = QuoteForm,
  formProps = {
    capabilityTitle: "Contact Us",
    capabilitySlug: "contact-us",
    serviceCategory: "contact-us",
    formType: "generic",
    buttonText: "Send quote request",
  },
} = Astro.props as Props;

const highlights = [
  {
    icon: "lucide:scan-search",
    title: "Clearer first step",
    description:
      "A short quote request gives us enough context to tell you whether this is a new build, an improvement project, or ongoing support.",
  },
  {
    icon: "lucide:messages-square",
    title: "More useful follow-up",
    description:
      "We can make the next conversation more specific when we already know your goals, timeline, and what the site needs to do.",
  },
  {
    icon: "lucide:rocket",
    title: "Built around fit",
    description:
      "If we are a good fit, we will show you the clearest next move. If not, we would rather be honest early than waste your time.",
  },
];
---

<Section id={id} class={`outer-section ${className}`.trim()}>
  <div class="inner-section">
    <div class="contact-quote-layout">
      <div class="contact-quote-copy sticky-section lg:self-start">
        <SectionHeader
          title={showEyebrow ? eyebrowTitle : undefined}
          heading="Tell us what you are planning and we will point you in the right direction."
          description="Whether you need a new website, a set of focused improvements, or ongoing support, this is the best place to start."
          className="text-left"
          headingClassName="h2 mb-6 text-heading"
          emphasisClassName="text-heading"
          descriptionClassName="large-text max-w-2xl"
        />

        <ContentRenderer
          query={query("testimonials")
            .where((entry) => entry.data.featured === true)
            .limit(3)}
          variant="TestimonialCirclesCounterVariant"
          className="contact-quote-testimonials"
          counterStart={10}
          counterEnd={100}
          counterDuration={1800}
          counterSuffix="+"
          counterLabel="Happy Clients"
        />

        <ul class="contact-quote-highlights">
          {highlights.map((item) => (
            <li class="contact-quote-highlight">
              <span class="contact-quote-icon" aria-hidden="true">
                <Icon icon={item.icon} size="sm" />
              </span>
              <div class="space-y-1">
                <p class="contact-quote-highlight-title">{item.title}</p>
                <p class="contact-quote-highlight-text">{item.description}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div class="contact-quote-card section-box card-bg">
        <div class="contact-quote-card__header">
          <h3 class="contact-quote-card__title">Start the conversation</h3>
          <p class="contact-quote-card__description">
            Send the basics and we will follow up with the clearest recommendation for your project.
          </p>
        </div>
        <FormComponent {...formProps} />
      </div>
    </div>
  </div>
</Section>

<style>
  .contact-quote-layout {
    display: grid;
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
  }

  .contact-quote-copy {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .contact-quote-highlights {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
  }

  .contact-quote-testimonials {
    padding-inline: 0;
  }

  .contact-quote-highlight {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
  }

  .contact-quote-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 999px;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-primary) 18%, transparent);
    flex-shrink: 0;
  }

  .contact-quote-highlight-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-heading);
  }

  .contact-quote-highlight-text {
    margin: 0;
    max-width: 30rem;
    line-height: 1.55;
    color: color-mix(in srgb, var(--color-text) 74%, transparent);
  }

  .contact-quote-card {
    position: relative;
    overflow: hidden;
    box-shadow: 0 35px 90px -48px rgba(0, 0, 0, 0.55);
  }

  .contact-quote-card__header {
    margin-bottom: 1.5rem;
  }

  .contact-quote-card__title {
    margin: 0;
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--color-heading);
  }

  .contact-quote-card__description {
    margin: 0.65rem 0 0;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-text) 74%, transparent);
  }

  .contact-quote-card :global(form > .mt-6) {
    display: flex;
    justify-content: flex-start;
  }

  .contact-quote-card :global(form > .mt-6 > span) {
    width: auto !important;
    justify-content: flex-start;
  }

  .contact-quote-card :global(form > .mt-6 > span > a),
  .contact-quote-card :global(form > .mt-6 > span > button) {
    width: auto !important;
  }

  @media (min-width: 1024px) {
    .contact-quote-layout {
      grid-template-columns: minmax(0, 1fr) minmax(22rem, 0.95fr);
    }
  }
</style>
