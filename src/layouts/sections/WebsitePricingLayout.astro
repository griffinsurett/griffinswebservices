---
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { sortByOrder } from "@/utils/query";
import { related, children, roots } from "@/utils/query/snippets";

interface SectionCopy {
  id?: string;
  title?: string;
  heading?: string;
  description?: string;
  columns?: 1 | 2 | 3 | 4 | "auto";
  gap?: "sm" | "md" | "lg" | "xl";
}

export interface Props {
  newWebsiteOptions?: SectionCopy;
  existingWebsiteServices?: SectionCopy;
}

const {
  newWebsiteOptions = {},
  existingWebsiteServices = {},
} = Astro.props as Props;
---

<ContentRenderer
  query={related("pricing", "solutions", "websites").orderBy(sortByOrder())}
  variant="PricingVariant"
  id={newWebsiteOptions.id ?? "pricing"}
  columns={newWebsiteOptions.columns ?? 3}
  gap={newWebsiteOptions.gap ?? "lg"}
/>

<ContentRenderer
  query={children("solutions", "website-improvements-upgrades")}
  variant="CardVariant"
  sectionLayout="split"
  id={existingWebsiteServices.id ?? "website-improvements"}
  title={existingWebsiteServices.title ?? "Website Improvements & Upgrades"}
  heading={existingWebsiteServices.heading ?? "Already Have a Website That Needs Work?"}
  description={existingWebsiteServices.description ?? "When the site already exists, we handle cleanup, restructuring, redesign work, and platform-level changes to get it stable, clearer, and easier to grow."}
  columns={existingWebsiteServices.columns ?? "auto"}
  gap={existingWebsiteServices.gap ?? "lg"}
/>
