---
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { sortByOrder } from "@/utils/query";
import { related, children, roots } from "@/utils/query/snippets";

interface SectionCopy {
  id?: string;
  title?: string;
  heading?: string;
  description?: string;
  columns?: 1 | 2 | 3 | 4 | "auto";
  gap?: "sm" | "md" | "lg" | "xl";
}

export interface Props {
  newWebsiteOptions?: SectionCopy;
  existingWebsiteOptions?: SectionCopy;
  existingWebsiteServices?: SectionCopy;
  enhancementOptions?: SectionCopy;
}

const {
  newWebsiteOptions = {},
  existingWebsiteOptions = {},
  existingWebsiteServices = {},
  enhancementOptions = {},
} = Astro.props as Props;
---

<ContentRenderer
  query={related("pricing", "solutions", "websites").orderBy(sortByOrder())}
  variant="PricingVariant"
  id={newWebsiteOptions.id ?? "pricing"}
  title={newWebsiteOptions.title ?? "Website Pricing"}
  heading={newWebsiteOptions.heading ?? "Looking for a Brand-New Website Built to Hold Up and Convert?"}
  description={newWebsiteOptions.description ?? "Choose the website option that fits where your business is now, then move forward with a site built to look professional, load fast, and support real growth from the start."}
  columns={newWebsiteOptions.columns ?? 3}
  gap={newWebsiteOptions.gap ?? "lg"}
/>

<ContentRenderer
  query={roots("enhancements")}
  variant="CardVariant"
  id={enhancementOptions.id ?? "enhancements"}
  title={enhancementOptions.title ?? "Need Something More Specific?"}
  heading={enhancementOptions.heading ?? "Enhancements That Layer Onto the Core Website Work"}
  description={enhancementOptions.description ?? "When you need more than the core build or maintenance path, these enhancement options cover SEO, automation, booking, e-commerce, systems, and brand-supporting work."}
  columns={enhancementOptions.columns ?? "auto"}
  gap={enhancementOptions.gap ?? "lg"}
/>

<ContentRenderer
  query={related("pricing", "capabilities", "hosting").orderBy(sortByOrder())}
  variant="PricingVariant"
  id={existingWebsiteOptions.id ?? "existing-site-options"}
  title={existingWebsiteOptions.title ?? "Existing Website Support"}
  heading={existingWebsiteOptions.heading ?? "Already Have a Website That Needs Hosting, Maintenance, or Ongoing Help?"}
  description={existingWebsiteOptions.description ?? "Keep your existing website stable, secure, and professionally maintained with hosting and support options built for businesses that need dependable ongoing coverage."}
  columns={existingWebsiteOptions.columns ?? 3}
  gap={existingWebsiteOptions.gap ?? "lg"}
/>

<ContentRenderer
  query={children("solutions", "website-improvements-upgrades")}
  variant="CardVariant"
  sectionLayout="split"
  id={existingWebsiteServices.id ?? "website-improvements"}
  title={existingWebsiteServices.title ?? "Website Improvements & Upgrades"}
  heading={existingWebsiteServices.heading ?? "Focused Improvements for Existing Websites"}
  description={existingWebsiteServices.description ?? "When the site already exists, we handle the cleanup, restructuring, and platform-level changes needed to get it stable, clearer, and easier to grow."}
  columns={existingWebsiteServices.columns ?? "auto"}
  gap={existingWebsiteServices.gap ?? "lg"}
/>
