---
import Section from "@/components/Section.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import BackgroundMediaFrame from "@/components/BackgroundMediaFrame.astro";
import DividerLine from "@/components/DividerLine.astro";
import FloatingLogoBadge from "@/components/FloatingLogoBadge.astro";
import TextCarousel from "@/components/TextCarousel.astro";
import { siteData } from "@/content/siteData";
import { byItemKeys } from "@/utils/query/snippets";
import meoncompImg from "@/assets/meoncomp.jpg";
import { animationProps } from "@/integrations/scroll-animations/props";

const missionEntry = await byItemKeys("about-us", "our-mission").first();
const visionEntry = await byItemKeys("about-us", "our-vision").first();
const missionStatement = missionEntry?.data.description ?? siteData.ceoQuote;
const visionStatement =
  visionEntry?.data.description ??
  "My vision is for business owners to have websites that work for them instead of against them, with modern design, fast loading, and a clear structure that helps people trust what they see and take action without delay.";
const statements = [
  { label: "Mission", text: missionStatement },
  { label: "Vision", text: visionStatement },
];
---

<Section class="outer-section">
  <div class="inner-section">
    <div class="px-4 sm:px-6 lg:px-10">
      <SectionHeader
        heading="Recommended by 30+ business owners and 2 marketing agencies."
        description="You focus on running the business. We focus on building a website that loads fast, performs well, and gives people a reason to trust what they see."
        className="text-section text-center"
        headingClassName="h2 mb-6 text-heading"
        emphasisClassName="text-heading"
        descriptionClassName="large-text mx-auto max-w-4xl"
      />

      <div
        class="trust-roll-shell relative mt-10 pb-10"
        {...animationProps("fade-in-up", { once: true, threshold: 0.15 })}
      >
        <BackgroundMediaFrame
          imageSrc={meoncompImg}
          imageClass="h-full w-full min-h-[36rem] object-cover max-lg:min-h-[42rem]"
          imageMaxWidth={1600}
          mediaOverlayClass="bg-bg/80"
          className="min-h-[36rem] max-lg:min-h-[42rem]"
        >
          <div
            aria-hidden="true"
            class="absolute inset-0 z-0 bg-[linear-gradient(90deg,rgba(10,11,18,0.94)_0%,rgba(10,11,18,0.86)_23%,rgba(10,11,18,0.54)_56%,rgba(10,11,18,0.28)_100%)]"
          ></div>

          <div class="relative z-10 grid min-h-[36rem] grid-cols-12 gap-8 px-8 py-10 max-lg:flex max-lg:min-h-[42rem] max-lg:flex-col max-lg:px-6 max-lg:py-8">
            <div class="col-span-4 flex flex-col justify-between pr-8 max-lg:pr-0">
              <div class="space-y-10 max-lg:space-y-8">
                <div>
                  <p class="text-[3.2rem] font-bold leading-none tracking-[-0.06em] text-primary-light max-lg:text-[2.8rem]">
                    30+
                  </p>
                  <p class="mt-3 max-w-[17rem] text-[1.1rem] leading-[1.35] text-secondary-light">
                    business owners recommend us.
                  </p>
                </div>

                <DividerLine className="max-w-[17rem] max-lg:max-w-none" />

                <div>
                  <p class="text-[3.2rem] font-bold leading-none tracking-[-0.06em] text-primary-light max-lg:text-[2.8rem]">
                    2
                  </p>
                  <p class="mt-3 max-w-[17rem] text-[1.1rem] leading-[1.35] text-secondary-light">
                    marketing agencies refer us for their clients website needs.
                  </p>
                </div>
              </div>

              <div class="max-w-[20rem]">
              </div>
            </div>

            <DividerLine
              orientation="vertical"
              className="col-span-1 justify-self-center max-lg:hidden"
            />

            <DividerLine className="hidden max-lg:block" />

            <div class="col-span-7 flex flex-col justify-center pl-4 max-lg:pl-0">
              <div class="max-w-[42rem]">
                <div
                  class="max-w-[44rem]"
                >
                  <TextCarousel
                    items={statements}
                    quoteMarks={true}
                    textClassName="text-[clamp(1.75rem,2.45vw,2.75rem)] leading-[1.08] tracking-[-0.05em] text-primary-light max-lg:text-[clamp(1.5rem,6.5vw,2.25rem)]"
                  />
                </div>
                <div class="mt-8">
                  <p class="text-[1.6rem] font-semibold uppercase leading-[1.05] tracking-[0.12em] text-primary-light max-lg:text-[1.3rem]">
                    Griffin Surett
                  </p>
                  <p class="text-[1.08rem] leading-[1.2] text-text">
                    Founder
                  </p>
                </div>
              </div>
            </div>
          </div>
        </BackgroundMediaFrame>

        <FloatingLogoBadge
          class="trust-roll-logo-track pointer-events-none absolute bottom-[0.9rem] left-1/2 z-30 h-[4.75rem] w-screen -translate-x-1/2 translate-y-[10%] overflow-visible max-lg:h-14"
          badgeClassName="trust-roll-logo inline-flex h-[4.75rem] w-[4.75rem] items-center justify-center lg:h-[5.5rem] lg:w-[5.5rem]"
          imageClassName="block h-14 w-14 object-contain drop-shadow-[0_14px_30px_rgba(0,0,0,0.35)] lg:h-[4.5rem] lg:w-[4.5rem]"
        />
      </div>
    </div>
  </div>
</Section>

<style>
  :global(.trust-roll-logo) {
    position: absolute;
    left: 50%;
    top: 0;
    transform: translateX(-50%) rotate(0deg);
    will-change: left, transform;
  }

  @supports (animation-timeline: view()) {
    .trust-roll-shell {
      view-timeline-name: --trust-roll-progress;
      view-timeline-axis: block;
    }

    :global(.trust-roll-logo) {
      animation: trust-logo-scroll linear both;
      animation-timeline: --trust-roll-progress;
      animation-range: entry 30% cover 82%;
    }
  }

  @keyframes trust-logo-scroll {
    from {
      left: 0%;
      transform: translateX(-50%) rotate(0deg);
    }

    to {
      left: 100%;
      transform: translateX(-50%) rotate(1440deg);
    }
  }

  @media (max-width: 1023px) {
    :global(.trust-roll-logo) {
      left: 50%;
      transform: translateX(-50%) rotate(0deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.trust-roll-logo) {
      left: 50%;
      transform: translateX(-50%) rotate(0deg);
    }
  }
</style>
