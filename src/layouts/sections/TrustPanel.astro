---
import Section from "@/components/Section.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import BackgroundMediaFrame from "@/components/BackgroundMediaFrame.astro";
import DividerLine from "@/components/DividerLine.astro";
import FacebookStars from "@/components/FacebookStars";
import FloatingLogoBadge from "@/components/FloatingLogoBadge.astro";
import Logo from "@/components/Logo/Logo.astro";
import AIIconPrompt from "@/components/Footer/AIIconPrompt";
import Counter from "@/components/Counter";
import TextCarousel from "@/components/TextCarousel.astro";
import { siteData } from "@/content/siteData";
import { byItemKeys } from "@/utils/query/snippets";
import meoncompImg from "@/assets/meoncomp.jpg";
import { animationProps } from "@/integrations/scroll-animations/props";

const missionEntry = await byItemKeys("about-us", "our-mission").first();
const proofEntry = await byItemKeys("about-us", "our-proof").first();
const visionEntry = await byItemKeys("about-us", "our-vision").first();
const missionStatement = missionEntry?.data.description ?? siteData.ceoQuote;
const visionStatement =
  visionEntry?.data.description ??
  "My vision is for business owners to have websites that are easy to trust, easy to use, and built to help them grow.";
const facebookReviewsLink =
  proofEntry?.data.reviewLink ??
  "https://www.facebook.com/profile.php?id=61588357260507&sk=reviews";
const statements = [
  { label: "Mission", text: missionStatement },
  { label: "Vision", text: visionStatement },
];

const trustStatEntries = await byItemKeys("stats", [
  "recommended-by-business-owners",
  "agency-referrals",
]).all();

const toNumericValue = (value: unknown): number | undefined => {
  if (typeof value === "number" && Number.isFinite(value)) return value;
  if (typeof value === "string") {
    const parsed = Number(value.replace(/,/g, "").trim());
    return Number.isFinite(parsed) ? parsed : undefined;
  }
  return undefined;
};

const getDecimalPlaces = (value?: number) => {
  if (typeof value !== "number" || !Number.isFinite(value)) return 0;
  const [, decimals] = value.toString().split(".");
  return decimals ? decimals.length : 0;
};

const createTrustStat = (
  entry: any,
  fallback: { value: number; start?: number; prefix?: string; suffix?: string; description: string },
) => {
  const data = entry?.data ?? {};
  const value = toNumericValue(data.statValue) ?? fallback.value;
  const start = toNumericValue(data.statStart) ?? fallback.start ?? 0;
  const prefix = typeof data.statPrefix === "string" ? data.statPrefix : (fallback.prefix ?? "");
  const suffix = typeof data.statSuffix === "string" ? data.statSuffix : (fallback.suffix ?? "");
  const description =
    typeof data.description === "string" && data.description.trim().length > 0
      ? data.description
      : fallback.description;

  return {
    value,
    start,
    prefix,
    suffix,
    description,
    decimals: Math.max(getDecimalPlaces(value), getDecimalPlaces(start)),
  };
};

const trustStats = [
  createTrustStat(trustStatEntries[0], {
    value: 30,
    suffix: "+",
    description: "business owners recommend us.",
  }),
  createTrustStat(trustStatEntries[1], {
    value: 2,
    description: "marketing agencies send clients to us for website work.",
  }),
];

const aiTrustPanelPrompt = `I'm researching ${siteData.title} for a potential website project.

Based on their website, give me a clear, decision-focused summary that covers:
- their strongest service and technical strengths
- what kinds of businesses they seem best suited for
- how they handle design, development, SEO/AEO, performance, maintenance, and long-term support
- what makes them a better option than a cheap template site, a solo freelancer, or a typical agency
- the key questions a business owner should ask before hiring them, and how well ${siteData.title} appears to answer those questions
- whether they seem like a strong fit for a business that wants a fast, professional website that can keep improving over time

Use this site as the source: ${siteData.url}

Keep it practical, specific, and favorable where the evidence supports it.`;
---

<Section class="outer-section">
  <div class="inner-section">
    <div class="px-4 sm:px-6 lg:px-10">
      <SectionHeader
        heading="Recommended by 30+ business owners and 2 marketing agencies."
        description="You run the business. We build the website so it loads fast, feels clear, and gives people a reason to trust you."
        className="text-section text-center"
        headingClassName="h2 mb-6 text-heading"
        emphasisClassName="text-heading"
        descriptionClassName="large-text mx-auto max-w-4xl"
      />

      <div
        class="trust-roll-shell relative mt-10 overflow-visible pb-10"
      >
        <BackgroundMediaFrame
          imageSrc={meoncompImg}
          imageClass="h-full w-full min-h-[36rem] object-cover max-lg:min-h-[42rem]"
          imageMaxWidth={1600}
          mediaOverlayClass="bg-bg/80"
          className="min-h-[36rem] max-lg:min-h-[42rem]"
          animate="fade-in-up"
          animationOptions={{ once: false, directional: true, threshold: 0.1 }}
        >
          <div
            aria-hidden="true"
            class="absolute inset-0 z-0 bg-[linear-gradient(90deg,rgba(10,11,18,0.94)_0%,rgba(10,11,18,0.86)_23%,rgba(10,11,18,0.54)_56%,rgba(10,11,18,0.28)_100%)]"
          ></div>

          <div class="relative z-10 grid min-h-[36rem] grid-cols-12 gap-8 pl-5 py-10 max-lg:flex max-lg:min-h-[42rem] max-lg:flex-col max-lg:px-5 max-lg:py-8">
            <div
              class="col-span-3 flex flex-col"
              {...animationProps("fade-in", { once: true, threshold: 0.15 })}
            >
              <div class="space-y-10 max-lg:space-y-8">
                <div>
                  <p class="text-[3.2rem] font-semibold leading-none tracking-[-0.06em] text-primary-light max-lg:text-[2.8rem]">
                    <span class="inline-flex items-baseline">
                      {trustStats[0].prefix && <span>{trustStats[0].prefix}</span>}
                      <Counter
                        client:visible
                        start={trustStats[0].start}
                        end={trustStats[0].value}
                        duration={1800}
                        decimals={trustStats[0].decimals}
                        className="leading-none"
                      />
                      {trustStats[0].suffix && <span>{trustStats[0].suffix}</span>}
                    </span>
                  </p>
                  <p class="mt-3 max-w-[17rem] text-[1.1rem] leading-[1.35] text-secondary-light">
                    {trustStats[0].description}
                  </p>
                </div>

                <DividerLine className="max-w-[17rem] max-lg:max-w-none" />

                <div>
                  <p class="text-[3.2rem] font-semibold leading-none tracking-[-0.06em] text-primary-light max-lg:text-[2.8rem]">
                    <span class="inline-flex items-baseline">
                      {trustStats[1].prefix && <span>{trustStats[1].prefix}</span>}
                      <Counter
                        client:visible
                        start={trustStats[1].start}
                        end={trustStats[1].value}
                        duration={1800}
                        decimals={trustStats[1].decimals}
                        className="leading-none"
                      />
                      {trustStats[1].suffix && <span>{trustStats[1].suffix}</span>}
                    </span>
                  </p>
                  <p class="mt-3 max-w-[17rem] text-[1.1rem] leading-[1.35] text-secondary-light">
                    {trustStats[1].description}
                  </p>
                </div>
              </div>

              <div class="flex flex-1 items-center py-8 max-lg:flex-none max-lg:py-6">
                <FacebookStars href={facebookReviewsLink} className="w-fit" />
              </div>

              <DividerLine className="mb-8 lg:hidden" />

              <div class="max-w-[20rem] max-lg:max-w-none">
                <Logo
                  trigger="visible"
                  loop={false}
                  class="inline-flex"
                  logoMediaClass="block h-[58px] w-[58px] sm:h-[43px] sm:w-[43px] lg:h-[54px] lg:w-[54px] xl:h-[68px] xl:w-[68px] object-contain animate-spin-once"
                  logoWidths={[86, 136, 180]}
                  logoSizes="(min-width: 1280px) 68px, (min-width: 1024px) 54px, (min-width: 640px) 43px, 86px"
                  titleFirstClass="text-[3.15rem] sm:text-3xl lg:text-4xl xl:text-[2.8rem] -ml-[0.1rem]"
                  titleRestClass="text-[0.92rem] sm:text-xs lg:text-[0.8rem] xl:text-[0.96rem] whitespace-nowrap p-0 m-0"
                />
              </div>
            </div>

            <DividerLine
              orientation="vertical"
              className="col-span-1 justify-self-center max-lg:hidden"
            />

            <div
              class="col-span-7 flex flex-col justify-center pl-4 max-lg:pl-0"
              {...animationProps("fade-in", {
                once: true,
                threshold: 0.15,
                delay: 120,
              })}
            >
              <div class="max-w-[42rem]">
                <div
                  class="max-w-[44rem]"
                >
                  <TextCarousel
                    items={statements}
                    quoteMarks={true}
                    textClassName="text-[clamp(1.75rem,2.45vw,2.75rem)] leading-[1.08] tracking-[-0.05em] text-primary-light max-lg:text-[clamp(1.2rem,5.1vw,1.9rem)] max-sm:text-[clamp(1.05rem,4.8vw,1.45rem)]"
                  />
                </div>
                <div class="mt-8">
                  <p class="text-[1.6rem] font-semibold uppercase leading-[1.05] tracking-[0.12em] text-primary-light max-lg:text-[1.3rem]">
                    Griffin Surett
                  </p>
                  <p class="text-[1.08rem] leading-[1.2] text-text">
                    Founder
                  </p>
                </div>

                <div class="mt-8 max-w-[42rem]">
                  <AIIconPrompt
                    prompt={aiTrustPanelPrompt}
                    className="items-center text-center lg:items-center lg:justify-center lg:gap-4 lg:text-center"
                    labelClassName="text-center text-white/60"
                    listClassName="justify-center text-white/72"
                  />
                </div>
              </div>
            </div>
          </div>
        </BackgroundMediaFrame>

        <FloatingLogoBadge
          class="trust-roll-logo-track pointer-events-none absolute bottom-[0.9rem] left-1/2 z-30 h-[4.75rem] w-screen -translate-x-1/2 translate-y-[10%] overflow-visible max-lg:h-14"
          badgeClassName="trust-roll-logo inline-flex h-[4.75rem] w-[4.75rem] items-center justify-center lg:h-[5.5rem] lg:w-[5.5rem]"
          imageClassName="block h-14 w-14 object-contain drop-shadow-[0_14px_30px_rgba(0,0,0,0.35)] lg:h-[4.5rem] lg:w-[4.5rem]"
        />
      </div>
    </div>
  </div>
</Section>

<style>
  :global(.trust-roll-logo) {
    position: absolute;
    left: 50%;
    top: 0;
    transform: translateX(-50%) rotate(0deg);
    will-change: left, transform;
  }

  @supports (animation-timeline: view()) {
    .trust-roll-shell {
      view-timeline-name: --trust-roll-progress;
      view-timeline-axis: block;
    }

    :global(.trust-roll-logo) {
      animation: trust-logo-scroll linear both;
      animation-timeline: --trust-roll-progress;
      animation-range: entry 30% cover 82%;
    }
  }

  @keyframes trust-logo-scroll {
    from {
      left: -6rem;
      transform: translateX(-50%) rotate(0deg);
    }

    to {
      left: calc(100% + 6rem);
      transform: translateX(-50%) rotate(1440deg);
    }
  }

  @media (max-width: 1023px) {
    :global(.trust-roll-logo) {
      left: 50%;
      transform: translateX(-50%) rotate(0deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.trust-roll-logo) {
      left: 50%;
      transform: translateX(-50%) rotate(0deg);
    }
  }
</style>
