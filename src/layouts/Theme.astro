---
// src/layouts/Theme.astro
/**
 * Theme Component - Site Branding and Icons
 * 
 * Handles:
 * - Favicon configuration (multiple sizes and formats)
 * - Apple touch icons
 * - Theme color for mobile browsers
 * - PWA manifest (commented out)
 * 
 * All favicons point to favicon.svg for simplicity.
 * Can be customized to use different images per size.
 */

import "../styles/global.css";
import "../integrations/scroll-animations/styles/animations.css";
---

<!-- Favicons -->
<link rel="shortcut icon" href="/2dfavicons/favicon.ico" />
<link rel="icon" type="image/png" sizes="16x16" href="/2dfavicons/favicon-16x16.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/2dfavicons/favicon-32x32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/2dfavicons/apple-touch-icon.png" />
<link rel="manifest" href="/2dfavicons/site.webmanifest" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- Color scheme & mobile -->
<meta name="color-scheme" content="dark light" />
<meta name="theme-color" content="var(--color-bg3)" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

<!-- Scroll animations (deferred to avoid blocking initial render) -->
<script>
  // Import observer directly to avoid pulling in React via index barrel exports
  import "@/integrations/scroll-animations/observer";
</script>
