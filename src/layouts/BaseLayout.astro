---
// src/layouts/BaseLayout.astro
/**
 * Base Layout - Root HTML Structure
 *
 * Minimal document layout shared by all pages.
 * Site-specific chrome such as the header and footer should be composed
 * in higher-level layouts built on top of this one.
 */

// Note: fonts.css and global.css are imported in Theme.astro
import SEO from "./SEO.astro";
import Theme from "./Theme.astro";

// Integration bundles - consolidate all integration scripts
import IntHeadScripts from "@/integrations/IntHeadScripts.astro";
import IntBodyScripts from "@/integrations/IntBodyScripts.astro";
import IntFooterScripts from "@/integrations/IntFooterScripts.astro";

export interface Props {
  [key: string]: any;
}

const {
  bodyClass = "antialiased",
  mainClass = "",
  mainId = "main-content",
  mainRole = "main",
  mainAriaLabel = "Main content",
  showSkipLink = true,
  ...seoProps
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <Theme />
    <meta name="generator" content={Astro.generator} />

    {/* SEO meta tags */}
    <SEO title={seoProps.title} {...seoProps} />

    {/* Integration head scripts (GTM, Consent, Accessibility, Language Detection) */}
    <IntHeadScripts />

    {/* Optional noindex for unpublished content */}
    {seoProps.noindex && <meta name="robots" content="noindex,nofollow" />}
  </head>

  <body class={bodyClass}>
    {showSkipLink && (
      <a
        href={`#${mainId}`}
        class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-1/2 focus:-translate-x-1/2 focus:z-9999 focus:px-6 focus:py-3 focus:bg-primary focus:text-white focus:font-semibold focus:rounded-lg focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-heading focus:ring-offset-2"
      >
        Skip to main content
      </a>
    )}

    {/* Integration body scripts (Vercel Analytics, Translation) */}
    <IntBodyScripts />

    <slot name="before-main" />

    <main
      id={mainId}
      class={mainClass}
      tabindex="-1"
      role={mainRole}
      aria-label={mainAriaLabel}
    >
      <slot />
    </main>

    <slot name="after-main" />

    {/* Integration footer scripts (cookie banners, widgets, etc.) */}
    <IntFooterScripts />
  </body>
</html>
