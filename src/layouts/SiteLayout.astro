---
import BaseLayout from "./BaseLayout.astro";
import Header from "./sections/Header.astro";
import Footer from "./sections/Footer.astro";

const { ...seoProps } = Astro.props;
---

<BaseLayout {...seoProps} bodyClass="antialiased min-h-screen flex flex-col" mainClass="relative flex-1">
  <Fragment slot="before-main">
    <Header />
  </Fragment>

  <Fragment slot="after-main">
    <Footer />
  </Fragment>

  <slot />
</BaseLayout>
