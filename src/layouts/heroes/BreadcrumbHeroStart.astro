---
// src/layouts/heroes/BreadcrumbHeroStart.astro
import Button from "@/components/Button/Button";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import Hero from "@/components/Hero.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { siteData } from "@/content/siteData";
import type { HeadingContent } from "@/content/schema";
import { query } from "@/utils/query";

interface CTA {
  text: string;
  link: string;
  rightIcon?: string;
}

interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  title?: string;
  heading?: HeadingContent;
  description?: string;
  primaryCTA?: CTA;
  breadcrumbs?: BreadcrumbItem[];
  className?: string;
  id?: string;
  rightColumnClassName?: string;
}

const defaultDescription =
  "Hand-crafted websites, automated systems, and ongoing support so you can sell more, grow faster, and stay secure without juggling multiple vendors.";

const {
  title,
  heading,
  description = siteData.description ?? defaultDescription,
  primaryCTA: incomingPrimaryCTA,
  breadcrumbs = [],
  className = "",
  id = "hero",
  rightColumnClassName = "",
} = Astro.props as Props;

const primaryCTA: CTA = {
  text: "Book An Intro Call",
  link: "#contact",
  ...incomingPrimaryCTA,
  rightIcon: incomingPrimaryCTA?.rightIcon ?? "lu:arrow-up-right",
};

const hasRightContent = Astro.slots.has("right") || Astro.slots.has("default");
---

<Hero
  id={id}
  class={`landscape-hero ${className}`}
  size="full"
  contentAlign="center"
  contentVerticalAlign="center"
>
  <div class="relative z-10 min-h-screen inner-section flex">
    <div class="min-h-screen xl:h-auto inner-section mx-auto flex flex-col justify-center w-full">
      {
        breadcrumbs.length > 0 && (
          <nav aria-label="Breadcrumb" class="hero-breadcrumbs w-full">
            <ol class="flex flex-wrap items-center gap-x-4 gap-y-2 list-none p-0 m-0">
              {breadcrumbs.map((item, index) => {
                const isLast = index === breadcrumbs.length - 1;
                return (
                  <li class="flex items-center gap-4">
                    {item.href && !isLast ? (
                      <a href={item.href} class="hero-breadcrumb-link">
                        {item.label}
                      </a>
                    ) : (
                      <span
                        class="hero-breadcrumb-link"
                        aria-current={isLast ? "page" : undefined}
                      >
                        {item.label}
                      </span>
                    )}

                    {!isLast && <span aria-hidden="true" class="text-text/40">/</span>}
                  </li>
                );
              })}
            </ol>
          </nav>
        )
      }

      <div
        class={`grid items-center gap-10 lg:gap-16 w-full ${hasRightContent ? "lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)]" : ""}`}
      >
        <div class="flex flex-col gap-5 lg:gap-8 items-start text-left w-full">
          <SectionHeader
            className="text-left w-full"
            title={title}
            heading={heading}
            headingTag="h1"
            headingClassName="text-4xl md:text-5xl font-bold"
            description={description ?? defaultDescription}
            descriptionClassName="hero-text text-lg max-w-3xl leading-relaxed"
          />

          <div class="flex flex-col xl:flex-row items-start xl:items-center gap-4 xl:gap-6">
            <Button
              client:idle
              href={primaryCTA.link}
              variant="primary"
              size="lg"
              rightIcon={primaryCTA.rightIcon}
            >
              {primaryCTA.text}
            </Button>

            <ContentRenderer
              query={query("testimonials")
                .where((entry) => entry.data.featured === true)
                .limit(3)}
              variant="TestimonialCirclesVariant"
              counterStart={10}
              counterEnd={100}
              counterDuration={1800}
              counterSuffix="+"
              counterLabel="Happy Clients"
            />
          </div>
        </div>

        {
          hasRightContent && (
            <div class={`w-full justify-self-stretch ${rightColumnClassName}`}>
              <slot name="right">
                <slot />
              </slot>
            </div>
          )
        }
      </div>
    </div>
  </div>
</Hero>

<style>
  .hero-breadcrumbs {
    margin-bottom: 2.75rem;
  }

  .hero-breadcrumb-link {
    font-size: 0.85rem;
    line-height: 1;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-text) 72%, transparent);
    text-decoration: none;
    transition: color 180ms ease;
  }

  a.hero-breadcrumb-link:hover {
    color: var(--color-heading);
  }

  @media (max-width: 1023px) {
    .hero-breadcrumbs {
      margin-bottom: 2rem;
    }

    .hero-breadcrumb-link {
      font-size: 0.74rem;
      letter-spacing: 0.12em;
    }
  }
</style>
