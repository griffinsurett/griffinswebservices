---
// src/layouts/heroes/BreadcrumbHeroCenter.astro
import Button from "@/components/Button/Button";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import Hero from "@/components/Hero.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import { query } from "@/utils/query";
import { siteData } from "@/content/siteData";
import type { HeadingContent } from "@/content/schema";

interface CTA {
  text: string;
  link: string;
  rightIcon?: string;
}

interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  title?: string;
  heading?: HeadingContent;
  description?: string;
  primaryCTA?: CTA;
  breadcrumbs?: BreadcrumbItem[];
  className?: string;
  breadcrumbsClassName?: string;
  id?: string;
  minHeight?: string;
  showButtonSection?: boolean;
}

const defaultDescription =
  "Hand-crafted websites, automated systems, and ongoing support so you can sell more, grow faster, and stay secure without juggling multiple vendors.";

const {
  title,
  heading,
  description = siteData.description ?? defaultDescription,
  primaryCTA: incomingPrimaryCTA,
  breadcrumbs = [],
  className = "",
  breadcrumbsClassName = "",
  id = "hero",
  minHeight,
  showButtonSection = true,
} = Astro.props as Props;

const primaryCTA: CTA = {
  text: "Book An Intro Call",
  link: "#contact",
  ...incomingPrimaryCTA,
  rightIcon: incomingPrimaryCTA?.rightIcon ?? "lu:arrow-up-right",
};

const resolvedMinHeight = minHeight ?? "100vh";

---

<Hero
  id={id}
  class={`landscape-hero ${className}`}
  size="full"
  minHeight={minHeight}
  contentAlign="center"
  contentVerticalAlign="center"
>
  <div class="relative z-10" style={`min-height: ${resolvedMinHeight}`}>
    <div
      class="mx-auto flex w-full max-w-6xl flex-col px-2 pb-12 lg:max-w-7xl lg:px-0 lg:pb-0"
      style={`min-height: ${resolvedMinHeight}`}
    >
      {
        breadcrumbs.length > 0 && (
          <div class="flex min-h-[8.5rem] items-end pt-24 lg:min-h-[8.5rem] lg:pt-16">
            <nav
              aria-label="Breadcrumb"
              class={`hero-breadcrumbs mx-auto w-[95%] text-left lg:mx-0 lg:w-full ${breadcrumbsClassName}`.trim()}
            >
              <ol class="flex flex-wrap items-center justify-start gap-x-2 gap-y-2 list-none p-0 m-0">
                {breadcrumbs.map((item, index) => {
                  const isLast = index === breadcrumbs.length - 1;
                  const isHome = item.label.trim().toLowerCase() === "home";
                  const labelContent = isHome ? (
                    <span
                      class="inline-flex items-center justify-center"
                      aria-hidden="true"
                    >
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="h-[0.9rem] w-[0.9rem]"
                      >
                        <path d="M3 10.5 12 3l9 7.5" />
                        <path d="M5.25 9.75V21h13.5V9.75" />
                      </svg>
                    </span>
                  ) : (
                    item.label
                  );

                  return (
                    <li class="flex items-center gap-2">
                      {item.href && !isLast ? (
                        <a
                          href={item.href}
                          class="hero-breadcrumb-link"
                          aria-label={isHome ? item.label : undefined}
                        >
                          {labelContent}
                        </a>
                      ) : (
                        <span
                          class="hero-breadcrumb-link"
                          aria-current={isLast ? "page" : undefined}
                          aria-label={isHome ? item.label : undefined}
                        >
                          {labelContent}
                        </span>
                      )}

                      {!isLast && <span aria-hidden="true" class="text-text/40">/</span>}
                    </li>
                  );
                })}
              </ol>
            </nav>
          </div>
        )
      }

      <div
        class="flex flex-1 items-center"
      >
        <div
          class="mx-auto flex w-full max-w-5xl flex-col items-start gap-5 px-2 text-left sm:px-4 lg:items-center lg:gap-8 lg:px-0 lg:text-center"
        >
          <SectionHeading
            className="w-full text-left lg:text-center"
            title={title}
            heading={heading}
            headingTag="h1"
            headingClassName="h2 font-semibold"
            description={description ?? defaultDescription}
            descriptionClassName="hero-text max-w-3xl leading-relaxed lg:mx-auto"
          />

          {showButtonSection && (
            <div class="flex w-auto max-w-full flex-col items-start gap-4 sm:flex-row sm:flex-wrap sm:items-center sm:gap-5 lg:justify-center xl:gap-6">
              <Button
                client:idle
                href={primaryCTA.link}
                variant="primary"
                size="lg"
                rightIcon={primaryCTA.rightIcon}
                className="!w-auto whitespace-nowrap"
                buttonWrapperClasses="!w-auto justify-start"
              >
                {primaryCTA.text}
              </Button>

              <ContentRenderer
                query={query("testimonials")
                  .where((entry) => entry.data.featured === true)
                  .limit(3)}
                variant="TestimonialCirclesCounterVariant"
                className="shrink-0"
                counterStart={10}
                counterEnd={100}
                counterDuration={1800}
                counterSuffix="+"
                counterLabel="Happy Clients"
              />
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</Hero>

<style>
  @media (max-width: 1023px) {
    .hero-breadcrumb-link {
      font-size: 0.62rem;
      letter-spacing: 0.08em;
    }
  }

  .hero-breadcrumb-link {
    font-size: 0.85rem;
    line-height: 1;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-text) 72%, transparent);
    text-decoration: none;
    transition: color 180ms ease;
  }

  a.hero-breadcrumb-link:hover {
    color: var(--color-heading);
  }
</style>
