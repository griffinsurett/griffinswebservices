---
import Hero from "@/components/Hero.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import { siteData } from "@/content/siteData";
import type { HeadingContent } from "@/content/schema";

interface CTA {
  text: string;
  link: string;
  rightIcon?: string;
}

export interface Props {
  title?: string;
  heading?: HeadingContent;
  description?: string;
  primaryCTA?: CTA;
  className?: string;
  id?: string;
  showButtonSection?: boolean;
}

const defaultDescription =
  siteData.description ??
  "Hand-crafted websites, automated systems, and ongoing support so you can sell more, grow faster, and stay secure without juggling multiple vendors.";

const {
  title,
  heading,
  description = defaultDescription,
  className = "",
  id = "secondary-hero",
} = Astro.props as Props;

---

<Hero
  id={id}
  class={`landscape-hero min-h-[40vh] md:min-h-[50vh] lg:min-h-[55vh] ${className}`}
  size="small"
  contentAlign="center"
  contentVerticalAlign="center"
  animate="none"
>
  <div class="relative z-10">
    <div
      class="mx-auto flex w-full max-w-7xl flex-col px-4 pb-8 sm:px-6 lg:px-0 lg:pb-10"
      style="padding-top: var(--site-header-clearance);"
    >
      <div class="flex flex-1 items-center justify-center">
        <div class="flex w-full flex-col items-center gap-3 text-center lg:gap-4">
          <SectionHeading
            className="mb-0 w-full text-center"
            title={title}
            titleClassName="mb-0"
            heading={heading}
            headingTag="h1"
            headingClassName="h1 mb-3 max-w-none font-semibold tracking-normal"
            description={description}
            descriptionClassName="hero-text max-w-none text-center leading-relaxed"
          />
        </div>
      </div>
    </div>
  </div>
</Hero>
