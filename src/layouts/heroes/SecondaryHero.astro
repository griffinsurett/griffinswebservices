---
// src/layouts/SecondaryHero.astro
/**
 * Secondary Hero Layout
 *
 * Full-width hero for index, about, and collection pages.
 * Uses SectionHeader component for consistent heading structure.
 *
 * Features:
 * - SectionHeader integration with support for heading/title props
 * - Responsive background images (mobile/tablet/desktop)
 * - Automatic LCP optimization with aboveTheFold
 * - Gradient overlay for text readability
 * - Optional metadata display (date, author, reading time)
 */

import { getAuthorName } from "@/layouts/collections/helpers/layoutHelpers";
import SectionHeader from "@/components/SectionHeader.astro";
import Hero from "@/components/Hero.astro";
import type { HeadingContent } from "@/content/schema";

interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  title?: string;
  heading?: HeadingContent;
  description?: string;
  image?: any; // Astro image asset or public path
  publishDate?: Date | string;
  author?: string | { collection: string; id: string };
  readingTime?: number;
  className?: string;
  minHeight?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title,
  heading,
  description,
  image,
  publishDate,
  author,
  readingTime,
  className = "",
  minHeight = "60vh",
  breadcrumbs = [],
} = Astro.props;

// Keep the eyebrow title and main heading separate.
const displayHeading = heading || title;
---

<Hero
  class={`landscape-hero ${className}`}
  size="medium"
  minHeight={minHeight}
  contentAlign="center"
  contentVerticalAlign="center"
  animate="none"
>
  <div class="relative z-10" style={`min-height: ${minHeight}`}>
    <div
      class="mx-auto flex w-full max-w-6xl flex-col px-2 pb-12 pt-24 lg:max-w-7xl lg:px-0 lg:pb-0 lg:pt-16"
      style={`min-height: ${minHeight}`}
    >
      {
        breadcrumbs.length > 0 && (
          <div class="flex min-h-[8.5rem] items-end pt-6 lg:min-h-[8.5rem] lg:pt-0">
            <nav
              aria-label="Breadcrumb"
              class="hero-breadcrumbs mx-auto w-[95%] text-left lg:mx-0 lg:w-full"
            >
              <ol class="m-0 flex list-none flex-wrap items-center justify-start gap-x-2 gap-y-2 p-0">
                {breadcrumbs.map((item, index) => {
                  const isLast = index === breadcrumbs.length - 1;
                  const isHome = item.label.trim().toLowerCase() === "home";
                  const labelContent = isHome ? (
                    <span
                      class="inline-flex items-center justify-center"
                      aria-hidden="true"
                    >
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="h-[0.9rem] w-[0.9rem]"
                      >
                        <path d="M3 10.5 12 3l9 7.5" />
                        <path d="M5.25 9.75V21h13.5V9.75" />
                      </svg>
                    </span>
                  ) : (
                    item.label
                  );

                  return (
                    <li class="flex items-center gap-2">
                      {item.href && !isLast ? (
                        <a
                          href={item.href}
                          class="hero-breadcrumb-link"
                          aria-label={isHome ? item.label : undefined}
                        >
                          {labelContent}
                        </a>
                      ) : (
                        <span
                          class="hero-breadcrumb-link"
                          aria-current={isLast ? "page" : undefined}
                          aria-label={isHome ? item.label : undefined}
                        >
                          {labelContent}
                        </span>
                      )}

                      {!isLast && <span aria-hidden="true" class="text-text/40">/</span>}
                    </li>
                  );
                })}
              </ol>
            </nav>
          </div>
        )
      }

      <div class="flex flex-1 items-center justify-center py-12 lg:py-0">
        <div class="mx-auto flex w-full max-w-4xl flex-col gap-6 text-center">
          <SectionHeader
            title={title}
            titleClassName="mb-0"
            heading={displayHeading}
            headingTag="h1"
            headingClassName="text-4xl font-semibold md:text-5xl lg:text-6xl"
            description={description}
            descriptionClassName="text-xl leading-relaxed text-text md:text-2xl"
            className="text-center"
          />

          {
            (publishDate || author || readingTime) && (
              <div class="flex flex-wrap justify-center gap-4 text-sm text-text/85 md:gap-6 md:text-base">
                {publishDate && (
                  <time
                    datetime={new Date(publishDate).toISOString()}
                    class="flex items-center gap-2"
                  >
                    <svg
                      class="h-4 w-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                      />
                    </svg>
                    {new Date(publishDate).toLocaleDateString()}
                  </time>
                )}

                {author && (
                  <span class="flex items-center gap-2">
                    <svg
                      class="h-4 w-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                      />
                    </svg>
                    By {getAuthorName(author)}
                  </span>
                )}

                {readingTime && (
                  <span class="flex items-center gap-2">
                    <svg
                      class="h-4 w-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                      />
                    </svg>
                    {readingTime} min read
                  </span>
                )}
              </div>
            )
          }
        </div>
      </div>
    </div>
  </div>

  {/* Optional slot for additional content below hero */}
  <slot />
</Hero>

<style>
  @media (max-width: 1023px) {
    .hero-breadcrumb-link {
      font-size: 0.62rem;
      letter-spacing: 0.08em;
    }
  }

  .hero-breadcrumb-link {
    font-size: 0.85rem;
    line-height: 1;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-text) 72%, transparent);
    text-decoration: none;
    transition: color 180ms ease;
  }

  a.hero-breadcrumb-link:hover {
    color: var(--color-heading);
  }
</style>
