---
import { Image } from "astro:assets";
import BackgroundMediaFrame from "@/components/BackgroundMediaFrame.astro";
import Button from "@/components/Button/Button";
import Counter from "@/components/Counter.astro";
import FacebookStars from "@/components/FacebookStars";
import Icon from "@/components/Icon";
import Section from "@/components/Section.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import type { HeadingContent, IconType } from "@/content/schema";
import { contactCtaData, pricingCtaData, siteData } from "@/content/siteData";
import { animationProps } from "@/integrations/scroll-animations/props";
import { byItemKeys } from "@/utils/query/snippets";
import logoMark from "@/assets/GWS-animated.png";
import performanceImg from "@/assets/100performance.png";
import meoncompImg from "@/assets/meoncomp.jpg";

interface CTA {
  text: string;
  link: string;
  rightIcon?: string;
}

interface FeatureItem {
  icon: IconType;
  text: string;
}

export interface Props {
  title?: string;
  heading?: HeadingContent;
  description?: string;
  primaryCTA?: CTA;
  secondaryCTA?: CTA;
  className?: string;
  id?: string;
}

const proofEntry = await byItemKeys("about-us", "our-proof").first();

const defaultDescription =
  "Hand-crafted websites, automated systems, and ongoing support so you can sell more, grow faster, and stay secure without juggling multiple vendors.";

const {
  title,
  heading,
  description = siteData.description ?? defaultDescription,
  primaryCTA: incomingPrimaryCTA,
  secondaryCTA: incomingSecondaryCTA,
  className = "",
  id = "hero",
} = Astro.props as Props;

const primaryCTA: CTA = {
  text: contactCtaData.text,
  link: contactCtaData.link,
  ...incomingPrimaryCTA,
  rightIcon: incomingPrimaryCTA?.rightIcon ?? "lu:arrow-up-right",
};

const secondaryCTA: CTA = {
  text: incomingSecondaryCTA?.text ?? "See Pricing",
  link: incomingSecondaryCTA?.link ?? pricingCtaData.link,
  rightIcon: incomingSecondaryCTA?.rightIcon ?? "lu:arrow-up-right",
};

const reviewLink =
  proofEntry?.data.reviewLink ??
  "https://www.facebook.com/profile.php?id=61588357260507&sk=reviews";

const reviewLabel =
  proofEntry?.data.reviewLabel ?? "Across the businesses we work with";

const toNumber = (value: unknown, fallback: number) => {
  if (typeof value === "number" && Number.isFinite(value)) return value;
  if (typeof value === "string") {
    const parsed = Number(value.replace(/,/g, "").trim());
    if (Number.isFinite(parsed)) return parsed;
  }

  return fallback;
};

const statValue = toNumber(proofEntry?.data.statValue, 3.5);
const statPrefix = proofEntry?.data.statPrefix ?? "$";
const statSuffix = proofEntry?.data.statSuffix ?? "M+";
const statDescription =
  proofEntry?.data.statDescription ?? "in combined annual revenue.";

const features: FeatureItem[] = proofEntry?.data.featureItems?.length
  ? proofEntry.data.featureItems
  : [
      {
        icon: "lu:badge-check",
        text: "Built To Win Trust",
      },
      {
        icon: "lu:rocket",
        text: "Fast Turnaround",
      },
      {
        icon: "lu:shield-check",
        text: "Support That Stays",
      },
    ];
---

<Section
  id={id}
  class={`outer-section overflow-visible ${className}`.trim()}
>
  <div class="inner-section">
    <div
      class="relative mx-auto flex w-full max-w-[120rem] flex-col gap-5"
      {...animationProps("fade-in-up", { once: true, threshold: 0.1 })}
    >
      <div
        class="pointer-events-none absolute left-5 top-5 z-30 flex h-16 w-16 items-center justify-center rounded-[1.35rem] border border-white/14 bg-black/45 shadow-[0_18px_45px_rgba(0,0,0,0.35)] backdrop-blur-xl max-lg:left-4 max-lg:top-4 max-lg:h-12 max-lg:w-12"
      >
        <Image
          src={logoMark}
          alt=""
          widths={[48, 72, 96]}
          sizes="(min-width: 1024px) 40px, 32px"
          class="block h-10 w-10 object-contain max-lg:h-8 max-lg:w-8"
          aria-hidden="true"
        />
      </div>

      <div
        class="pointer-events-none absolute left-[4.9rem] top-[-1.35rem] z-20 w-72 overflow-hidden rounded-[1.75rem] border border-white/12 bg-bg/88 shadow-[0_28px_70px_rgba(0,0,0,0.42)] backdrop-blur-xl max-lg:left-[3.2rem] max-lg:top-2 max-lg:w-44"
      >
        <Image
          src={performanceImg}
          alt="100 performance score graphic"
          widths={[320, 480, 640]}
          sizes="(min-width: 1024px) 18rem, 11rem"
          class="block aspect-[16/10] w-full object-cover"
        />
      </div>

      <BackgroundMediaFrame
        imageSrc={meoncompImg}
        imageClass="h-full w-full min-h-[42rem] object-cover max-lg:min-h-[54rem]"
        imageMaxWidth={1600}
        mediaOverlayClass="bg-bg/72"
        className="min-h-[42rem] max-lg:min-h-[54rem]"
      >
        <div
          aria-hidden="true"
          class="absolute inset-0 z-0 bg-[linear-gradient(90deg,rgba(10,11,18,0.86)_0%,rgba(10,11,18,0.58)_38%,rgba(10,11,18,0.76)_100%),linear-gradient(0deg,rgba(10,11,18,0.92)_0%,rgba(10,11,18,0.18)_36%,rgba(10,11,18,0.28)_100%)]"
        ></div>

        <div class="relative z-10 hidden min-h-[42rem] grid-cols-[minmax(0,0.92fr)_minmax(0,1fr)] gap-10 px-8 pb-28 pt-14 lg:grid">
          <div class="flex flex-col justify-end">
            <div class="max-w-[31rem]">
              <div class="mb-4">
                <FacebookStars href={reviewLink} />
              </div>

              <p class="mb-3 text-[clamp(1.15rem,1.45vw,1.85rem)] leading-[1.2] text-white/82">
                {reviewLabel}
              </p>

              <h2 class="mb-3 text-[clamp(2.9rem,4.4vw,5.4rem)] leading-[0.98] tracking-[-0.06em] text-white">
                <Counter
                  prefix={statPrefix}
                  end={statValue}
                  suffix={statSuffix}
                  class="!gap-[0.01em]"
                />
              </h2>

              <p class="text-[clamp(1.15rem,1.45vw,1.85rem)] leading-[1.2] text-white/82">
                {statDescription}
              </p>
            </div>
          </div>

          <div class="flex items-start justify-end pt-2">
            <div class="w-full max-w-[40rem]">
              <SectionHeader
                title={title}
                heading={heading ?? proofEntry?.data.heading ?? siteData.tagline}
                description={description}
                headingTag="h2"
                className="w-full text-left"
                titleClassName="mb-5"
                titlePillClassName="border-white/14 bg-white/6 text-white/72 backdrop-blur-xl"
                headingClassName="m-0 text-[clamp(2.2rem,3.35vw,4.6rem)] leading-[0.96] tracking-[-0.06em] text-white text-balance"
                emphasisClassName="text-white"
                descriptionClassName="mt-7 max-w-[35rem] text-[1.06rem] leading-[1.58] text-white/84"
                descriptionAsHeading={false}
              />
            </div>
          </div>
        </div>

        <div class="relative z-10 flex min-h-[54rem] flex-col px-5 pb-7 pt-[9.6rem] lg:hidden">
          <div class="max-w-[22rem]">
            <SectionHeader
              title={title}
              heading={heading ?? proofEntry?.data.heading ?? siteData.tagline}
              description={description}
              headingTag="h2"
              className="w-full text-left"
              titleClassName="mb-4"
              titlePillClassName="border-white/14 bg-white/6 text-white/72 backdrop-blur-xl"
              headingClassName="m-0 text-[clamp(2.15rem,8.8vw,3.5rem)] leading-[0.97] tracking-[-0.06em] text-white"
              emphasisClassName="text-white"
              descriptionClassName="mt-6 text-[1rem] leading-[1.56] text-white/84"
              descriptionAsHeading={false}
            />
          </div>

          <div class="mt-6 w-fit">
            <FacebookStars href={reviewLink} />
          </div>

          <div class="mt-5 max-w-[22rem]">
            <p class="mb-2 text-[1.08rem] leading-[1.2] text-white/82">
              {reviewLabel}
            </p>

            <h2 class="mb-2 text-[clamp(3rem,11vw,4.3rem)] leading-[1] tracking-[-0.05em] text-white">
              <Counter
                prefix={statPrefix}
                end={statValue}
                suffix={statSuffix}
                class="!gap-[0.01em]"
              />
            </h2>

            <p class="text-[1.08rem] leading-[1.2] text-white/82">
              {statDescription}
            </p>
          </div>

          <ul class="mt-6 grid list-none grid-cols-1 gap-3 p-0" aria-label="Website outcomes">
            {features.map((feature) => (
              <li class="flex items-center gap-3 text-left text-[0.84rem] font-semibold uppercase tracking-[0.14em] text-white/94">
                <span
                  class="inline-flex h-[2.2rem] w-[2.2rem] shrink-0 items-center justify-center rounded-full border border-white/30 bg-bg/40 text-white backdrop-blur-xl"
                  aria-hidden="true"
                >
                  <Icon icon={feature.icon} size="md" className="text-current" />
                </span>
                <span>{feature.text}</span>
              </li>
            ))}
          </ul>
        </div>

        <ul
          class="absolute inset-x-0 bottom-0 z-10 hidden list-none grid-cols-3 gap-3 px-6 pb-7 pt-5 lg:grid"
          aria-label="Website outcomes"
        >
          {features.map((feature) => (
            <li class="flex min-h-16 items-center justify-center gap-3 text-center text-[0.94rem] font-semibold uppercase tracking-[0.16em] text-white/94">
              <span
                class="inline-flex h-[2.2rem] w-[2.2rem] shrink-0 items-center justify-center rounded-full border border-white/30 bg-bg/40 text-white backdrop-blur-xl"
                aria-hidden="true"
              >
                <Icon icon={feature.icon} size="md" className="text-current" />
              </span>
              <span>{feature.text}</span>
            </li>
          ))}
        </ul>
      </BackgroundMediaFrame>

      <div class="mx-auto grid w-full max-w-[48rem] items-center gap-4 px-4 lg:grid-cols-[minmax(20rem,28rem)_auto] lg:px-0">
        <div class="flex">
          <Button
            href={primaryCTA.link}
            variant="primary"
            size="lg"
            rightIcon={primaryCTA.rightIcon}
            fullWidth={true}
            className="justify-center whitespace-nowrap"
            buttonWrapperClasses="w-full"
          >
            {primaryCTA.text}
          </Button>
        </div>

        <div class="flex justify-center lg:justify-start">
          <Button
            href={secondaryCTA.link}
            variant="tertiary"
            size="lg"
            rightIcon={secondaryCTA.rightIcon}
            className="justify-center text-[1.1rem] font-semibold text-heading hover:text-heading/80 no-underline hover:no-underline"
          >
            {secondaryCTA.text}
          </Button>
        </div>
      </div>
    </div>
  </div>
</Section>
