---
import Button from "@/components/Button/Button";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import Hero from "@/components/Hero.astro";
import ScrollIndicator from "@/components/ScrollIndicator.astro";
import { siteData } from "@/content/siteData";
import type { HeadingContent } from "@/content/schema";
import { query } from "@/utils/query";

interface CTA {
  text: string;
  link: string;
  rightIcon?: string;
}

export interface Props {
  title?: string;
  heading?: HeadingContent;
  description?: string;
  checklist?: string[];
  primaryCTA: CTA;
  secondaryCTA: CTA;
  className?: string;
  id?: string;
  scrollToSection?: string;
}

const defaultDescription =
  siteData.description ??
  "Hand-crafted websites, automated systems, and ongoing support so you can sell more, grow faster, and stay secure without juggling multiple vendors.";

const {
  title,
  heading,
  description = defaultDescription,
  checklist = [],
  primaryCTA: incomingPrimaryCTA,
  secondaryCTA: incomingSecondaryCTA,
  className = "",
  id = "hero",
  scrollToSection,
} = Astro.props as Props;

const primaryCTA: CTA = {
  ...incomingPrimaryCTA,
  rightIcon: incomingPrimaryCTA?.rightIcon ?? "lu:arrow-up-right",
};

const secondaryCTA: CTA = {
  ...incomingSecondaryCTA,
  rightIcon: incomingSecondaryCTA?.rightIcon ?? "lu:arrow-up-right",
};

const checklistGradientId = `${id}-centered-check-gradient`;
---

<Hero
  id={id}
  class={`landscape-hero ${className}`}
  size="full"
  contentAlign="center"
  contentVerticalAlign="center"
>
  <div class="relative z-10 inner-section flex min-h-screen items-center">
    <div
      class="mx-auto flex w-full max-w-5xl flex-col items-center justify-center text-center"
    >
      <SectionHeader
        title={title}
        heading={heading}
        headingTag="h1"
        className="mx-auto w-full text-center"
        headingClassName="text-3xl sm:text-4xl md:text-5xl lg:text-6xl leading-[1.02]"
        description={description}
        descriptionClassName="hero-text mx-auto mt-3 max-w-3xl text-lg leading-relaxed lg:text-xl"
      />

      {
        checklist.length > 0 && (
          <>
            <svg
              aria-hidden="true"
              width="0"
              height="0"
              focusable="false"
              class="pointer-events-none h-0 w-0 overflow-hidden"
            >
              <defs>
                <linearGradient
                  id={checklistGradientId}
                  x1="0%"
                  y1="0%"
                  x2="100%"
                  y2="100%"
                >
                  <stop
                    offset="0%"
                    stop-color="currentColor"
                    class="text-primary-100"
                  />
                  <stop
                    offset="55%"
                    stop-color="currentColor"
                    class="text-primary"
                  />
                  <stop
                    offset="100%"
                    stop-color="currentColor"
                    class="text-primary-800"
                  />
                </linearGradient>
              </defs>
            </svg>

            <ul class="mt-4 grid w-full max-w-3xl gap-2 text-left md:grid-cols-2">
              {checklist.map((item) => (
                <li class="flex items-center gap-2 rounded-2xl card-bg px-4 py-2">
                  <span class="faded-bg flex flex-shrink-0 items-center justify-center rounded-full p-1 text-accent">
                    <svg
                      class="h-3 w-3 lg:h-4 lg:w-4"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke={`url(#${checklistGradientId})`}
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                  </span>
                  <span class="text-sm leading-relaxed text-text lg:text-base">
                    {item}
                  </span>
                </li>
              ))}
            </ul>
          </>
        )
      }

      <div
        class="mt-5 flex flex-col items-center gap-2 lg:flex-row lg:justify-center"
      >
        <Button
          href={primaryCTA.link}
          variant="primary"
          size="lg"
          rightIcon={primaryCTA.rightIcon}
        >
          {primaryCTA.text}
        </Button>

        <Button
          href={secondaryCTA.link}
          variant="secondary"
          size="lg"
          rightIcon={secondaryCTA.rightIcon}
          client:visible
        >
          {secondaryCTA.text}
        </Button>
      </div>

      <ContentRenderer
        query={query("testimonials")
          .where((entry) => entry.data.featured === true)
          .limit(3)}
        variant="TestimonialCirclesVariant"
        className="mt-4"
        counterStart={10}
        counterEnd={100}
        counterDuration={1800}
        counterSuffix="+"
        counterLabel="Happy Clients"
      />
    </div>
  </div>

  <ScrollIndicator slot="after" href={scrollToSection} />
</Hero>
