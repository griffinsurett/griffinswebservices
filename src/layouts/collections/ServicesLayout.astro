---
// src/layouts/collections/ServicesLayout.astro
/**
 * Services Layout - Item Page Layout for Solutions
 *
 * A specialized layout for solution-type collection items.
 * Features:
 * - QuoteHero for solutions
 * - MDX content rendering
 *
 * Note: Parent solutions (websites, web-apps, landing-pages) use
 * WebSolutionLayout directly via their frontmatter layout property.
 * Capability pages use CapabilityLayout.
 */
import SiteLayout from "@/layouts/SiteLayout.astro";
import QuoteHero from "@/layouts/heroes/QuoteHero.astro";
import type { CollectionLayoutProps } from "./types";

const {
  entry,
  collection,
  collectionMeta,
  Content,
  isIndexPage,
  seoProps = {},
  ...extraProps
} = Astro.props as CollectionLayoutProps;

const data = entry?.data || {};
const {
  title,
  description,
  price,
  heading,
} = data;

// Build the description with price if available
const heroDescription = price ? `${description} ${price}` : description;
---

<SiteLayout {...seoProps}>
  <QuoteHero
    title={title}
    heading={heading}
    description={heroDescription}
    primaryCTA={{
      text: `View All ${collectionMeta?.data?.title || "Services"}`,
      link: `/${collection}`,
      rightIcon: "lu:arrow-left",
    }}
    id="services-quote-hero"
  />

  {/* MDX Content */}
  {Content && <Content />}
</SiteLayout>
