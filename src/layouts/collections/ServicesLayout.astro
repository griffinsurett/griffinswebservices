---
// src/layouts/collections/ServicesLayout.astro
/**
 * Solutions layout aligned to the capability page pattern.
 *
 * Features:
 * - Centered breadcrumb hero
 * - Long-form written content area with table of contents
 * - Quote form placed deeper in the page
 */
import SiteLayout from "@/layouts/SiteLayout.astro";
import BreadcrumbHeroCenter from "@/layouts/heroes/BreadcrumbHeroCenter.astro";
import WrittenLayout from "@/layouts/sections/WrittenLayout.astro";
import CapabilityQuoteSection from "@/layouts/sections/CapabilityQuoteSection.astro";
import { contactCtaData } from "@/content/siteData";
import type { CollectionLayoutProps } from "./types";
import { shouldCollectionHavePage } from "@/utils/pages";
import { getBreadcrumbs } from "@/utils/query";

const {
  entry,
  collectionMeta,
  Content,
  seoProps = {},
} = Astro.props as CollectionLayoutProps;

const data = entry?.data || {};
const entryKey = entry ? entry.id : "";
const breadcrumbRelations = entryKey
  ? await getBreadcrumbs("solutions", entryKey, true)
  : [];
const solutionsHref = collectionMeta && shouldCollectionHavePage(collectionMeta)
  ? "/solutions"
  : undefined;

const solutionBreadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Solutions", href: solutionsHref },
  ...breadcrumbRelations.map((relation) => ({
    label:
      relation.entry?.data?.title ||
      relation.id
        .replace(/-/g, " ")
        .replace(/\b\w/g, (char: string) => char.toUpperCase()),
    href:
      relation.id === entryKey ? undefined : `/${relation.id}`,
  })),
];

const solutionQuoteSectionId = "solution-quote";
---

<SiteLayout {...seoProps}>
  <BreadcrumbHeroCenter
    title={data.title}
    heading={data.heading}
    description={data.description}
    breadcrumbs={solutionBreadcrumbs}
    primaryCTA={{
      text: contactCtaData.text,
      link: contactCtaData.link,
      target: "_blank",
      rel: "noopener noreferrer",
      link: `#${solutionQuoteSectionId}`,
    }}
    id="solutions-breadcrumb-hero"
  />

  <WrittenLayout
    id={`${entryKey || "solution"}-written-layout`}
    showHeadingSection={false}
    showToc={false}
    className="pt-0"
  >
    {Content && <Content />}
  </WrittenLayout>

  <CapabilityQuoteSection
    id={solutionQuoteSectionId}
    title={data.title}
    capabilityTitle={data.title}
    heading="Thinking about the next step?"
    description="share the basics here and we will review the scope, the priorities, and the clearest next step for your website."
  />
</SiteLayout>
