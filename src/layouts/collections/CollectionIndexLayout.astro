---
// src/layouts/collections/CollectionIndexLayout.astro
/**
 * Default Collection Index Layout
 *
 * Plain wrapper for collection index pages.
 * Custom page structure should live inside each collection's _meta.mdx body.
 */
import type { CollectionKey } from "astro:content";
import SiteLayout from "@/layouts/SiteLayout.astro";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { query } from "@/utils/query";

export interface Props {
  Content?: any;
  collectionName: CollectionKey;
  collectionMeta: any;
  seoProps: any;
  hasContent?: boolean;
  [key: string]: any;
}

const {
  Content,
  collectionName,
  seoProps,
  hasContent = false,
} = Astro.props;

---

<SiteLayout {...seoProps}>
  {
    hasContent && Content ? (
      <Content />
    ) : (
      <ContentRenderer
        query={query(collectionName)}
        variant="CardVariant"
      />
    )
  }
</SiteLayout>
