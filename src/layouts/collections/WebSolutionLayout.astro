---
// src/layouts/collections/WebSolutionLayout.astro
/**
 * Web Solution Layout - Minimal layout for parent solutions
 *
 * Simply provides BaseLayout with a slot for MDX content.
 * All content (including FrontPageHero) is defined in the MDX files.
 *
 * Used by websites.mdx, web-apps.mdx, landing-pages.mdx
 */
import SiteLayout from "@/layouts/SiteLayout.astro";
import type { CollectionLayoutProps } from "./types";

const {
  entry,
  collection,
  collectionMeta,
  Content,
  seoProps = {},
} = Astro.props as CollectionLayoutProps;
---

<SiteLayout {...seoProps}>
  {Content && <Content />}
</SiteLayout>
