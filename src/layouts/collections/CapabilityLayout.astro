---
import Logo from "@/components/Logo/Logo.astro";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { contactCtaData } from "@/content/siteData";
import SiteLayout from "@/layouts/SiteLayout.astro";
import BreadcrumbHeroStart from "@/layouts/heroes/BreadcrumbHeroStart.astro";
import CapabilityQuoteSection from "@/layouts/sections/CapabilityQuoteSection.astro";
import WrittenLayout from "@/layouts/sections/WrittenLayout.astro";
import type { CollectionLayoutProps } from "./types";
import { shouldCollectionHavePage } from "@/utils/pages";
import { getBreadcrumbs, sortByOrder } from "@/utils/query";
import { related } from "@/utils/query/snippets";

const {
  entry,
  collection,
  collectionMeta,
  Content,
  seoProps = {},
} = Astro.props as CollectionLayoutProps;

const data = entry?.data || {};
const entryKey = entry ? entry.id : "";
const breadcrumbRelations = entryKey
  ? await getBreadcrumbs("capabilities", entryKey, true)
  : [];
const collectionHref =
  collection && collectionMeta && shouldCollectionHavePage(collectionMeta)
    ? `/${collection}`
    : undefined;

const capabilityBreadcrumbs = [
  { label: "Home", href: "/" },
  { label: collectionMeta?.title || "Capabilities", href: collectionHref },
  ...breadcrumbRelations.map((relation) => ({
    label:
      relation.entry?.data?.title ||
      relation.id
        .replace(/-/g, " ")
        .replace(/\b\w/g, (char: string) => char.toUpperCase()),
    href:
      relation.id === entryKey ? undefined : `/${relation.collection}/${relation.id}`,
  })),
];

const rawBody = typeof entry?.body === "string" ? entry.body : "";
const hasCustomStructuredBody =
  rawBody.includes("<CapabilityBodyLayout") ||
  rawBody.includes('slot="hero"') ||
  rawBody.includes("<BreadcrumbHero");
const pricingCount = entryKey
  ? await related("pricing", "capabilities", entryKey).count()
  : 0;
const faqCount = entryKey
  ? await related("faq", "capabilities", entryKey).count()
  : 0;

---

<SiteLayout {...seoProps}>
  {hasCustomStructuredBody ? (
    <Fragment>
      {Content && <Content />}
    </Fragment>
  ) : (
    <Fragment>
      <BreadcrumbHeroStart
        title={data.title}
        heading={data.heading}
        description={data.description}
        breadcrumbs={capabilityBreadcrumbs}
        primaryCTA={{
          text: contactCtaData.text,
          link: contactCtaData.link,
          target: "_blank",
          rel: "noopener noreferrer",
        }}
        id="capabilities-quote-hero"
      >
        <div
          slot="right"
          class="flex w-full items-center justify-center py-8 lg:py-0"
        >
          <Logo
            showText={false}
            useLottie={true}
            loading="eager"
            trigger="load"
            hydrate="idle"
            autoplay={true}
            loop={true}
            altContext={`${data.title ?? "Capability"} Hero`}
            class="pointer-events-none"
            logoMediaClass="block h-[min(72vw,20rem)] w-[min(72vw,20rem)] object-contain lg:h-[24rem] lg:w-[24rem]"
            logoWidths={[320, 560, 768]}
            logoSizes="(min-width: 1024px) 24rem, min(72vw, 20rem)"
          />
        </div>
      </BreadcrumbHeroStart>

      <WrittenLayout
        id={`${entryKey || "capability"}-written-layout`}
        showHeadingSection={false}
        tocTitle="On This Page"
        headingSelector="h2:not([data-toc-exclude]), h3:not([data-toc-exclude])"
        className="pt-0"
      >
        {Content && <Content />}
      </WrittenLayout>

      {
        pricingCount > 0 && (
          <ContentRenderer
            query={related("pricing", "capabilities", entryKey).orderBy(sortByOrder())}
            variant="PricingVariant"
            id="pricing"
            title="Plans"
            heading={`${data.title || "Capability"} Plans`}
            columns={3}
            gap="lg"
          />
        )
      }

      {
        faqCount > 0 && (
          <ContentRenderer
            query={related("faq", "capabilities", entryKey).orderBy(sortByOrder())}
            variant="AccordionVariant"
            allowMultiple={false}
            title="FAQs"
            heading={`Common Questions About ${data.title || "This Capability"}`}
          />
        )
      }

      {
        <CapabilityQuoteSection
          id="capability-quote"
          title={data.title}
          capabilityTitle={data.title}
        />
      }
    </Fragment>
  )}
</SiteLayout>
