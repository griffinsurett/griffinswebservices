---
import { contactCtaData } from "@/content/siteData";
import SiteLayout from "@/layouts/SiteLayout.astro";
import BreadcrumbHeroCenter from "@/layouts/heroes/BreadcrumbHeroCenter.astro";
import BreadcrumbHeroStart from "@/layouts/heroes/BreadcrumbHeroStart.astro";
import type { CollectionLayoutProps } from "./types";
import { getItemKey } from "@/utils/collections";
import { getBreadcrumbs } from "@/utils/query";

const {
  entry,
  collection,
  collectionMeta,
  Content,
  seoProps = {},
} = Astro.props as CollectionLayoutProps;

const data = entry?.data || {};
const entryKey = entry ? getItemKey(entry) : "";
const breadcrumbRelations = entryKey
  ? await getBreadcrumbs("capabilities", entryKey, true)
  : [];

const capabilityBreadcrumbs = [
  { label: "Home", href: "/" },
  { label: collectionMeta?.data?.title || "Capabilities", href: `/${collection}` },
  ...breadcrumbRelations.map((relation) => ({
    label:
      relation.entry?.data?.title ||
      relation.id
        .replace(/-/g, " ")
        .replace(/\b\w/g, (char: string) => char.toUpperCase()),
    href:
      relation.id === entryKey ? undefined : `/${relation.collection}/${relation.id}`,
  })),
];

const HeroComponent =
  data.heroVariant === "start" ? BreadcrumbHeroStart : BreadcrumbHeroCenter;
---

<SiteLayout {...seoProps}>
  <HeroComponent
    title={data.title}
    heading={data.heading}
    description={data.description}
    breadcrumbs={capabilityBreadcrumbs}
    primaryCTA={{
      text: contactCtaData.text,
      link: contactCtaData.link,
    }}
    id="capabilities-quote-hero"
  />

  {Content && <Content />}
</SiteLayout>
