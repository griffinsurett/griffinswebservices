---
// src/layouts/collections/CapabilityCustomLayout.astro
/**
 * Minimal capability item layout.
 *
 * Use this when a capability page should define its entire structure,
 * including the hero, directly inside the MDX file.
 */
import SiteLayout from "@/layouts/SiteLayout.astro";
import type { CollectionLayoutProps } from "./types";

const {
  Content,
  seoProps = {},
} = Astro.props as CollectionLayoutProps;
---

<SiteLayout {...seoProps}>
  {Content && <Content />}
</SiteLayout>
