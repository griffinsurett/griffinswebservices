---
import Logo from "@/components/Logo/Logo.astro";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import WebsiteQuoteForm from "@/components/Form/forms/WebsiteQuoteForm.astro";
import QuoteForm from "@/components/Form/forms/QuoteForm.astro";
import Icon from "@/components/Icon";
import Section from "@/components/Section.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import TrustStatement from "@/components/TrustStatement.astro";
import { contactCtaData } from "@/content/siteData";
import type { HeadingContent } from "@/content/schema";
import BreadcrumbHeroStart from "@/layouts/heroes/BreadcrumbHeroStart.astro";
import HomeSolutionBridge from "@/layouts/sections/HomeSolutionBridge.astro";
import { getCollectionMeta } from "@/utils/collections";
import { shouldCollectionHavePage } from "@/utils/pages";
import { getBreadcrumbs, query, sortByOrder } from "@/utils/query";
import { related } from "@/utils/query/snippets";

interface GrandparentContent {
  introText?: string;
  introTextClassName?: string;
  testimonialsTitle?: string;
  testimonialsHeading?: string;
  testimonialsDescription?: string;
  faqTitle?: string;
  faqHeading?: string;
}

interface Props {
  title?: string;
  heading?: HeadingContent;
  description?: string;
  primaryCTA?: {
    text: string;
    link: string;
    rightIcon?: string;
  };
  className?: string;
  heroClassName?: string;
  heroRightColumnClassName?: string;
  id?: string;
  grandparentContent?: GrandparentContent;
}

const {
  title,
  heading,
  description,
  primaryCTA: incomingPrimaryCTA,
  className = "",
  heroClassName = "",
  heroRightColumnClassName = "",
  id = "capabilities-quote-hero",
  grandparentContent,
} = Astro.props as Props;

const pathname = Astro.url.pathname.replace(/\/+$/, "");
const slug = pathname.split("/").filter(Boolean).at(-1) ?? "";
const breadcrumbRelations = slug
  ? await getBreadcrumbs("capabilities", slug, true)
  : [];
const capabilitiesMeta = getCollectionMeta("capabilities");
const capabilitiesHref = shouldCollectionHavePage(capabilitiesMeta)
  ? "/capabilities"
  : undefined;

const capabilityBreadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Capabilities", href: capabilitiesHref },
  ...breadcrumbRelations.map((relation) => ({
    label:
      relation.entry?.data?.title ||
      relation.id
        .replace(/-/g, " ")
        .replace(/\b\w/g, (char: string) => char.toUpperCase()),
    href:
      relation.id === slug ? undefined : `/${relation.collection}/${relation.id}`,
  })),
];

const hasCustomHero = Astro.slots.has("hero");
const hasCustomHeroRight = Astro.slots.has("hero-right");
const hasTopicSections = Astro.slots.has("topic-sections");

const resolvedGrandparentContent: GrandparentContent = {
  introTextClassName:
    "text-left text-3xl md:text-4xl lg:text-5xl xl:text-6xl text-heading",
  testimonialsTitle: "Testimonials",
  testimonialsHeading: "What business owners say about working with us.",
  testimonialsDescription:
    "Real feedback from businesses that wanted a stronger website and a better online presence.",
  faqTitle: "FAQs",
  faqHeading: `Common Questions About ${title || "This Capability"}`,
  ...grandparentContent,
};

const resolvedCapabilityTitle = title ?? "Capability";
const capabilityQuoteSectionId = "capability-quote";
const capabilityQuoteHref = `#${capabilityQuoteSectionId}`;
const primaryCTA = {
  text: contactCtaData.text,
  link: capabilityQuoteHref,
  ...incomingPrimaryCTA,
};
const websiteFormCapabilities = new Set(["web-design"]);
const usesWebsiteQuoteForm = websiteFormCapabilities.has(slug);

const capabilityQuoteHighlights = usesWebsiteQuoteForm
  ? [
      {
        icon: "lucide:scan-search",
        title: "Clear next step",
        description:
          "We look at the real scope first, then tell you whether this is a refresh, a rebuild, or something more custom.",
      },
      {
        icon: "lucide:rocket",
        title: "Budget alignment",
        description:
          "A rough budget range helps us recommend the right path without wasting time on the wrong solution.",
      },
      {
        icon: "lucide:messages-square",
        title: "Built around your business",
        description:
          "The conversation starts with your goals, your pages, and what the website actually needs to handle.",
      },
    ]
  : [
      {
        icon: "lucide:scan-search",
        title: "Simple starting point",
        description:
          "Share the basics and we will review what you need before recommending the best next step.",
      },
      {
        icon: "lucide:messages-square",
        title: "Clearer conversation",
        description:
          "A short quote request gives us enough context to make the follow-up more useful and more specific.",
      },
      {
        icon: "lucide:phone",
        title: "Easy follow-up",
        description:
          "We can reach out, clarify the scope, and figure out whether this needs a small fix, a focused project, or a broader plan.",
      },
    ];

const capabilityQuoteHeading = usesWebsiteQuoteForm
  ? "Thinking about your next move?"
  : "Want to talk through the project?";
const capabilityQuoteDescription = usesWebsiteQuoteForm
  ? `If you are planning ${resolvedCapabilityTitle.toLowerCase()} work, share the basics here and we will review the scope, the budget range, and the clearest next step for your website.`
  : `If you are planning ${resolvedCapabilityTitle.toLowerCase()} work, send a few details here and we will follow up with the clearest next step.`;
const capabilityQuoteCardTitle = usesWebsiteQuoteForm
  ? "Start your quote"
  : "Start the conversation";
const capabilityQuoteCardDescription = usesWebsiteQuoteForm
  ? "Send the basics and we will follow up with the right recommendation for your website."
  : "Send the basics and we will follow up with the right recommendation for this project.";
---

<div class={className || undefined}>
  {
    hasCustomHero ? (
      <slot name="hero" />
    ) : (
      <BreadcrumbHeroStart
        title={title}
        heading={heading}
        description={description}
        breadcrumbs={capabilityBreadcrumbs}
        primaryCTA={primaryCTA}
        className={heroClassName}
        rightColumnClassName={heroRightColumnClassName}
        id={id}
      >
        {
          hasCustomHeroRight ? (
            <Fragment slot="right">
              <slot name="hero-right" />
            </Fragment>
          ) : (
            <div
              slot="right"
              class="flex w-full items-center justify-center py-8 lg:py-0"
            >
              <Logo
                showText={false}
                useLottie={true}
                loading="eager"
                trigger="load"
                hydrate="idle"
                autoplay={true}
                loop={true}
                altContext={`${title ?? "Capability"} Hero`}
                class="pointer-events-none"
                logoMediaClass="block h-[min(72vw,20rem)] w-[min(72vw,20rem)] object-contain lg:h-[24rem] lg:w-[24rem]"
                logoWidths={[320, 560, 768]}
                logoSizes="(min-width: 1024px) 24rem, min(72vw, 20rem)"
              />
            </div>
          )
        }
      </BreadcrumbHeroStart>
    )
  }

  <slot />

  {hasTopicSections && (
    <>
      {resolvedGrandparentContent.introText && (
        <TrustStatement
          text={resolvedGrandparentContent.introText}
          textClassName={resolvedGrandparentContent.introTextClassName}
        />
      )}

      <slot name="topic-sections" />

      <HomeSolutionBridge
        primaryCtaLink={capabilityQuoteHref}
        secondaryCtaText="Get Quote"
        secondaryCtaLink={capabilityQuoteHref}
      />

      <div class="bottom-content-section">
        <ContentRenderer
          query={query("testimonials").where((entry) => entry.data.rating >= 4)}
          variant="TestimonialCarouselVariant"
          title={resolvedGrandparentContent.testimonialsTitle}
          heading={resolvedGrandparentContent.testimonialsHeading}
          description={resolvedGrandparentContent.testimonialsDescription}
        />

        <Section id={capabilityQuoteSectionId} class="outer-section">
          <div class="inner-section">
            <div class="capability-quote-layout">
              <div class="capability-quote-copy sticky-section lg:self-start">
                <SectionHeader
                  title="Request a Quote"
                  heading={capabilityQuoteHeading}
                  description={capabilityQuoteDescription}
                  className="text-left"
                  headingClassName="h2 mb-6 text-heading"
                  emphasisClassName="text-heading"
                  descriptionClassName="large-text max-w-2xl"
                />

                <ul class="capability-quote-highlights">
                  {capabilityQuoteHighlights.map((item) => (
                    <li class="capability-quote-highlight">
                      <span class="capability-quote-icon" aria-hidden="true">
                        <Icon icon={item.icon} size="sm" />
                      </span>
                      <div class="space-y-1">
                        <p class="capability-quote-highlight-title">{item.title}</p>
                        <p class="capability-quote-highlight-text">{item.description}</p>
                      </div>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="capability-quote-card section-box card-bg">
                <div class="capability-quote-card__header">
                  <h3 class="capability-quote-card__title">{capabilityQuoteCardTitle}</h3>
                  <p class="capability-quote-card__description">
                    {capabilityQuoteCardDescription}
                  </p>
                </div>
                {
                  usesWebsiteQuoteForm ? (
                    <WebsiteQuoteForm
                      capabilityTitle={resolvedCapabilityTitle}
                      capabilitySlug={slug}
                      serviceCategory="capabilities"
                      formType="website"
                    />
                  ) : (
                    <QuoteForm
                      capabilityTitle={resolvedCapabilityTitle}
                      capabilitySlug={slug}
                      serviceCategory="capabilities"
                      formType="generic"
                      buttonText="Send quote request"
                    />
                  )
                }
              </div>
            </div>
          </div>
        </Section>

        <ContentRenderer
          query={related("faq", "capabilities", slug).orderBy(sortByOrder())}
          variant="AccordionVariant"
          allowMultiple={false}
          title={resolvedGrandparentContent.faqTitle}
          heading={resolvedGrandparentContent.faqHeading}
        />
      </div>
    </>
  )}
</div>

<style>
  .capability-quote-layout {
    display: grid;
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
  }

  .capability-quote-copy {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .capability-quote-highlights {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
  }

  .capability-quote-highlight {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
  }

  .capability-quote-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 999px;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-primary) 18%, transparent);
    flex-shrink: 0;
  }

  .capability-quote-highlight-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-heading);
  }

  .capability-quote-highlight-text {
    margin: 0;
    max-width: 30rem;
    line-height: 1.55;
    color: color-mix(in srgb, var(--color-text) 74%, transparent);
  }

  .capability-quote-card {
    position: relative;
    overflow: hidden;
    box-shadow: 0 35px 90px -48px rgba(0, 0, 0, 0.55);
  }

  .capability-quote-card__header {
    margin-bottom: 1.5rem;
  }

  .capability-quote-card__title {
    margin: 0;
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--color-heading);
  }

  .capability-quote-card__description {
    margin: 0.65rem 0 0;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-text) 74%, transparent);
  }

  .capability-quote-card :global(form > .mt-6) {
    display: flex;
    justify-content: flex-start;
  }

  .capability-quote-card :global(form > .mt-6 > span) {
    width: auto !important;
    justify-content: flex-start;
  }

  .capability-quote-card :global(form > .mt-6 > span > a),
  .capability-quote-card :global(form > .mt-6 > span > button) {
    width: auto !important;
  }

  @media (min-width: 1024px) {
    .capability-quote-layout {
      grid-template-columns: minmax(0, 1fr) minmax(22rem, 0.95fr);
    }
  }
</style>
