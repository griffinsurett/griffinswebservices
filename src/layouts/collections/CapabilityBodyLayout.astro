---
import Logo from "@/components/Logo/Logo.astro";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import TrustStatement from "@/components/TrustStatement.astro";
import { contactCtaData } from "@/content/siteData";
import type { HeadingContent } from "@/content/schema";
import BreadcrumbHeroStart from "@/layouts/heroes/BreadcrumbHeroStart.astro";
import HomeSolutionBridge from "@/layouts/sections/HomeSolutionBridge.astro";
import TrustPanel from "@/layouts/sections/TrustPanel.astro";
import { getBreadcrumbs, query, sortByOrder } from "@/utils/query";
import { children, related } from "@/utils/query/snippets";

interface GrandparentContent {
  introText?: string;
  introTextClassName?: string;
  testimonialsTitle?: string;
  testimonialsHeading?: string;
  testimonialsDescription?: string;
  projectsHeading?: string;
  projectsDescription?: string;
  faqTitle?: string;
  faqHeading?: string;
}

interface Props {
  title?: string;
  heading?: HeadingContent;
  description?: string;
  primaryCTA?: {
    text: string;
    link: string;
    rightIcon?: string;
  };
  className?: string;
  heroClassName?: string;
  heroRightColumnClassName?: string;
  id?: string;
  grandparentContent?: GrandparentContent;
}

const {
  title,
  heading,
  description,
  primaryCTA = {
    text: contactCtaData.text,
    link: contactCtaData.link,
  },
  className = "",
  heroClassName = "",
  heroRightColumnClassName = "",
  id = "capabilities-quote-hero",
  grandparentContent,
} = Astro.props as Props;

const pathname = Astro.url.pathname.replace(/\/+$/, "");
const slug = pathname.split("/").filter(Boolean).at(-1) ?? "";
const breadcrumbRelations = slug
  ? await getBreadcrumbs("capabilities", slug, true)
  : [];

const capabilityBreadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Capabilities", href: "/capabilities" },
  ...breadcrumbRelations.map((relation) => ({
    label:
      relation.entry?.data?.title ||
      relation.id
        .replace(/-/g, " ")
        .replace(/\b\w/g, (char: string) => char.toUpperCase()),
    href:
      relation.id === slug ? undefined : `/${relation.collection}/${relation.id}`,
  })),
];

const hasCustomHero = Astro.slots.has("hero");
const hasCustomHeroRight = Astro.slots.has("hero-right");
const directChildren = slug ? await children("capabilities", slug).all() : [];
const grandchildCounts = await Promise.all(
  directChildren.map((child) => children("capabilities", child.id).count())
);
const isGrandparentCapability =
  directChildren.length > 0 && grandchildCounts.some((count) => count > 0);

const resolvedGrandparentContent: GrandparentContent = {
  introTextClassName:
    "text-left text-3xl md:text-4xl lg:text-5xl xl:text-6xl text-heading",
  testimonialsTitle: "Testimonials",
  testimonialsHeading: "What business owners say about working with us.",
  testimonialsDescription:
    "Real feedback from businesses that wanted a stronger website and a better online presence.",
  projectsHeading: "Recent website work built to look credible and perform.",
  projectsDescription:
    "A closer look at websites and landing pages built to feel clear, trustworthy, and ready to convert.",
  faqTitle: "FAQs",
  faqHeading: `Common Questions About ${title || "This Capability"}`,
  ...grandparentContent,
};
---

<div class={className || undefined}>
  {
    hasCustomHero ? (
      <slot name="hero" />
    ) : (
      <BreadcrumbHeroStart
        title={title}
        heading={heading}
        description={description}
        breadcrumbs={capabilityBreadcrumbs}
        primaryCTA={primaryCTA}
        className={heroClassName}
        rightColumnClassName={heroRightColumnClassName}
        id={id}
      >
        {
          hasCustomHeroRight ? (
            <Fragment slot="right">
              <slot name="hero-right" />
            </Fragment>
          ) : (
            <div
              slot="right"
              class="flex w-full items-center justify-center py-8 lg:py-0"
            >
              <Logo
                showText={false}
                useLottie={true}
                loading="eager"
                trigger="load"
                hydrate="idle"
                autoplay={true}
                loop={true}
                altContext={`${title ?? "Capability"} Hero`}
                class="pointer-events-none"
                logoMediaClass="block h-[min(72vw,20rem)] w-[min(72vw,20rem)] object-contain lg:h-[24rem] lg:w-[24rem]"
                logoWidths={[320, 560, 768]}
                logoSizes="(min-width: 1024px) 24rem, min(72vw, 20rem)"
              />
            </div>
          )
        }
      </BreadcrumbHeroStart>
    )
  }

  <slot />

  {isGrandparentCapability && (
    <>
      {resolvedGrandparentContent.introText && (
        <TrustStatement
          text={resolvedGrandparentContent.introText}
          textClassName={resolvedGrandparentContent.introTextClassName}
        />
      )}

      <ContentRenderer
        variant="CapabilityTopicSectionsVariant"
        query={children("capabilities", slug)}
        cardColumns={4}
      />

      <HomeSolutionBridge />

      <div class="bottom-content-section">
        <ContentRenderer
          query={query("testimonials").where((entry) => entry.data.rating >= 4)}
          variant="TestimonialCarouselVariant"
          title={resolvedGrandparentContent.testimonialsTitle}
          heading={resolvedGrandparentContent.testimonialsHeading}
          description={resolvedGrandparentContent.testimonialsDescription}
        />

        <ContentRenderer
          query={query("projects")
            .where((entry) => !!entry.data.featuredVideo)
            .orderBy(sortByOrder())}
          variant="PortfolioVideoShowcaseVariant"
          heading={resolvedGrandparentContent.projectsHeading}
          description={resolvedGrandparentContent.projectsDescription}
          primaryCtaHref={primaryCTA.link}
          primaryCtaText={primaryCTA.text}
          ctaHref="/projects"
          ctaText="See Portfolio"
        />

        <TrustPanel />

        <ContentRenderer
          query={related("faq", "capabilities", slug).orderBy(sortByOrder())}
          variant="AccordionVariant"
          allowMultiple={false}
          title={resolvedGrandparentContent.faqTitle}
          heading={resolvedGrandparentContent.faqHeading}
        />
      </div>
    </>
  )}
</div>
