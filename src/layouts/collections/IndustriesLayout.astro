---
// src/layouts/collections/IndustriesLayout.astro
/**
 * Industries Layout - Item Page Layout for Industry Pages
 *
 * A specialized layout for industry-specific landing pages.
 * Features:
 * - Breadcrumb hero
 * - Portfolio screen showcase filtered by industry
 * - MDX content (which includes IndustriesSection)
 */
import SiteLayout from "@/layouts/SiteLayout.astro";
import Logo from "@/components/Logo/Logo.astro";
import BreadcrumbHeroStart from "@/layouts/heroes/BreadcrumbHeroStart.astro";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { query, getBreadcrumbs } from "@/utils/query";
import { related } from "@/utils/query/snippets";
import { capitalizeWords } from "@/utils/string";
import { getItemKey } from "@/utils/collections";
import type { CollectionLayoutProps } from "./types";
import { animationProps } from "@/integrations/scroll-animations/props";

const {
  entry,
  collection,
  collectionMeta,
  Content,
  isIndexPage,
  seoProps = {},
  ...extraProps
} = Astro.props as CollectionLayoutProps;

const data = entry?.data || {};
const {
  title,
  description,
  heading,
  icon,
} = data;

// Get the industry slug for filtering projects
const industrySlug = entry ? getItemKey(entry) : "";
const breadcrumbRelations = industrySlug
  ? await getBreadcrumbs("industries", industrySlug, true)
  : [];

// Capitalize the slug for display
const displayTitle =
  title || capitalizeWords(entry?.slug?.replace(/-/g, " ") || "");
const industryBreadcrumbs = [
  { label: "Home", href: "/" },
  { label: collectionMeta?.data?.title || "Industries", href: "/industries" },
  ...breadcrumbRelations.map((relation) => ({
    label:
      relation.entry?.data?.title ||
      relation.id
        .replace(/-/g, " ")
        .replace(/\b\w/g, (char: string) => char.toUpperCase()),
    href:
      relation.id === industrySlug ? undefined : `/${relation.collection}/${relation.id}`,
  })),
];
---

<SiteLayout {...seoProps}>
    <BreadcrumbHeroStart
      title={title}
      heading={heading}
      description={description}
      breadcrumbs={industryBreadcrumbs}
      primaryCTA={{
        text: "Get A Quote",
        link: "#industry-quote",
      }}
      id="industry-quote-hero"
    >
      <div
        slot="right"
        class="flex w-full items-center justify-center py-8 lg:py-0"
      >
        <Logo
          showText={false}
          useLottie={true}
          loading="eager"
          trigger="load"
          hydrate="idle"
          autoplay={true}
          loop={true}
          altContext={`${displayTitle || "Industry"} Hero`}
          class="pointer-events-none"
          logoMediaClass="block h-[min(72vw,20rem)] w-[min(72vw,20rem)] object-contain lg:h-[24rem] lg:w-[24rem]"
          logoWidths={[320, 560, 768]}
          logoSizes="(min-width: 1024px) 24rem, min(72vw, 20rem)"
        />
      </div>
    </BreadcrumbHeroStart>

    {/* Portfolio Screen Showcase - filtered by industry */}
    <div id="under-hero">
      <div
        class="block lg:min-h-screen inner-section"
        {...animationProps("fade-in-up", { once: false, threshold: 0.2 })}
      >
        <ContentRenderer
          query={related("projects", "industry", industrySlug)}
          variant="PortfolioScreenVariant"
          clientLoadPlaceholder={true}
        />
      </div>

      {/* MDX Content - includes IndustriesSection */}
      {Content && <Content />}
    </div>
</SiteLayout>
