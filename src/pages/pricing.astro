---
import { getCollection } from "astro:content";
import PricingLayout from "@/layouts/PricingLayout.astro";
import PricingCalculator from "@/components/Form/forms/PricingCalculator";

const industries = await getCollection("industries", ({ data }) => !data.draft);
const industryNames = industries
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
  .map((i) => i.data.title);

const pricingFormId = import.meta.env.PUBLIC_FORMSPREE_PRICING_ID ?? "";
---

<PricingLayout
  title="Pricing — Griffin's Web Services"
  description="Get a transparent project estimate in minutes. Tell us about your business and our AI builds your site structure and pricing on the spot."
>
  <div class="inner-section pt-20 pb-10 lg:pt-28">
    <!-- Accessible alternative for screen reader users. Hidden visually, exposed to AT. -->
    <section class="sr-only focus-within:not-sr-only" aria-label="Pricing information">
      <h1>Website Pricing — Griffin's Web Services</h1>
      <p>
        We build custom websites for local businesses. Pricing starts at $750 for a single-page site
        and scales based on the number of pages, add-ons like SEO, analytics, AI chat, and booking
        integrations. Larger projects are scoped on a call.
      </p>
      <p>
        <a href="/contact">Contact us to discuss your project and get a quote →</a>
      </p>
    </section>

    <!-- Interactive pricing calculator. Hidden from screen readers; use the contact link above. -->
    <div class="rounded-3xl card-bg relative overflow-hidden" aria-hidden="true">
      <PricingCalculator client:idle industryNames={industryNames} formspreeId={pricingFormId} />
    </div>
  </div>
</PricingLayout>
