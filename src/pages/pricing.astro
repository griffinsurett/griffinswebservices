---
import { getCollection } from "astro:content";
import SiteLayout from "@/layouts/SiteLayout.astro";
import SecondaryHero from "@/layouts/heroes/SecondaryHero.astro";
import PricingCalculator from "@/components/Form/forms/PricingCalculator";

const industries = await getCollection("industries", ({ data }) => !data.draft);
const industryNames = industries
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
  .map((i) => i.data.title);
---

<SiteLayout
  title="Pricing — Griffin's Web Services"
  description="Get a transparent project estimate in minutes. Tell us about your business and our AI builds your site structure and pricing on the spot."
>
  <SecondaryHero
    title="Transparent Pricing"
    heading={"Get an estimate for your project"}
    description="Fill in your business below — the calculator builds your site structure and gives you a real number, not a range."
  />

  <div class="w-19/20 mx-auto py-8 lg:py-12">
    <div class="rounded-3xl card-bg relative">
      <PricingCalculator client:idle industryNames={industryNames} />
    </div>
  </div>
</SiteLayout>
