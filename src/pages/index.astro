---
// src/pages/index.astro
import SiteLayout from "@/layouts/SiteLayout.astro";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { query, sortByOrder, sortByDate, byTag } from "@/utils/query";
import { contactCtaData, siteData } from "@/content/siteData";
import { roots, related } from "@/utils/query/snippets";
import FrontPageHero from "@/layouts/heroes/FrontPageHero.astro";
import HomeProblemSolutionIntro from "@/layouts/sections/HomeProblemSolutionIntro.astro";
import HomeSolutionBridge from "@/layouts/sections/HomeSolutionBridge.astro";
// TrustPanel removed from the homepage — see the commented render below.
// import TrustPanel from "@/layouts/sections/TrustPanel.astro";
import AboutSection from "@/components/AboutSection/AboutSection.astro";
import TestimonialCarousel from "@/components/TestimonialCarousel/TestimonialCarousel.astro";
// CurtainStack available if a multi-layer curtain is wanted later; the filmstrip
// now peels off on its own (standalone mode) to reveal normal-flow content.
// import CurtainStack from "@/components/CurtainStack/CurtainStack.astro";
import { animationProps } from "@/integrations/scroll-animations/props";

const heroHeading = {
  before: "Launch a Website That Actually Works.",
  text: "Fast. Clear. Built to Grow.",
  after: "",
};

const heroDescription =
  "We build websites for businesses that want it done right the first time. Our sites load fast, look trustworthy, and make it easy for people to understand what you do and reach out.";
---

<SiteLayout
  title="Fast, Secure Websites Built to Grow Your Business"
  description={siteData.description}
>
  <!-- HERO -->
  <FrontPageHero
    heading={heroHeading}
    description={heroDescription}
    primaryCTA={{
      text: contactCtaData.text,
      link: contactCtaData.link,
    }}
    scrollToSection="#under-hero"
  />

  <div id="under-hero">
    <!-- <div
      class="block lg:min-h-screen inner-section"
      {...animationProps("fade-in-up", { once: false, threshold: 0.2 })} -->
    
      <ContentRenderer
        query={byTag("capabilities", "featured").orderBy(sortByOrder())}
        variant="CardVariant"
        id="capabilities"
        title="What We Do"
        columns={3}
        gap="md"
        showHeadingSection={false}
        showButtonSection={false}
        card={{
          hoverOverlayClassName: "inset-0 bg-transparent",
        }}
      />
      <!-- <ContentRenderer
        query={byTag("projects", "screen").orderBy(sortByOrder())}
        variant="PortfolioScreenVariant"
        clientLoadPlaceholder={true}
      /> -->
    <!-- </div> -->

    {
      /* ABOUT — ported from webmaxers. Animated statement reveal → rolling logo
        divider → single image that expands to a full-bleed background with a
        marquee scrolling over it. The testimonials carousel is revealed over the
        full-bleed image via the `expand-content` slot — same as the webmaxers
        homepage. (No `withBackground` here: the AboutSection's own expanding
        image is already the backdrop.) */
    }
    <AboutSection
      statement={`${siteData.title} builds fast, trustworthy websites that help local businesses get found, look credible, and win more work.`}
      leftText="We design for clarity first, build it right the first time, and keep it fast long after launch."
      rightText="Our goal is simple: a website that makes your business easier to trust, easier to find, and easier to contact."
      ctaText="See What We Do"
      ctaLink="/capabilities"
      showStats
    >
      <div slot="expand-content" class="w-full">
        <TestimonialCarousel id="testimonials-home" />
      </div>
    </AboutSection>

    {
      /* PROJECTS — ported from webmaxers' filmstrip. In standalone mode it
        self-pins: the project row scrubs left, then the whole section peels
        off-LEFT to reveal whatever follows it in normal document flow (here,
        the Benefits section). This is the same "curtain" peel as webmaxers, but
        the revealed content below scrolls NATURALLY — it isn't trapped in a
        fixed-height stacked layer, so tall sections are never clipped.
        Below 768px / reduced-motion the filmstrip flattens to a vertical stack. */
    }
    
    {/* Page-level border wrappers: the rule lives on the PAGE composition, not
        the section — so the same variant shows a divider here but none where a
        page wraps it without `section-rule-*`. */}
    <div class="section-rule-y">
      <ContentRenderer
        query={byTag("projects", "featured").orderBy(sortByOrder())}
        variant="FilmstripVariant"
        title={"Selected work\n& explorations"}
        collectionUrl="/projects"
      />
    </div>

    <!-- <div class="section-rule-b"> -->
      <ContentRenderer
        query={query("benefits").orderBy(sortByOrder()).limit(8)}
        variant="BenefitsCardStackVariant"
        id="benefits"
        heading="Your website should help with things like this."
        description="Your website should do more than look good — it should quietly work for your business every day. It should make you easier to trust the moment someone lands on it, easier to find when people search, and easier to contact when they're ready to act. Every site we build is designed around outcomes like these, so the things that actually move your business forward keep happening long after launch."
      />
    <!-- </div> -->

    <div class="bottom-content-section">
      <ContentRenderer
        query={byTag("technologies", "featured")
          .orderBy(sortByOrder())
          .limit(13)}
        variant="TechnologiesVariant"
        title="Featured Technologies"
        description="These are some of the tools and platforms we use to build and support websites."
      />
    </div>

      {/* FAQs moved to /faq */}

    <!-- BLOG — editorial cards (webmaxers style) under a GWS SectionHeading. -->
    <ContentRenderer
      query={query("blog").orderBy(sortByDate("publishDate", "desc")).limit(4)}
      variant="BlogVariant"
      columns={2}
      showButtonSection={false}
      eyebrow="Latest Articles"
      title="Latest Articles"
      heading={{
        before: "Stay Informed. Read Our Latest Insights.",
      }}
    />
  </div>
</SiteLayout>
