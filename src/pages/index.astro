---
// src/pages/index.astro
import SiteLayout from "@/layouts/SiteLayout.astro";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { query, sortByOrder, sortByDate, byTag } from "@/utils/query";
import { contactCtaData, siteData } from "@/content/siteData";
import { roots, related } from "@/utils/query/snippets";
import FrontPageHero from "@/layouts/heroes/FrontPageHero.astro";
import HomeProblemSolutionIntro from "@/layouts/sections/HomeProblemSolutionIntro.astro";
import HomeSolutionBridge from "@/layouts/sections/HomeSolutionBridge.astro";
import TrustPanel from "@/layouts/sections/TrustPanel.astro";
import { animationProps } from "@/integrations/scroll-animations/props";

const heroHeading = {
  before: "Launch a Website That Actually Works.",
  text: "Fast. Clear. Built to Grow.",
  after: "",
};

const heroDescription =
  "We build websites for businesses that want it done right the first time. Our sites load fast, look trustworthy, and make it easy for people to understand what you do and reach out.";
---

<SiteLayout title="Fast, Secure Websites Built to Grow Your Business" description={siteData.description}>
  <!-- HERO -->
  <FrontPageHero
    heading={heroHeading}
    description={heroDescription}
    primaryCTA={{
      text: contactCtaData.text,
      link: contactCtaData.link,
    }}
    scrollToSection="#under-hero"
  />

  <div id="under-hero">
    <!-- Portfolio Showcase -->
    <div
      class="block lg:min-h-screen inner-section"
      {...animationProps("fade-in-up", { once: false, threshold: 0.2 })}
    >
      <ContentRenderer
        query={byTag("projects", "screen").orderBy(sortByOrder())}
        variant="PortfolioScreenVariant"
        clientLoadPlaceholder={true}
      />
    </div>

    <ContentRenderer
      query={byTag("capabilities", "featured").orderBy(sortByOrder())}
      variant="CardVariant"
      id="capabilities"
      title="What We Do"
      heading={{
        before: "What we build to help your business look trustworthy, get found, and",
        text: "win more leads.",
      }}
      description="We design, build, improve, and support websites so they stay fast, easy to use, and ready to bring in more calls, forms, and sales."
      columns={3}
      gap="md"
      showButtonSection={false}
      card={{
        hoverOverlayClassName: "inset-0 bg-transparent",
      }}
    />

    <!-- PROCESS -->
    <ContentRenderer
      query={query("process").orderBy(sortByOrder())}
      variant="NumberCardVariant"
      id="process"
      title="How We Work"
      heading="A Clear Plan From Start To Launch And Support"
      description="Good websites do not come from guessing. They come from a clear plan, careful work, and support after launch."
      gap="lg"
      showButtonSection={false}
    />

    <!-- <HomeProblemSolutionIntro /> -->

    <!-- <HomeSolutionBridge /> -->

        <!-- BENEFITS -->
    <ContentRenderer
      query={related("benefits", "solutions", "websites").orderBy(sortByOrder())}
      variant="BenefitsVariant"
      id="benefits"
      heading="Your website should help with things like this."
      description="A good website should make your business easier to trust, easier to find, and easier to contact."
      columns={2}
      gap="lg"
    />

       <HomeSolutionBridge />

    <div class="bottom-content-section">
      <ContentRenderer
        query={query("testimonials").where((entry: any) => entry.data.rating >= 4)}
        variant="TestimonialCarouselVariant"
      />

      <ContentRenderer
        query={query("projects")
          .where((entry: any) => !!entry.data.featuredVideo)
          .orderBy(sortByOrder())}
        variant="PortfolioVideoShowcaseVariant"
        heading="Websites Built to Get Attention"
        description="Fast, sharp websites that help people trust what they see."
        primaryCtaHref={contactCtaData.link}
        primaryCtaText={contactCtaData.text}
        ctaHref="/projects"
        ctaText="See Portfolio"
      />
      <TrustPanel />

      <ContentRenderer
        query={byTag("technologies", "featured").orderBy(sortByOrder()).limit(8)}
        variant="TechnologiesVariant"
        title="Featured Technologies"
        description="These are some of the tools and platforms we use to build and support websites."
      />

      <ContentRenderer
        query={byTag("faq", "featured").orderBy(sortByOrder())}
        variant="AccordionVariant"
        allowMultiple={false}
        title="FAQs"
        heading="Common Questions About Griffin's Web Services"
      />
    </div>

    <!-- BLOG -->
    <ContentRenderer
      query={query("blog").orderBy(sortByDate("publishDate", "desc")).limit(4)}
      variant="BlogVariant"
      columns={2}
      title="Latest Articles"
      heading={{
        before: "Stay informed.",
        text: "Read our latest insights.",
      }}
    />

  </div>
</SiteLayout>
