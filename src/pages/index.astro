---
// src/pages/index.astro
import SiteLayout from "@/layouts/SiteLayout.astro";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { query, sortByOrder, sortByDate, byTag } from "@/utils/query";
import { contactCtaData, pricingCtaData, siteData } from "@/content/siteData";
import { roots, related, byItemKeys } from "@/utils/query/snippets";
import CTASection from "@/layouts/heroes/CTASection.astro";
import FrontPageHero from "@/layouts/heroes/FrontPageHero.astro";
// import DoubleCard from "@/layouts/sections/DoubleCard.astro";
import HomeProblemSolutionIntro from "@/layouts/sections/HomeProblemSolutionIntro.astro";
import HomeSolutionBridge from "@/layouts/sections/HomeSolutionBridge.astro";
import BottomContentSection from "@/layouts/sections/BottomContentSection.astro";
import { animationProps } from "@/integrations/scroll-animations/props";

const heroHeading = {
  before: "Launch a Website That Actually Works.",
  text: "Fast. Secure. Built to Grow.",
  after: "",
};

const heroDescription =
  "We're a New Jersey–based web agency focused on building high-quality websites for businesses that want something done right the first time. Every site we deliver is built with intention — prioritizing performance, reliability, and long-term value over shortcuts or throwaway builds.";
---

<SiteLayout title="Fast, Secure Websites Built to Grow Your Business" description={siteData.description}>
  <!-- HERO -->
  <FrontPageHero
    heading={heroHeading}
    description={heroDescription}
    primaryCTA={{
      text: contactCtaData.text,
      link: contactCtaData.link,
    }}
    scrollToSection="#under-hero"
  />

  <div id="under-hero">
    <!-- Portfolio Showcase -->
    <div
      class="block lg:min-h-screen inner-section"
      {...animationProps("fade-in-up", { once: false, threshold: 0.2 })}
    >
      <ContentRenderer
        query={query("projects")}
        variant="PortfolioScreenVariant"
        clientLoadPlaceholder={true}
      />
    </div>

    <!-- SOLUTIONS -->
    <!-- <ContentRenderer
      query={byItemKeys("solutions", ["websites", "web-apps"])}
      id="solutions"
      title="Solutions"
      heading="Web Solutions Built Around the System You Need"
      description="Whether you need a business website or a custom application, the structure stays clear: core solutions first, pricing in one place, and enhancements layered in when they create real value."
    /> -->

    <HomeProblemSolutionIntro />

    <!-- <HomeSolutionBridge /> -->

        <!-- BENEFITS -->
    <ContentRenderer
      query={related("benefits", "solutions", "websites").orderBy(sortByOrder())}
      variant="BenefitsVariant"
      id="benefits"
      heading="Then your business deserves some of these solutions."
      description="These are the kinds of benefits the right website should start delivering for your business."
      columns={2}
      gap="lg"
    />

    <!-- PHILOSOPHY -->
    <!-- <ContentRenderer
      query={query("philosophy").orderBy(sortByOrder())}
      variant="IconListVariant"
      id="philosophy"
      title="Philosophy"
      heading="Why Our Websites Work When Others Don't"
      description="Most websites don't fail all at once. They quietly slow down, become harder to manage, or stop supporting the business they were built for. We take a different approach. Every website we build is guided by clear principles that prioritize performance, stability, and maintainability — so your site doesn't just launch strong, it continues working as your business grows. We intentionally build websites in a way that minimizes ongoing maintenance without sacrificing reliability, security, or long-term performance."
    /> -->

        <!-- CAPABILITIES -->
    <!-- <ContentRenderer
      query={related("capabilities", "solutions", "websites").orderBy(sortByOrder())}
      variant="CardVariant"
      id="capabilities"
      title="Our Capabilities"
      heading="The Capabilities That Make the Work Possible"
      description="Everything above depends on having the right technical foundation and ongoing oversight. Our capabilities work together to ensure your website stays fast, stable, and dependable over time."
      gap="lg"
      showButtonSection={false}
    /> -->

       <!-- <DoubleCard /> -->
       <HomeSolutionBridge />

    <!-- Bottom Content Section - Testimonials, Portfolio, FAQ -->
    <BottomContentSection
      testimonials={{
        customQuery: query("testimonials").where((entry: any) => entry.data.rating >= 4)
      }}
      portfolio={{
        filterQuery: query('industries').orderBy(sortByOrder()),
        title: "Portfolio",
        heading: "Websites that deliver real results",
        description: "From contractors to e-commerce brands, we build sites that look great, load fast, and convert visitors into customers.",
        showCount: false,
        showFilters: true,
        showArrows: true
      }}
      technologies={{
        customQuery: byTag("technologies", "featured").orderBy(sortByOrder()).limit(8),
        title: "Featured Technologies",
        description: "Frameworks, platforms, and infrastructure we rely on to keep sites fast, secure, and easy to evolve."
      }}
      faq={{
        customQuery: byTag("faq", "featured").orderBy(sortByOrder()),
        title: "FAQs"
      }}
    />

    <!-- BLOG -->
    <ContentRenderer
      query={query("blog").orderBy(sortByDate("publishDate", "desc")).limit(4)}
      variant="BlogVariant"
      columns={2}
      title="Latest Articles"
      heading={{
        before: "Stay informed.",
        text: "Read our latest insights.",
      }}
    />

    <!-- CTA -->
    <CTASection
      title="Get Started"
      heading="Ready to Build a Website That Works?"
      primaryCTA={{
        text: contactCtaData.text,
        link: contactCtaData.link,
      }}
      secondaryCTA={{
        text: pricingCtaData.text,
        link: pricingCtaData.link,
      }}
    />
  </div>
</SiteLayout>
