---
// src/pages/example.astro — Curtain component test playground
import SiteLayout from "@/layouts/SiteLayout.astro";
import Curtain from "@/components/Curtain/Curtain.astro";
---

<SiteLayout title="Curtain Test" description="Curtain transition playground">
  {/* Scroll space above so the curtain enters from mid-page. */}
  <section class="flex min-h-[60vh] items-center justify-center bg-bg text-text">
    <p class="text-2xl opacity-70">Scroll down to reach the curtain ↓</p>
  </section>

  {/* Content is slotted directly — slot="1" lifts away, slot="2" is revealed.
      Seam curtain reveals only at the BOUNDARY: section 1's last screen lifts to
      uncover section 2's first screen. For the reveal to read, section 2's first
      screen must pin itself (position: sticky) — the curtain overlaps, the
      content pins. (On the real site slot 2 is the Filmstrip, which pins
      internally.) So the demo pins its own first screen below. */}
  <Curtain>
    <div
      slot="1"
      class="flex min-h-screen flex-col items-center justify-center gap-4 text-white"
      style="background:#5e76f6"
    >
      <h2 class="text-5xl font-bold">Section 1 — Foreground</h2>
      <p class="text-xl opacity-90">This lifts upward like a curtain.</p>
    </div>

    {/* Tall section: a sticky first screen (pins during the reveal) + more
        content below so the section keeps its full natural height. */}
    <div slot="2" class="text-white" style="background:#0f172a">
      <div class="sticky top-0 flex h-screen flex-col items-center justify-center gap-4">
        <h2 class="text-5xl font-bold">Section 2 — Revealed</h2>
        <p class="text-xl opacity-90">Pinned underneath, uncovered as you scroll.</p>
      </div>
      <div class="flex min-h-screen items-center justify-center">
        <p class="text-xl opacity-70">…and section 2 keeps scrolling normally.</p>
      </div>
    </div>
  </Curtain>

  {/* Content between the two curtains proves Section 2 rejoins normal flow. */}
  <section class="flex min-h-[60vh] items-center justify-center bg-bg text-text">
    <p class="text-2xl opacity-70">Normal page flow between two curtains ↕</p>
  </section>

  {/* A SECOND curtain — proves instances are isolated and don't interfere. */}
  <Curtain>
    <div
      slot="1"
      class="flex min-h-screen flex-col items-center justify-center gap-4 text-white"
      style="background:#7c3aed"
    >
      <h2 class="text-5xl font-bold">Curtain B — Section 1</h2>
      <p class="text-xl opacity-90">Second instance, independent scroll.</p>
    </div>

    <div slot="2" class="text-white" style="background:#064e3b">
      <div class="sticky top-0 flex h-screen flex-col items-center justify-center gap-4">
        <h2 class="text-5xl font-bold">Curtain B — Section 2</h2>
        <p class="text-xl opacity-90">Revealed underneath the second curtain.</p>
      </div>
      <div class="flex min-h-screen items-center justify-center">
        <p class="text-xl opacity-70">…and section 2 keeps scrolling normally.</p>
      </div>
    </div>
  </Curtain>

  <section class="flex min-h-[80vh] items-center justify-center bg-bg text-text">
    <p class="text-2xl opacity-70">Normal page flow resumes here ↑</p>
  </section>
</SiteLayout>
