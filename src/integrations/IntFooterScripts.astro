---
// src/integrations/IntFooterScripts.astro
/**
 * Integration Footer Scripts Bundle
 *
 * Consolidates all integration components that should appear in/near the footer.
 * This is primarily for UI components that need to be at the end of the DOM.
 *
 * Currently a placeholder - add footer-level integration components here as needed.
 * Examples of what could go here:
 * - Cookie consent banner (if not lazy-loaded elsewhere)
 * - Chat widgets
 * - Feedback modals
 * - Any deferred UI that should render last
 *
 * Usage in BaseLayout.astro:
 *   <Footer />
 *   <IntFooterScripts />
 */

// Import footer-level integration components here as needed
// Chat widget: the webmaxers "Ask AI" UI — a fixed bottom-centre "Ask a question"
// bar that opens a centered modal with suggestion chips + input. UI-ONLY (no
// backend; submitting/chips just fill the field). Replaces the old ChatBot widget.
// The previous ChatBot lives at @/integrations/chatbot/chatbot.integration.astro
// if it's ever needed again.
import AskAi from "@/components/AskAi/AskAi";
import ChatBot from "@/integrations/chatbot/chatbot.integration.astro";
---

<!-- Footer-level integration components -->
<AskAi client:visible />
<slot />
