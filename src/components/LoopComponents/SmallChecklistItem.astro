---
// src/components/LoopComponents/SmallChecklistItem.astro

export interface Props {
  as?: "li" | "div";
  class?: string;
  iconWrapperClassName?: string;
  iconClassName?: string;
  textClassName?: string;
}

const {
  as = "li",
  class: className = "",
  iconWrapperClassName = "faded-bg p-1 rounded-full flex items-center justify-center text-accent flex-shrink-0",
  iconClassName = "w-3 h-3 lg:w-4 lg:h-4",
  textClassName = "text-text text-sm leading-relaxed",
} = Astro.props as Props;

const wrapperClasses = `list-none flex items-center gap-1.5 ${className}`.trim();
---

{
  as === "div" ? (
    <div class={wrapperClasses}>
      <span class={iconWrapperClassName}>
        <svg
          class={iconClassName}
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="20 6 9 17 4 12" />
        </svg>
      </span>
      <span class={textClassName}>
        <slot />
      </span>
    </div>
  ) : (
    <li class={wrapperClasses}>
      <span class={iconWrapperClassName}>
        <svg
          class={iconClassName}
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="20 6 9 17 4 12" />
        </svg>
      </span>
      <span class={textClassName}>
        <slot />
      </span>
    </li>
  )
}
