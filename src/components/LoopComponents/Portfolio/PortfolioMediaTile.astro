---
import HoverScrollImage from "@/components/LoopComponents/Portfolio/HoverScrollImage";
import HoverPlayVideo from "@/components/Video/HoverPlayVideo/HoverPlayVideo.astro";
import Button from "@/components/Button/Button";
import {
  generateResponsiveCroppedImage,
  generateResponsiveImage,
  getImageAlt,
  resolveImageMetadata,
} from "@/utils/images";

interface Props {
  item: Record<string, any>;
  className?: string;
  showMetadata?: boolean;
  [key: string]: unknown;
}

const {
  item,
  className = "",
  showMetadata = false,
  ...rest
} = Astro.props as Props;

const entry = item?.data ? { ...item.data, ...item } : item;
const title = entry?.title ?? "Project preview";
const projectLink = entry?.projectUrl ?? entry?.url;
const metadataLink =
  entry?.link &&
  typeof entry.link.label === "string" &&
  entry.link.label.trim().length > 0 &&
  typeof entry.link.url === "string" &&
  entry.link.url.trim().length > 0
    ? { label: entry.link.label, url: entry.link.url }
    : undefined;
const featuredVideo = entry?.featuredVideo;
const imageSource =
  entry?.fullSiteImage ?? entry?.bannerImage ?? entry?.image ?? entry?.featuredImage;
const imageMetadata = resolveImageMetadata(imageSource);
const imageAlt =featuredVideo
  ? `${title} website preview`
  : getImageAlt(imageSource, `${title} website preview`);
const mediaFrameClass = "block w-full overflow-hidden aspect-[20/13]";
const imageSizes =
  "(max-width: 767px) calc(100vw - 2rem), (max-width: 1199px) calc((100vw - 4rem) / 2), calc((100vw - 5rem) / 3)";
const imageFormats = [
  { format: "avif" as const, quality: 55 },
  { format: "webp" as const, quality: 72 },
];
const croppedImage = imageMetadata
  ? await generateResponsiveCroppedImage(imageMetadata, {
      widths: [640, 960, 1280],
      sizes: imageSizes,
      aspectRatio: 13 / 20,
      formats: imageFormats,
      fallbackFormat: "webp",
      position: "top",
    })
  : undefined;
const fullImage = imageMetadata
  ? await generateResponsiveImage(imageMetadata, {
      widths: [640, 960, 1280],
      sizes: imageSizes,
      formats: imageFormats,
      fallbackFormat: "webp",
    })
  : undefined;
---

<article
  class={`relative isolate overflow-hidden bg-transparent shadow-[0_35px_90px_-48px_rgba(0,0,0,0.55)] outer-card-transition ${className}`.trim()}
  {...rest}
>
  <div class={showMetadata ? "space-y-5" : undefined}>
    {
      featuredVideo ? (
        <div class={mediaFrameClass}>
          <HoverPlayVideo
            src={featuredVideo}
            alt={imageAlt}
            class="m-0 h-full w-full"
            muted={true}
            loop={true}
            controls={false}
            lazy={true}
            playsInline={true}
            posterWidth={1280}
            generateThumbAt={0.75}
            wrapperClass="h-full w-full overflow-hidden"
            mediaClass="block !h-auto !w-full !object-contain object-top"
            clientWrapperClass="h-full w-full overflow-hidden items-start"
          />
        </div>
      ) : imageMetadata ? (
        <div class={`${mediaFrameClass} relative`} data-hover-scroll-tile>
          {
            croppedImage && (
              <figure
                class="absolute inset-0 overflow-hidden bg-black/40 transition-opacity duration-300"
                data-hover-scroll-placeholder
                aria-hidden="true"
              >
                <picture>
                  {croppedImage.sources.map((source) => (
                    <source
                      type={source.type}
                      srcset={source.srcSet}
                      sizes={source.sizes ?? croppedImage.sizes}
                    />
                  ))}
                  <img
                    src={croppedImage.src}
                    srcset={croppedImage.srcSet}
                    sizes={croppedImage.sizes}
                    alt=""
                    width={croppedImage.width}
                    height={croppedImage.height}
                    loading="eager"
                    decoding="async"
                    draggable={false}
                    class="block h-full w-full select-none object-cover object-top"
                  />
                </picture>
              </figure>
            )
          }

          <div class="relative z-10 h-full">
            <HoverScrollImage
              client:visible
              src={fullImage?.src ?? imageMetadata?.src}
              srcSet={fullImage?.srcSet}
              sizes={fullImage?.sizes}
              sources={fullImage?.sources}
              alt={imageAlt}
              width={fullImage?.width ?? imageMetadata?.width}
              height={fullImage?.height ?? imageMetadata?.height}
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      ) : (
        <div class={`${mediaFrameClass} flex items-center justify-center bg-black text-sm uppercase tracking-[0.28em] text-white/55`}>
          Preview coming soon
        </div>
      )
    }

    {
      showMetadata && (
        <div class="flex flex-col items-start gap-2 px-1 pb-1 text-left">
          <h3 class="text-xl font-semibold leading-tight text-heading sm:text-2xl">
            {title}
          </h3>

          {
            metadataLink ? (
              <Button
                href={metadataLink.url}
                variant="link"
                rightIcon="lu:arrow-up-right"
                target="_blank"
                rel="noopener noreferrer"
                className="p-0 text-base font-medium text-heading"
              >
                {metadataLink.label}
              </Button>
            ) : (
              projectLink && (
                <Button
                  href={projectLink}
                  variant="link"
                  rightIcon="lu:arrow-up-right"
                  target="_blank"
                  rel="noopener noreferrer"
                  className="p-0 text-base font-medium text-heading"
                >
                  Website
                </Button>
              )
            )
          }
        </div>
      )
    }
  </div>
</article>
