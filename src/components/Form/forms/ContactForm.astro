---
// src/components/Form/forms/ContactForm.astro
/**
 * Contact Form — declarative field config rendered by a single accessible
 * FormWrapper island (real labels, per-field errors, autocomplete, live region).
 */
import FormWrapper from "@/components/Form/FormWrapper";
import type { FieldConfig } from "@/components/Form/fields";

interface Props {
  title?: string;
  description?: string;
  className?: string;
  buttonText?: string;
}

const {
  title,
  description,
  className = "",
  buttonText = "Submit Form",
} = Astro.props;

const currentPageUrl = Astro.url.href;

const solutionOptions = [
  { value: "general-contact-inquiry", label: "General Contact Inquiry" },
  { value: "other", label: "Other" },
];

const fields: FieldConfig[] = [
  { name: "firstName", label: "Full Name", type: "text", required: true, minLength: 2, autoComplete: "name", colSpan: 1 },
  { name: "lastName", label: "Last Name", type: "text", required: true, minLength: 2, autoComplete: "family-name", colSpan: 1 },
  { name: "email", label: "Email Address", type: "email", required: true, autoComplete: "email", colSpan: 1 },
  {
    name: "phone",
    label: "Phone Number",
    type: "tel",
    required: true,
    autoComplete: "tel",
    pattern: "[0-9]{10,}",
    hint: "At least 10 digits, numbers only.",
    errorMessage: "Enter a phone number with at least 10 digits.",
    colSpan: 1,
  },
  { name: "company", label: "Company Name", type: "text", autoComplete: "organization", colSpan: 2 },
  { name: "solution", label: "What are you interested in?", type: "select", required: true, options: solutionOptions, colSpan: 2 },
  { name: "message", label: "Tell us about your project", type: "textarea", required: true, minLength: 10, rows: 5, colSpan: 2 },
];

const FORMSPREE_BASE_ACTION = "https://formspree.io/f/";
const contactFormId = import.meta.env.PUBLIC_FORMSPREE_CONTACT_ID;
const contactFormAction = contactFormId
  ? `${FORMSPREE_BASE_ACTION}${contactFormId}`
  : undefined;
---

<div class={className}>
  {title && <h2 class="text-3xl mb-3">{title}</h2>}
  {description && <p class="text-text mb-8">{description}</p>}

  <FormWrapper
    client:load
    fields={fields}
    fieldsClassName="grid gap-4 md:grid-cols-2"
    formspreeEndpoint={contactFormAction}
    formspreeFormName="Contact Form"
    className="group flex flex-col relative overflow-hidden"
    submitButton={{
      text: buttonText,
      className: "w-full md:w-auto",
      disabled: !contactFormAction,
    }}
  >
    <input type="hidden" name="pageUrl" value={currentPageUrl} />
  </FormWrapper>
</div>