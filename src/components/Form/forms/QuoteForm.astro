---
// src/components/Form/forms/QuoteForm.astro
/**
 * Quote Form — compact hero-section form. Declarative field config rendered by a
 * single accessible FormWrapper island (real labels, per-field errors, autocomplete).
 */
import FormWrapper from "@/components/Form/FormWrapper";
import type { FieldConfig } from "@/components/Form/fields";

interface Props {
  className?: string;
  buttonText?: string;
  capabilityTitle?: string;
  serviceCategory?: string;
  capabilitySlug?: string;
  formType?: string;
}

const {
  className = "",
  buttonText = "Get Your Quote",
  capabilityTitle,
  serviceCategory,
  capabilitySlug,
  formType = "generic",
} = Astro.props;

const currentPageUrl = Astro.url.href;

const referralSourceOptions = [
  { value: "referral", label: "Referral" },
  { value: "google-search", label: "Google Search" },
  { value: "ai-prompt-engine", label: "AI Prompt Engine" },
  { value: "social-media", label: "Social Media" },
  { value: "repeat-client", label: "Repeat Client" },
  { value: "other", label: "Other" },
];

const fields: FieldConfig[] = [
  { name: "firstName", label: "First Name", type: "text", required: true, minLength: 2, autoComplete: "given-name", colSpan: 1 },
  { name: "lastName", label: "Last Name", type: "text", required: true, minLength: 2, autoComplete: "family-name", colSpan: 1 },
  { name: "email", label: "Email Address", type: "email", required: true, autoComplete: "email", colSpan: 1 },
  { name: "phone", label: "Phone Number", type: "tel", autoComplete: "tel", colSpan: 1 },
  { name: "message", label: "Tell us about your project", type: "textarea", required: true, minLength: 10, rows: 3, colSpan: 2 },
  { name: "referralSource", label: "How did you hear about us?", type: "select", required: true, options: referralSourceOptions, colSpan: 2 },
];

const FORMSPREE_BASE_ACTION = "https://formspree.io/f/";
const quoteFormId = import.meta.env.PUBLIC_FORMSPREE_QUOTE_ID;
const quoteFormAction = quoteFormId
  ? `${FORMSPREE_BASE_ACTION}${quoteFormId}`
  : undefined;
---

<div class={className}>
  <FormWrapper
    client:load
    fields={fields}
    fieldsClassName="grid gap-3 md:grid-cols-2"
    formspreeEndpoint={quoteFormAction}
    formspreeFormName="Quote Request"
    className="group flex flex-col relative overflow-hidden"
    submitButton={{
      text: buttonText,
      className: "w-full",
      disabled: !quoteFormAction,
    }}
  >
    <input type="hidden" name="pageUrl" value={currentPageUrl} />
    {serviceCategory && <input type="hidden" name="serviceCategory" value={serviceCategory} />}
    <input type="hidden" name="formType" value={formType} />
    {capabilityTitle && <input type="hidden" name="capabilityTitle" value={capabilityTitle} />}
    {capabilitySlug && <input type="hidden" name="capabilitySlug" value={capabilitySlug} />}
  </FormWrapper>
</div>