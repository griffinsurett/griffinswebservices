---
import Section from "@/components/Section.astro";
import { animationProps } from "@/integrations/scroll-animations/props";

interface Props {
  text: string;
  className?: string;
  textClassName?: string;
  stickyScroll?: boolean;
  stickyHeight?: string;
  stickyTopOffset?: string;
  excludeFromToc?: boolean;
}

const {
  text,
  className,
  textClassName,
  stickyScroll = true,
  stickyHeight = "220svh",
  stickyTopOffset = "clamp(5.5rem, 7vw, 7rem)",
  excludeFromToc = false,
} = Astro.props;

const resolvedClassName = className ?? (
  stickyScroll
    ? "mx-auto inner-section"
    : "min-h-[40vh] flex items-center mx-auto inner-section"
);

const resolvedTextClassName = textClassName ?? (
  stickyScroll
    ? "text-4xl md:text-5xl lg:text-6xl xl:text-7xl text-left text-heading"
    : "text-3xl md:text-4xl lg:text-5xl text-left"
);

const stickyStyle = stickyScroll
  ? `--trust-section-height:${stickyHeight}; --trust-sticky-top:${stickyTopOffset};`
  : undefined;
---

<Section
  tag="aside"
  class={`trust-statement ${stickyScroll ? "trust-statement--sticky" : ""} ${resolvedClassName}`.trim()}
  aria-label="Trust statement"
  animate={stickyScroll ? false : "fade-in"}
  animateOnce={false}
  style={stickyStyle}
  data-trust-sticky={stickyScroll ? "true" : undefined}
>
  {
    stickyScroll ? (
      <div class="trust-statement-pin" data-trust-sticky-inner>
        <h2
          class:list={[resolvedTextClassName, "trust-statement-heading", "trust-statement-heading--scroll", "font-normal"]}
          aria-label={text}
          data-toc-exclude={excludeFromToc ? "true" : undefined}
          {...animationProps("fade-in", {
            once: true,
            threshold: 0.1,
            rootMargin: "0px",
          })}
        >
          {text}
        </h2>
      </div>
    ) : (
      <h2
        class:list={[resolvedTextClassName, "trust-statement-heading", "font-normal"]}
        aria-label={text}
        data-toc-exclude={excludeFromToc ? "true" : undefined}
        {...animationProps("fade-in", {
          once: true,
          threshold: 0.1,
          rootMargin: "0px",
        })}
      >
        {text}
      </h2>
    )
  }
</Section>

<style>
  .trust-statement-heading:not(.trust-statement-heading--scroll) {
    color: var(--color-text);
  }

  .trust-statement--sticky {
    min-height: var(--trust-section-height);
    position: relative;
  }

  .trust-statement-pin {
    position: sticky;
    top: var(--trust-sticky-top);
    min-height: calc(100svh - var(--trust-sticky-top));
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding-block: clamp(2rem, 6vw, 4rem);
    width: 100%;
  }

  .trust-statement-heading--scroll {
    color: var(--color-heading);
    line-height: 1.08;
    text-wrap: balance;
    width: 100%;
  }

  @media (prefers-reduced-motion: reduce) {
    .trust-statement--sticky {
      min-height: auto;
    }

    .trust-statement-pin {
      position: static;
      min-height: auto;
      padding-block: 0;
    }
  }
</style>
