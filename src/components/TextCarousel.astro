---
interface CarouselItem {
  text: string;
  label?: string;
}

interface Props {
  items: CarouselItem[];
  autoplayMs?: number;
  className?: string;
  textClassName?: string;
  quoteMarks?: boolean;
}

const {
  items = [],
  autoplayMs = 6500,
  className = "",
  textClassName = "",
  quoteMarks = false,
} = Astro.props;

const hasMultipleItems = items.length > 1;
---

<div
  class={`text-carousel ${className}`.trim()}
  data-text-carousel={hasMultipleItems ? "" : undefined}
  data-text-carousel-autoplay-ms={hasMultipleItems ? autoplayMs : undefined}
>
  <div class="text-carousel-grid">
    {items.map((item, index) => (
      <div
        class={`text-carousel-slide ${index === 0 ? "is-active" : ""}`}
        data-text-carousel-slide={hasMultipleItems ? "" : undefined}
        aria-hidden={index === 0 ? "false" : "true"}
        aria-label={item.label}
      >
        <p class={textClassName}>
          {quoteMarks ? `"${item.text}"` : item.text}
        </p>
      </div>
    ))}
  </div>
</div>

<style>
  .text-carousel-grid {
    display: grid;
  }

  .text-carousel-slide {
    grid-area: 1 / 1;
    opacity: 0;
    pointer-events: none;
    transition: opacity 280ms ease;
  }

  .text-carousel-slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }
</style>

<script>
  (() => {
    if (typeof window === "undefined") return;

    const carousels = document.querySelectorAll("[data-text-carousel]");

    carousels.forEach((carousel) => {
      const slides = Array.from(carousel.querySelectorAll("[data-text-carousel-slide]"));
      const autoplayMs = Number(carousel.getAttribute("data-text-carousel-autoplay-ms") || "6500");

      if (slides.length < 2) return;

      let activeIndex = slides.findIndex((slide) => slide.classList.contains("is-active"));
      if (activeIndex < 0) activeIndex = 0;

      let intervalId;

      const setActive = (nextIndex) => {
        activeIndex = nextIndex;

        slides.forEach((slide, index) => {
          const isActive = index === activeIndex;
          slide.classList.toggle("is-active", isActive);
          slide.setAttribute("aria-hidden", isActive ? "false" : "true");
        });
      };

      const startAutoplay = () => {
        window.clearInterval(intervalId);
        intervalId = window.setInterval(() => {
          setActive((activeIndex + 1) % slides.length);
        }, autoplayMs);
      };

      carousel.addEventListener("mouseenter", () => window.clearInterval(intervalId));
      carousel.addEventListener("mouseleave", startAutoplay);

      setActive(activeIndex);
      startAutoplay();
    });
  })();
</script>
