---
// src/components/CurtainReveal/CurtainReveal.astro
/**
 * CurtainReveal — a slotted seam transition between two sections.
 *
 * Slot two sections in. Each keeps its OWN natural height and scroll behavior
 * (self-pinning, internal scrubs, morphs — all untouched). CurtainReveal owns
 * only the SEAM between them: as you finish scrolling the `outgoing` section,
 * its last full screen is pinned and slides off in the `move` direction like a
 * curtain, uncovering the `incoming` section — which was already sitting there,
 * full-screen and stationary, behind it.
 *
 *   <CurtainReveal move="up">
 *     <YourSectionA slot="outgoing" />   (stays fully intact)
 *     <YourSectionB slot="incoming" />   (revealed underneath)
 *   </CurtainReveal>
 *
 * `move`: which way the outgoing curtain slides off — "up" | "down" | "left" |
 * "right". Default "up".
 *
 * How it works (all viewports, motion allowed):
 *   • The incoming section is pulled up by one screen + the slide runway and then
 *     FROZEN there by a GSAP pin for the whole slide span (see the freeze pin in
 *     the script). So it sits dead-still behind the curtain — it does not drift
 *     with the page while the curtain lifts — and is flush at the top the moment
 *     the curtain finishes. The overlap is a scroll-space reservation, NOT an
 *     assumption about the incoming's height.
 *   • At the seam the outgoing wrapper is pinned (GSAP) for `slideVh` of scroll
 *     and translated off in `move` by exactly ONE screen (measured via a `100svh`
 *     probe, NOT window.innerHeight — that's the fix: innerHeight == 100svh on
 *     desktop but diverges on mobile as the browser chrome collapses, which made
 *     the old curtain park partway over the section below). A higher z-index keeps
 *     the curtain above the incoming one until it's gone.
 *   • The incoming section stays frozen at its start until the slide completes, so
 *     it "isn't loaded" until fully visible. Sections may ALSO opt into their own
 *     scroll-hold via `--curtain-hold` (e.g. FilmstripVariant on desktop); the
 *     wrapper's freeze pin makes the freeze correct even when they don't (e.g. the
 *     filmstrip's mobile fallback), so mobile matches desktop.
 *
 * The curtain runs on ALL widths by default; pass `flattenBelow` (a breakpoint or
 * px) to opt a caller OUT below a width. Reduced motion (OS or in-app toggle)
 * always flattens: NO pin, NO overlap, NO slide — both sections fall into plain
 * vertical flow with their own static fallbacks.
 */

type Move = "up" | "down" | "left" | "right";
/** Named min-width breakpoints (Tailwind defaults) accepted by `flattenBelow`. */
type Breakpoint = "sm" | "md" | "lg" | "xl" | "2xl";

/** Tailwind default breakpoints → px. Keep in sync with the Tailwind config. */
const BREAKPOINTS: Record<Breakpoint, number> = {
  sm: 640,
  md: 768,
  lg: 1024,
  xl: 1280,
  "2xl": 1536,
};

interface Props {
  /** Direction the outgoing curtain slides off to reveal the incoming section. */
  move?: Move;
  /** Scroll DURATION of the slide, in svh — how much scrolling the one-screen
      slide is scrubbed across (larger = slower, more deliberate lift). This is a
      duration only; the travel and overlap are always exactly ONE screen so the
      reveal never depends on the incoming section's height. Default 120. */
  slideVh?: number;
  /** Optional viewport width (inclusive) BELOW which the curtain flattens into
      normal vertical flow — the opt-out for callers who don't want it on small
      screens. Accepts a Tailwind breakpoint name ("sm"|"md"|"lg"|"xl"|"2xl") or a
      raw px number. Omitted → the curtain runs on ALL widths, phones included.
      Reduced motion always flattens regardless. */
  flattenBelow?: Breakpoint | number;
  class?: string;
}

const {
  move = "up",
  slideVh = 120,
  flattenBelow,
  class: className = "",
} = Astro.props;

// Resolve the flatten breakpoint to a px number for the runtime width test.
// undefined → 0 (never flatten by width).
const flattenPx =
  flattenBelow == null
    ? 0
    : typeof flattenBelow === "number"
      ? flattenBelow
      : (BREAKPOINTS[flattenBelow] ?? 0);
---

<div
  class:list={["curtain-reveal", className]}
  data-curtain-reveal
  data-move={move}
  data-curtain-flatten-below={flattenPx}
  style={`--curtain-slide: ${slideVh}svh;`}
>
  {/* OUTGOING — kept fully intact; the wrapper pins + slides its last screen. */}
  <div class="curtain-outgoing" data-curtain-outgoing>
    <slot name="outgoing" />
  </div>

  {/* INCOMING — pulled up to sit behind the outgoing curtain, held at its start
      (via --curtain-hold) until the slide reveals it. */}
  <div class="curtain-incoming" data-curtain-incoming>
    <slot name="incoming" />
  </div>
</div>

<style>
  .curtain-reveal {
    position: relative;
  }

  /* Pull the incoming section up by one screen PLUS the slide runway. The incoming
     is then FROZEN at this parked position by a GSAP pin (see script) for the
     whole slide span, so it sits static behind the curtain and is flush at the
     top the moment the curtain (one screen) finishes lifting — no trailing gap.
     The overlap is a scroll-space reservation, not an assumption about the
     incoming's height: the freeze pin + one-screen travel keep the reveal aligned
     on every viewport regardless of what the incoming section is. */
  .curtain-incoming {
    position: relative;
    z-index: 1;
    margin-top: -100svh;
  }

  /* The outgoing curtain rides ABOVE the incoming section while it slides away.
     The slotted outgoing section is responsible for being opaque (painting its
     own bg) — otherwise the incoming section parked behind it bleeds through the
     gaps before the curtain lifts. */
  .curtain-outgoing {
    position: relative;
    z-index: 2;
  }

  /* Hand the incoming section its HOLD distance = the full overlap it stays
     covered for (one screen + the slide runway). A section that supports a
     scroll-hold (see FilmstripVariant on desktop) reads --curtain-hold and freezes
     its internal scrub for this many px; the wrapper's GSAP freeze pin holds the
     whole section still regardless, so both agree. Inherited down to the section. */
  .curtain-incoming {
    --curtain-hold: 100svh;
  }

  /* Flatten: remove the overlap + hold so both sections sit in normal flow and
     self-drive. Driven by JS on the root:
       • data-curtain-flat — set when the viewport is below `flattenBelow` (the
         caller's opt-out) OR reduced motion is active.
     Plus the in-app a11y reduced-motion toggle as a static fallback. */
  [data-curtain-reveal][data-curtain-flat] .curtain-incoming {
    margin-top: 0;
    --curtain-hold: 0px;
  }
  @media (prefers-reduced-motion: reduce) {
    .curtain-incoming {
      margin-top: 0;
      --curtain-hold: 0px;
    }
  }
  :global([data-a11y-motion="reduced"]) .curtain-incoming {
    margin-top: 0;
    --curtain-hold: 0px;
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { readMotionPreference } from "@/hooks/useMotionPreference";
  gsap.registerPlugin(ScrollTrigger);

  type Move = "up" | "down" | "left" | "right";

  // The slide-off transform for each direction — exactly ONE SCREEN, measured the
  // SAME way as the CSS overlap (a 100svh probe → px), NOT window.innerHeight.
  // The outgoing section can be many viewports tall, but only its last screen is
  // at the seam, and the incoming is parked exactly one screen up, so one screen
  // of travel uncovers it flush. Using the same svh measurement as the overlap is
  // what keeps desktop and mobile identical — window.innerHeight equals 100svh on
  // desktop but diverges on mobile as the browser chrome collapses.
  function offEnd(move: Move, screen: number): gsap.TweenVars {
    switch (move) {
      case "down":  return { y: screen };
      case "left":  return { x: -screen };
      case "right": return { x: screen };
      case "up":
      default:      return { y: -screen };
    }
  }

  // Resolve a CSS length to px via a throwaway probe so svh resolves to the
  // CURRENT viewport. Re-run on each refresh — on mobile the browser chrome shows/
  // hides as you scroll, changing what svh resolves to.
  function measurePx(root: HTMLElement, cssLength: string): number {
    const probe = document.createElement("div");
    probe.style.cssText =
      "position:absolute;visibility:hidden;height:" + cssLength + ";";
    root.appendChild(probe);
    const px = Math.max(1, probe.offsetHeight);
    probe.remove();
    return px;
  }

  function buildReveal(root: HTMLElement) {
    const outgoing = root.querySelector<HTMLElement>("[data-curtain-outgoing]");
    const incoming = root.querySelector<HTMLElement>("[data-curtain-incoming]");
    if (!outgoing || !incoming) return () => {};

    const move = ((root.getAttribute("data-move") as Move) || "up") as Move;

    // Pin the outgoing section's LAST screen at the seam and slide it off by ONE
    // SCREEN (100svh, matching the overlap) over `--curtain-slide` of scroll (the
    // duration). GSAP pins the outgoing wrapper: start when its bottom reaches the
    // viewport bottom (its last screen fills the viewport), end one slide-duration
    // later. `pinSpacing:false` because the incoming section already occupies that
    // scroll space (pulled up one screen under the curtain).
    //
    // Both the travel and the `end` distance are FUNCTIONAL so they recompute from
    // the live viewport on every ScrollTrigger.refresh() (with invalidateOnRefresh)
    // — essential on mobile where svh changes as chrome collapses.
    const tween = gsap.fromTo(
      outgoing,
      { x: 0, y: 0 },
      { ...offEnd(move, measurePx(root, "100svh")), ease: "none" },
    );

    const st = ScrollTrigger.create({
      trigger: outgoing,
      start: "bottom bottom",
      end: () => "+=" + measurePx(root, "var(--curtain-slide,120svh)"),
      pin: true,
      pinSpacing: false,
      scrub: true,
      anticipatePin: 1,
      invalidateOnRefresh: true,
      // Recompute the one-screen travel on each refresh so it always matches the
      // CSS overlap for the current viewport.
      onRefresh: () => {
        const off = offEnd(move, measurePx(root, "100svh")) as any;
        tween.invalidate();
        tween.vars.x = off.x ?? 0;
        tween.vars.y = off.y ?? 0;
      },
      animation: tween,
    });

    // FREEZE the incoming section for the SAME span the curtain covers it. The
    // curtain wrapper owns this — the incoming section needs no curtain awareness.
    // Without it, the incoming (in normal flow, pulled up one screen) scrolls up
    // WITH the page while the curtain is pinned on top, so you see it drift behind
    // the curtain before it lifts. Pinning it holds it dead-still at its parked
    // first screen until the curtain has fully slid off, then it releases into
    // normal scrolling. A section with its own scroll-hold (FilmstripVariant on
    // desktop) also honors --curtain-hold; this pin makes the freeze correct even
    // when it doesn't (e.g. the filmstrip's mobile fallback), so behavior matches
    // on every viewport. Same trigger geometry + duration as the curtain slide.
    const stHold = ScrollTrigger.create({
      trigger: outgoing,
      start: "bottom bottom",
      end: () => "+=" + measurePx(root, "var(--curtain-slide,120svh)"),
      pin: incoming,
      pinSpacing: false,
      anticipatePin: 1,
      invalidateOnRefresh: true,
    });

    return () => {
      st.kill();
      stHold.kill();
      tween.kill();
      gsap.set(outgoing, { clearProps: "transform" });
    };
  }

  function init() {
    const roots = document.querySelectorAll<HTMLElement>("[data-curtain-reveal]");
    if (!roots.length) return;

    roots.forEach((root) => {
      let cleanup: () => void = () => {};
      let flat = false;
      let built = false;

      // Flatten below the caller's `flattenBelow` px (0 = never) OR on reduced
      // motion. Default runs the curtain on ALL widths — the opt-out is the prop.
      const flattenBelow = Number(root.getAttribute("data-curtain-flatten-below") || 0);
      const shouldFlatten = () =>
        window.innerWidth < flattenBelow || readMotionPreference();

      const build = () => {
        const next = shouldFlatten();
        // If flat state didn't change, a resize just needs the pin re-measured
        // against the live viewport (the mobile browser-chrome path).
        if (built && next === flat) {
          if (!flat) ScrollTrigger.refresh();
          return;
        }
        cleanup();
        cleanup = () => {};
        flat = next;
        built = true;
        // data-curtain-flat drives the CSS that removes the overlap + hold.
        root.toggleAttribute("data-curtain-flat", flat);
        if (!flat) cleanup = buildReveal(root);
      };

      build();

      // Rebuild/refresh on any width change — crosses `flattenBelow` AND catches
      // mobile browser-chrome resize (which changes what svh resolves to).
      window.addEventListener("resize", build, { passive: true });
      window
        .matchMedia("(prefers-reduced-motion: reduce)")
        .addEventListener("change", build);
      new MutationObserver(build).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["data-a11y-motion", "data-a11y-animations"],
      });
    });
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
