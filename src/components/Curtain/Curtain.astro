---
// src/components/Curtain/Curtain.astro
//
// Curtain — a fully isolated scroll transition between two arbitrary sections.
//
// Usage:
//   <Curtain>
//     <div slot="1">…anything…</div>
//     <div slot="2">…anything…</div>
//   </Curtain>
//
// WHAT IT DOES (and ONLY this): the LAST screen of the top section is held pinned,
// then lifts up and off while the FIRST screen of the bottom section is revealed
// behind it — held frozen at the bottom section's own start. The end of the top
// meets the start of the bottom, whatever the height of either.
//
// ── HEIGHT-AGNOSTIC ──────────────────────────────────────────────────────────
// The reveal plays out over ONE viewport of scroll that the curtain owns end to
// end. It measures only its OWN pinned lift-layer's position. A 1-screen section
// and a 20-screen section transition identically — no breakpoints, no per-section
// tuning, no dependency on either child's height.
//
// ── ISOLATED FROM WHATEVER YOU SLOT IN ───────────────────────────────────────
// The curtain never transforms, pins, or margins the slotted content. It works by
// STACKING, not by reaching into the children:
//
//   • TOP renders in normal flow. Appended AFTER it (still inside the top layer) is
//     the curtain's OWN sticky lift-layer (`.curtain-lift`) — a transparent,
//     viewport-tall sticky-BOTTOM block. Sticky-bottom grabs the TOP layer's final
//     screen and holds it at the viewport bottom as the top ends, then releases it
//     as you scroll past. This layer is the ONLY thing the curtain pins; it carries
//     the top's last screen upward via a compositor transform.
//   • BOTTOM renders in normal flow immediately after, pulled up by exactly ONE
//     viewport so its first screen sits behind the held top screen and is uncovered
//     as the lift-layer rises. Crucially the bottom's OWN sticky/scroll systems
//     (e.g. a pinned horizontal filmstrip) are NOT yet in their scrub window during
//     the reveal — the reveal happens over the lift-layer's sticky window, which
//     ends exactly as the bottom's own first frame settles at progress 0. So the
//     bottom is revealed AT ITS START and only begins its own animation afterward.
//
// The lift is one CSS var (`--curtain-lift`, 0→1) written per-frame by a tiny
// self-contained controller keyed off the lift-layer's own rect. No coordinator,
// no globals, no knowledge of the children.

interface Props {
  /** Extra classes on the root. */
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class:list={["curtain-root", className]} data-curtain>
  {/*
    TOP LAYER — the slotted top section in normal flow, followed by the curtain's
    own sticky lift-layer. On top (z 2). The lift-layer holds and raises the top's
    final screen; the slotted content itself is never transformed.
  */}
  <div class="curtain-top" data-curtain-top>
    <slot name="1" />
    {/* The curtain's OWN pinned surface — transparent, viewport-tall, sticky to the
        bottom so it captures the top layer's last screen. Its transform is the lift. */}
    <div class="curtain-lift" data-curtain-lift aria-hidden="true"></div>
  </div>

  {/*
    BOTTOM LAYER — the slotted bottom section, pulled up one viewport so its first
    screen sits behind the held top screen and is revealed as the lift rises. Behind
    (z 1). Its own scroll systems run undisturbed.
  */}
  <div class="curtain-bottom" data-curtain-bottom>
    <slot name="2" />
  </div>
</div>

<style>
  .curtain-root {
    position: relative;
    isolation: isolate; /* scope the z-index stack to this instance */
    --curtain-lift: 0;  /* 0 rest → 1 fully lifted; written per-frame by the controller */
  }

  /* TOP LAYER — normal flow, on top. The lift is applied to the sticky lift-layer
     below, not to this wrapper, so the slotted content keeps its own geometry. */
  .curtain-top {
    position: relative;
    z-index: 2;
  }

  /* The curtain's own SENTINEL — a transparent, viewport-tall, sticky-TOP spacer
     appended after the top's content. It adds exactly ONE viewport of scroll runway
     at the top section's end, and while the page scrolls that runway the sentinel is
     pinned (its rect.top holds at 0) then releases (rect.top climbs negative). The
     controller reads THIS element's rect to drive the lift 0→1 over that one
     viewport. It paints nothing; it is pure, curtain-owned runway + measuring stick. */
  .curtain-lift {
    position: sticky;
    top: 0;
    height: 100svh;
    pointer-events: none;
  }

  /* The lift itself: the whole top wrapper translates up 0 → -100svh across the
     sentinel's pinned window, carrying the top's last painted screen off the top of
     the viewport. It returns to 0 outside that window, so the top behaves as if
     untouched for its entire scroll except the final handoff. Compositor-only
     transform — no layout, so the slotted content's own scroll math is never
     disturbed mid-lift. */
  .curtain-top {
    transform: translate3d(0, calc(var(--curtain-lift) * -100svh), 0);
    will-change: transform;
  }

  /* BOTTOM LAYER — pulled up ONE viewport so its first screen is already positioned
     behind the top's held last screen. As the top lifts, this is uncovered at the
     bottom section's own START (progress 0). Behind the top (z 1). Uniform static
     offset — the child's internal scroll math stays self-consistent. */
  .curtain-bottom {
    position: relative;
    z-index: 1;
    margin-top: -100svh;
  }

  /* Reduced motion: plain vertical stack, no lift, no overlap. */
  @media (prefers-reduced-motion: reduce) {
    .curtain-top { transform: none; }
    .curtain-lift { display: none; }
    .curtain-bottom { margin-top: 0; }
  }
</style>

<script>
  import { readMotionPreference } from "@/hooks/useMotionPreference";

  function initCurtains() {
    const roots = document.querySelectorAll<HTMLElement>("[data-curtain]");

    roots.forEach((root) => {
      const lift = root.querySelector<HTMLElement>("[data-curtain-lift]");
      if (!lift) return;

      if ((root as any)._curtainCleanup) {
        (root as any)._curtainCleanup();
        (root as any)._curtainCleanup = null;
      }

      let rafId: number | null = null;
      let last = -1;

      const clamp = (v: number, lo: number, hi: number) =>
        v < lo ? lo : v > hi ? hi : v;

      const apply = () => {
        rafId = null;

        if (readMotionPreference()) {
          if (last !== 0) {
            root.style.setProperty("--curtain-lift", "0");
            last = 0;
          }
          return;
        }

        // Measure the lift-layer's OWN position. While it is sticky-pinned its top
        // sits at (viewportHeight - layerHeight) = 0 offset from bottom; as you
        // scroll PAST the top section the layer un-pins and its top rises above the
        // viewport. We want lift 0→1 across exactly the one viewport where the top's
        // last screen would otherwise be held pinned then released.
        //
        // The lift-layer is sticky bottom:0 with height = 100svh. It stays pinned
        // (rect.top ≈ 0) until the top layer's content above it has scrolled past;
        // then rect.top goes negative as it releases. Progress = how far its top has
        // risen past the viewport top, over one viewport.
        const rect = lift.getBoundingClientRect();
        const vh = window.innerHeight || 1;
        // While pinned, rect.top === 0. On release it climbs negative toward -vh.
        // Map [0 → -vh] → lift [0 → 1].
        const progress = clamp(-rect.top / vh, 0, 1);

        if (progress !== last) {
          root.style.setProperty("--curtain-lift", progress.toFixed(4));
          last = progress;
        }
      };

      const onScroll = () => {
        if (rafId == null) rafId = requestAnimationFrame(apply);
      };

      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onScroll, { passive: true });
      apply();

      (root as any)._curtainCleanup = () => {
        window.removeEventListener("scroll", onScroll);
        window.removeEventListener("resize", onScroll);
        if (rafId != null) cancelAnimationFrame(rafId);
      };
    });
  }

  initCurtains();
  document.addEventListener("astro:page-load", initCurtains);
</script>
