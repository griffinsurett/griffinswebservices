---
// src/components/starter/ContentRenderer/variants/CapabilityTopicSectionsVariant.astro
/**
 * CapabilityTopicSectionsVariant
 *
 * Renders a sequence of editorial capability topics where each topic has:
 * 1. A full-height split section with heading/description and an image
 * 2. A supporting HiddenCardVariant grid below it using that topic's children
 *
 * Intended for parent capabilities like "web-design" where child capabilities
 * act as the large feature topics and grandchildren act as the supporting cards.
 */

import type { BaseVariantProps } from "../ContentRenderer.types";
import type { CollectionKey, CollectionEntry } from "astro:content";
import SectionHeader from "@/components/SectionHeader.astro";
import HiddenCardVariant from "./HiddenCardVariant.astro";
import CustomWebsiteBuildDemo from "@/components/AnimatedExamples/CustomWebsiteBuildDemo";
import DevelopmentBuildDemo from "@/components/AnimatedExamples/DevelopmentBuildDemo";
import PlatformCmsDevelopmentDemo from "@/components/AnimatedExamples/PlatformCmsDevelopmentDemo";
import BarGraph from "@/components/AnimatedExamples/BarGraph";
import WebsiteLoadComparison from "@/components/AnimatedExamples/WebsiteLoadComparison";
import KeepGrowingDemo from "@/components/AnimatedExamples/KeepGrowingDemo";
import { toArray } from "@/utils/array";
import { byItemKeys, children } from "@/utils/query";
import { getCollectionMeta, prepareCollectionEntries, type PreparedItem } from "@/utils/collections";

interface Props extends BaseVariantProps {
  childCollection?: CollectionKey;
  cardCollection?: CollectionKey;
  cardColumns?: 1 | 2 | 3 | 4 | "auto";
  cardClassName?: string;
  sectionMinHeightClass?: string;
  imageAspectClass?: string;
}

type TopicSectionData = {
  item: PreparedItem;
  cards: PreparedItem[];
  reverse: boolean;
  key: string;
};

type TopicDemoName =
  | "CustomWebsiteBuildDemo"
  | "DevelopmentBuildDemo"
  | "PlatformCmsDevelopmentDemo"
  | "WebsiteLoadComparison"
  | "KeepGrowingDemo";

const {
  items = [],
  className = "",
  id,
  childCollection = "capabilities",
  cardCollection = childCollection,
  cardColumns = 4,
  cardClassName = "",
  sectionMinHeightClass = "lg:min-h-[100svh]",
  imageAspectClass = "aspect-[4/3] lg:aspect-[5/4]",
} = Astro.props as Props;

const safeItems = toArray(items) as PreparedItem[];
const iconGradientId = `${id ?? "capability-topic-sections"}-icon-gradient`;
const cardMeta = getCollectionMeta(cardCollection);
const technologyMeta = getCollectionMeta("technologies");

const getReferenceIds = (value: unknown): string[] => {
  const refs = Array.isArray(value) ? value : value ? [value] : [];
  return refs
    .map((ref) => {
      if (typeof ref === "string") return ref;
      if (ref && typeof ref === "object") {
        const record = ref as Record<string, unknown>;
        return typeof record.id === "string"
          ? record.id
          : typeof record.slug === "string"
            ? record.slug
            : "";
      }
      return "";
    })
    .filter(Boolean);
};

const topicSections: TopicSectionData[] = await Promise.all(
  safeItems.map(async (item, index) => {
    const slug = item.slug || (item as any).id || `topic-${index}`;

    let cards: PreparedItem[] = [];

    if (slug) {
      const result = await children(cardCollection, slug).get();
      const cardEntries = (result.entries ?? []) as CollectionEntry<any>[];
      cards = await prepareCollectionEntries(cardEntries, cardCollection, cardMeta);
    }

    const technologyCardIds = getReferenceIds((item as Record<string, unknown>).technologyCards);
    if (technologyCardIds.length > 0) {
      const technologyResult = await byItemKeys("technologies", technologyCardIds).get();
      const technologyEntries = (technologyResult.entries ?? []) as CollectionEntry<"technologies">[];
      const technologyCards = await prepareCollectionEntries(
        technologyEntries,
        "technologies",
        technologyMeta
      );
      cards = [
        ...technologyCards.map((technologyCard) => ({
          ...technologyCard,
          url: undefined,
        })),
        ...cards,
      ];
    }

    return {
      item,
      cards,
      reverse: index % 2 === 1,
      key: slug,
    };
  })
);

const resolveTopicTitle = (item: PreparedItem) =>
  item.heading ? item.title : undefined;

const resolveTopicHeading = (item: PreparedItem) =>
  item.heading ?? item.title;

const resolveTopicCardColumns = (cardCount: number) => {
  if (cardColumns !== 4) return cardColumns;
  if (cardCount <= 3) return cardCount as 1 | 2 | 3;
  if (cardCount % 3 === 0) return 3;
  return 4;
};

const resolveTopicGridClassName = (cardCount: number) => {
  const resolvedColumns = resolveTopicCardColumns(cardCount);
  if (resolvedColumns === 3) return "items-stretch !gap-4 lg:!grid-cols-3";
  if (resolvedColumns === 4) return "items-stretch !gap-4 lg:!grid-cols-2 xl:!grid-cols-4";
  return "";
};

const resolveTopicDemoName = (item: PreparedItem): TopicDemoName | undefined => {
  const body = item.content ?? "";

  if (!body.includes('slot="topic-demo"')) return undefined;
  if (body.includes("<CustomWebsiteBuildDemo")) return "CustomWebsiteBuildDemo";
  if (body.includes("<DevelopmentBuildDemo")) return "DevelopmentBuildDemo";
  if (body.includes("<PlatformCmsDevelopmentDemo")) return "PlatformCmsDevelopmentDemo";
  if (body.includes("<WebsiteLoadComparison")) return "WebsiteLoadComparison";
  if (body.includes("<KeepGrowingDemo")) return "KeepGrowingDemo";

  return undefined;
};

const compactTopicCardProps =
  cardColumns === 4
    ? {
        stretchToFill: true,
        innerClassName: "px-4 md:px-6 py-6 md:py-7",
        listItem: {
          iconClassName:
            "faded-bg border border-soft flex h-16 w-16 items-center justify-center rounded-full p-3 mb-5 shrink-0",
          iconStyle: {
            stroke: `url(#${iconGradientId})`,
            fill: `url(#${iconGradientId})`,
          },
          titleClassName:
            "text-xl sm:text-2xl lg:text-[1.75rem] xl:text-[1.9rem] leading-[1.08] font-semibold tracking-wide text-heading mb-2 relative z-10",
          descriptionClassName:
            "text-sm md:text-base leading-[1.65] relative z-10",
        },
      }
    : undefined;
---

<section id={id} class={`outer-section relative ${className}`.trim()}>
  <svg class="absolute h-0 w-0 overflow-hidden" aria-hidden="true" focusable="false">
    <defs>
      <linearGradient id={iconGradientId} x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="var(--color-primary)" />
        <stop offset="100%" stop-color="var(--color-accent)" />
      </linearGradient>
    </defs>
  </svg>
  <div class="inner-section space-y-24 lg:space-y-32">
    {topicSections.map((topic, index) => {
      const textOrderClass = topic.reverse ? "lg:order-2" : "";
      const mediaOrderClass = topic.reverse ? "lg:order-1" : "lg:order-2";
      const topicDemoName = resolveTopicDemoName(topic.item);

      return (
        <section class="space-y-10 lg:space-y-14" data-topic={topic.key}>
          <div
            class={`grid items-center gap-10 lg:grid-cols-[minmax(0,0.88fr)_minmax(0,1fr)] ${sectionMinHeightClass}`.trim()}
          >
            <div class={textOrderClass}>
              <SectionHeader
                title={resolveTopicTitle(topic.item)}
                heading={resolveTopicHeading(topic.item)}
                description={topic.item.description}
                className="space-y-5 text-left max-w-3xl"
              />
            </div>

            <div class={mediaOrderClass}>
              <div
                class={`card-bg overflow-hidden rounded-3xl ${imageAspectClass}`.trim()}
              >
                {topicDemoName === "CustomWebsiteBuildDemo" ? (
                  <div class="flex h-full w-full p-4 sm:p-5 lg:p-6">
                    <CustomWebsiteBuildDemo client:visible className="h-full w-full" />
                  </div>
                ) : topicDemoName === "DevelopmentBuildDemo" ? (
                  <div class="flex h-full w-full items-center justify-center p-4 sm:p-5 lg:p-6">
                    <DevelopmentBuildDemo client:visible className="w-full max-w-[32rem]" />
                  </div>
                ) : topicDemoName === "PlatformCmsDevelopmentDemo" ? (
                  <div class="flex h-full w-full p-4 sm:p-5 lg:p-6">
                    <PlatformCmsDevelopmentDemo client:visible className="h-full w-full" />
                  </div>
                ) : topicDemoName === "WebsiteLoadComparison" ? (
                  <div class="flex h-full w-full flex-col justify-center gap-4 p-4 sm:gap-5 sm:p-5 lg:gap-6 lg:p-6">
                    <div class="flex flex-col gap-3 sm:gap-4">
                      <BarGraph
                        label="GWS Average"
                        value={97.5}
                        statValue={2.5}
                        statSuffix=" seconds"
                        variant="primary-reverse"
                        client:visible
                      />
                      <BarGraph
                        label="Industry Average"
                        value={34}
                        statValue={7.1}
                        statSuffix=" seconds"
                        variant="grey"
                        delay={200}
                        client:visible
                      />
                    </div>
                    <WebsiteLoadComparison client:visible className="w-full" />
                  </div>
                ) : topicDemoName === "KeepGrowingDemo" ? (
                  <div class="flex h-full w-full items-center justify-center p-4 sm:p-5 lg:p-6">
                    <KeepGrowingDemo client:visible className="w-full max-w-[32rem]" />
                  </div>
                ) : null}
              </div>
            </div>
          </div>

          {topic.cards.length > 0 && (
            <HiddenCardVariant
              items={topic.cards}
              columns={resolveTopicCardColumns(topic.cards.length)}
              showButtonSection={false}
              className={`px-0 ${cardClassName}`.trim()}
              contentClassName=""
              gridClassName={resolveTopicGridClassName(topic.cards.length)}
              card={compactTopicCardProps}
            />
          )}
        </section>
      );
    })}
  </div>
</section>
