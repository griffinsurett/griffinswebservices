---
// src/components/ContentRenderer/variants/SmallChecklistVariant.astro
/**
 * Small Checklist Variant - Compact checklist using homepage-sized checks
 * Great for tight spaces like pricing cards or short inclusion lists.
 */

import type { BaseVariantProps } from "../ContentRenderer.types";
import Section from "@/components/Section.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import Button from "@/components/Button/Button";
import SmallChecklistItem from "@/components/LoopComponents/SmallChecklistItem.astro";
import { shouldShowCollectionCTA } from "../utils/helpers";
import { toArray } from "@/utils/array";

interface Props extends BaseVariantProps {
  columns?: 1 | 2;
  ctaHref?: string;
  ctaText?: string;
  listClassName?: string;
  itemTextClassName?: string;
}

const {
  items = [],
  title,
  heading,
  description,
  className = "outer-section",
  columns = 1,
  collectionUrl,
  collectionTitle,
  id,
  showButtonSection = true,
  ctaHref,
  ctaText,
  listClassName = "",
  itemTextClassName = "text-text text-sm leading-relaxed",
} = Astro.props as Props;

const safeItems = toArray(items);

const columnClasses: Record<1 | 2, string> = {
  1: "grid-cols-1",
  2: "grid-cols-1 md:grid-cols-2",
};

const showHeader = Boolean(title || heading || description);
const showCTA =
  showButtonSection &&
  shouldShowCollectionCTA(collectionUrl, safeItems.length) &&
  (ctaText || title || collectionTitle) &&
  (ctaHref || collectionUrl);
---

<Section id={id} class={`relative ${className}`.trim()}>
  <div class="inner-section">
    {showHeader && (
      <SectionHeading
        title={title}
        heading={heading}
        description={description}
        className="text-section"
      />
    )}

    {safeItems.length > 0 && (
      <ul class={`grid ${columnClasses[columns]} gap-2 list-none ${showHeader ? "mt-8" : ""} ${listClassName}`.trim()}>
        {safeItems.map((item) => (
          <SmallChecklistItem as="li" textClassName={itemTextClassName}>
            {item.title ?? item.description ?? ""}
          </SmallChecklistItem>
        ))}
      </ul>
    )}

    {showCTA && (
      <div class="buttons-section-center">
        <Button href={ctaHref ?? collectionUrl} rightIcon="lu:arrow-right" variant="secondary" client:visible>
          {ctaText ?? `View All ${(title ?? collectionTitle ?? "").trim()}`}
        </Button>
      </div>
    )}
  </div>
</Section>
