---
// TestimonialCirclesVariant.astro - Face circles over a five-star rating.
// No counter. (The animated-counter version is kept as
// TestimonialCirclesCounterVariant.astro.)
import { Image } from "astro:assets";
import Icon from "@/components/Icon";
import Placeholder from "@/assets/placeholder.jpg";
import type { BaseVariantProps } from "../ContentRenderer.types";
import { toArray } from "@/utils/array";
import { resolveImageMetadata, getImageAlt } from "@/utils/images";

interface Props extends BaseVariantProps {
  link?: string;
}

const {
  items = [],
  className = "",
  link = "/#testimonials-home",
  id,
} = Astro.props as Props;

const safeItems = toArray(items);
const faces = safeItems.slice(0, 5);

// Unique per-render id so multiple instances on a page don't collide.
const starGradientId = `${id ?? "testimonial"}-star-gradient`;
if (faces.length === 0) {
  return;
}

const resolveImage = (face: any) => {
  const featured = face.featuredImage;
  const metadata = resolveImageMetadata(featured);

  if (metadata) {
    const alt = getImageAlt(featured, face.author ?? "Testimonial");
    return { src: metadata, alt };
  }

  return { src: Placeholder, alt: face.author ?? "Testimonial" };
};
---

<a
  id={id}
  href={link}
  class={`testimonials flex items-center gap-4 lg:gap-5 px-2 md:px-0 ${className}`.trim()}
  aria-label="Five-star rated - View testimonials"
>
  {/* Brand gradient used to fill the stars (fa6-solid stars are fill-based, so
      passing this as the Icon `color` renders fill="url(#…)"). */}
  <svg aria-hidden="true" width="0" height="0" focusable="false" class="absolute pointer-events-none w-0 h-0 overflow-hidden">
    <defs>
      <linearGradient id={starGradientId} x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="currentColor" class="text-primary-100" />
        <stop offset="55%" stop-color="currentColor" class="text-primary" />
        <stop offset="100%" stop-color="currentColor" class="text-primary-800" />
      </linearGradient>
    </defs>
  </svg>

  <div class="flex justify-center items-center">
    {faces.map((face) => (
      <div class="circle -mr-2 lg:-mr-3 first:ml-0 w-9 h-9 sm:w-10 sm:h-10 rounded-full overflow-hidden shrink-0 flex items-center justify-center">
        {(() => {
          const resolved = resolveImage(face);
          return (
            <Image
              src={resolved.src}
              alt={resolved.alt}
              widths={[56]}
              class="object-cover w-full h-full"
              fetchpriority="high"
              loading="eager"
            />
          );
        })()}
      </div>
    ))}
  </div>

  {/* Stars pinned to the top, label to the bottom — the column stretches to the
      circle height so the two lines flank it. */}
  <div class="flex flex-col items-start justify-between self-stretch py-0.5">
    <div class="flex items-center gap-0.5" role="img" aria-label="Rated 5 out of 5 stars">
      {Array.from({ length: 5 }).map(() => (
        <Icon
          icon="fa6-solid:star"
          size="sm"
          color={`url(#${starGradientId})`}
          className="w-3.5 h-3.5 sm:w-4 sm:h-4"
          aria-hidden={true}
        />
      ))}
    </div>

    <p class="m-0 capitalize text-sm lg:text-base leading-relaxed text-heading">
      Trusted by businesses
    </p>
  </div>
</a>

<script is:inline>
  (function() {
    if (window.__testimonialsPulseInitialized) return;
    window.__testimonialsPulseInitialized = true;

    const initTestimonialsPulse = () => {
      // Pulse only the face circles — leave the trailing "+" badge static.
      const circles = document.querySelectorAll(".testimonials .circle");
      if (!circles.length) return;

      let idx = 0;
      const pulse = () => {
        const prev = (idx - 1 + circles.length) % circles.length;
        circles[prev]?.classList.remove("heartbeat");
        circles[idx]?.classList.add("heartbeat");
        idx = (idx + 1) % circles.length;
      };

      pulse();
      setInterval(pulse, 1600);
    };

    if ("requestIdleCallback" in window) {
      requestIdleCallback(initTestimonialsPulse);
    } else {
      window.addEventListener("load", initTestimonialsPulse, { once: true });
    }
  })();
</script>
