---
// src/components/ContentRenderer/variants/TestimonialGridVariant.astro
import type { BaseVariantProps } from "../ContentRenderer.types";
import SectionHeader from "@/components/SectionHeader.astro";
import Section from "@/components/Section.astro";
import TestimonialQuoteCarousel from "@/components/LoopTemplates/TestimonialQuoteCarousel";
import { toArray } from "@/utils/array";

interface Props extends BaseVariantProps {
  columns?: 1 | 2;
  gap?: "sm" | "md" | "lg" | "xl";
}

const {
  items = [],
  title,
  heading,
  description,
  className = "",
  collectionTitle,
  id,
} = Astro.props as Props;

const safeItems = toArray(items);
---

<Section
  id={id}
  class={`outer-section relative ${className}`.trim()}
>
  <div class="inner-section">
    {(title || collectionTitle || description || heading) && (
      <SectionHeader
        title={title ?? collectionTitle}
        heading={heading ?? title ?? collectionTitle}
        description={description}
        className="text-section"
        headingClassName="mb-6"
        descriptionClassName="large-text"
      />
    )}

    {safeItems.length > 0 && (
      <TestimonialQuoteCarousel
        client:visible
        items={safeItems}
        quoteClassName="text-[clamp(1.2rem,2vw,1.6rem)] tracking-[-0.03em]"
      />
    )}
  </div>
</Section>
