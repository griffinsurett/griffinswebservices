---
// src/components/ContentRenderer/variants/LinkPageVariant.astro
/**
 * Link Page Variant - Single-column links page layout.
 */

import LinkCard from "@/components/LoopComponents/LinkCard";
import LinkPageShareButton from "@/components/LinkPageShareButton";
import Logo from "@/components/Logo/Logo.astro";
import Icon from "@/components/Icon";
import SocialIcon from "@/components/LoopComponents/SocialIcon";
import ComputerScreen from "@/components/LoopTemplates/ComputerScreen.astro";
import PortfolioScreenShowcase from "@/components/LoopTemplates/Portfolio/PortfolioScreenShowcase";
import ThemeControls from "@/components/ThemeControls/ThemeControls.jsx";
import Section from "@/components/Section.astro";
import type { BaseVariantProps } from "../ContentRenderer.types";
import { toArray } from "@/utils/array";
import { getPublishedCollection } from "@/utils/collections";
import { getImageSrc } from "@/layouts/collections/helpers/layoutHelpers";
import { getCollection } from "astro:content";

interface Props extends BaseVariantProps {
  showIcons?: boolean;
}

const {
  items = [],
  title,
  description,
  className = "",
  id,
  showIcons = true,
} = Astro.props as Props;

const safeItems = toArray(items);
const socialLinks = await getCollection("social-media");
const contactLinks = await getCollection("contact-us");
const portfolioProjects = (await getPublishedCollection("projects")).map((entry) => ({
  id: entry.id,
  slug: entry.slug,
  title: entry.data.title,
  alt:
    (typeof entry.data.featuredImage === "object" &&
      entry.data.featuredImage &&
      "alt" in entry.data.featuredImage &&
      typeof entry.data.featuredImage.alt === "string" &&
      entry.data.featuredImage.alt) ||
    entry.data.title ||
    "Project preview",
  image:
    getImageSrc(entry.data.featuredImage) ||
    getImageSrc(entry.data.bannerImage),
  projectUrl: entry.data.projectUrl,
  url: entry.data.url,
}));
---

<Section id={id} class={`min-h-screen ${className}`}>
  <div class="relative flex flex-col gap-4 sm:gap-7">
    <header role="banner" aria-label="Links page header">
      <div class="grid grid-cols-[1fr_auto_1fr] items-center head-foot-section py-2 gap-4">
        <div class="justify-self-start">
          <Logo
            loading="eager"
            trigger="load"
            animateOutText={false}
            loop={false}
            altContext="Links"
            titleFirstClass="text-[2rem] sm:text-3xl text-heading -ml-[0.1rem] leading-wide font-bold no-translate"
            titleRestClass="font-light emphasized-text uppercase text-[0.7rem] sm:text-xs lg:text-sm p-0 m-0 tracking-[0.2em]"
          />
        </div>

        <ThemeControls client:idle />

        <div class="justify-self-end">
          <LinkPageShareButton
            shareTitle="Griffin's Web Services Links"
            client:idle
          />
        </div>
      </div>
    </header>

    <div class="mx-auto flex w-full max-w-[34rem] flex-col gap-4 overflow-hidden px-4 sm:gap-7">
      {
        contactLinks.length > 0 && (
          <div class="relative z-10 flex justify-center">
            <ul class="flex flex-wrap justify-center gap-6 list-none">
              {contactLinks.map((entry) => {
                const value = entry.data.description?.trim();
                const prefix = entry.data.linkPrefix ?? "";
                const href = value ? `${prefix}${value}` : undefined;
                const iconName = entry.data.icon ?? "fa6-solid:circle-dot";

                return (
                  <li class="contents">
                    {href ? (
                      <a
                        href={href}
                        class="inline-flex text-primary transition-all main-duration hover:-translate-y-1"
                        aria-label={entry.data.title}
                        title={entry.data.title}
                      >
                        {/* <span class="inline-flex h-12 w-12 items-center justify-center rounded-full"> */}
                          <Icon
                            icon={iconName}
                            size="lg"
                            className="text-current"
                          />
                        {/* </span> */}
                      </a>
                    ) : (
                      <div
                        class="inline-flex text-primary"
                        aria-label={entry.data.title}
                        title={entry.data.title}
                      >
                        <span class="inline-flex h-12 w-12 items-center justify-center rounded-full">
                          <Icon
                            icon={iconName}
                            size="md"
                            className="text-current"
                          />
                        </span>
                      </div>
                    )}
                  </li>
                );
              })}
            </ul>
          </div>
        )
      }

      {
        portfolioProjects.length > 0 && (
          <div class="mx-auto w-full max-w-[920px]">
            <div class="relative h-[240px] sm:h-[320px] lg:h-[360px]">
              <ComputerScreen>
                <div class="relative h-full bottom-image-fade">
                  <div class="relative z-10 h-full">
                    <PortfolioScreenShowcase
                      client:visible
                      items={portfolioProjects}
                    />
                  </div>
                </div>
              </ComputerScreen>
            </div>
          </div>
        )
      }

      {
        safeItems.length > 0 && (
          <nav class="relative z-10" aria-label="Links menu">
            <ul class="grid grid-cols-1 gap-4 list-none sm:gap-5">
              {safeItems.map((item, index) => (
                <li
                  class="h-full"
                  data-animate="fade-in-up"
                  data-animate-once="true"
                  data-animate-delay={String(index * 70)}
                  data-animate-threshold="0.15"
                  data-animate-root-margin="-10% 0px -10% 0px"
                >
                  <LinkCard
                    data={{
                      ...item,
                      ...(showIcons ? {} : { icon: undefined }),
                    }}
                    className="h-full"
                  />
                </li>
              ))}
            </ul>
          </nav>
        )
      }

      {
        socialLinks.length > 0 && (
          <div class="flex justify-center">
            <ul class="flex flex-wrap justify-center gap-3.5 list-none sm:gap-4">
              {socialLinks.map((entry) => (
                <li>
                  <SocialIcon
                    title={entry.data.title}
                    url={entry.data.link}
                    icon={entry.data.icon}
                    size="md"
                    client:visible
                  />
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>
  </div>
</Section>
