---
// src/components/ContentRenderer/variants/LinkTreeVariant.astro
/**
 * LinkTree Variant - Single-column links layout using FeatureCard styling.
 */

import LinkCard from "@/components/LoopComponents/LinkCard";
import Logo from "@/components/Logo/Logo.astro";
import Icon from "@/components/Icon";
import SocialIcon from "@/components/LoopComponents/SocialIcon";
import ThemeControls from "@/components/ThemeControls/ThemeControls.jsx";
import Section from "@/components/Section.astro";
import type { BaseVariantProps } from "../ContentRenderer.types";
import { toArray } from "@/utils/array";
import { getCollection } from "astro:content";

interface Props extends BaseVariantProps {
  showIcons?: boolean;
}

const {
  items = [],
  title,
  description,
  className = "",
  id,
  showIcons = true,
} = Astro.props as Props;

const safeItems = toArray(items);
const socialLinks = await getCollection("social-media");
const contactLinks = await getCollection("contact-us");
---

<Section id={id} class={`min-h-screen ${className}`}>
  <header class="mb-8" role="banner" aria-label="Links page header">
    <div class="grid grid-cols-[1fr_auto_1fr] items-center head-foot-section py-2 gap-4">
      <div class="flex items-center justify-start">
        <ThemeControls client:hover />
      </div>

      <div class="flex items-center justify-center">
        <Logo
          loading="eager"
          trigger="visible"
          animateOutText={false}
          useLottie={true}
          loop={false}
          altContext="Links"
        />
      </div>

      <div aria-hidden="true" class="flex items-center justify-end" />
    </div>
  </header>

  <div class="mx-auto max-w-[34rem] px-4">
    <div class="relative overflow-hidden rounded-[2.2rem] border border-[var(--color-border-soft-strong)] card-bg px-5 py-8 shadow-[0_22px_80px_color-mix(in_srgb,var(--color-primary)_18%,transparent)]">
      <div class="relative z-10">

        {contactLinks.length > 0 && (
          <div class="flex justify-center">
            <ul class="flex flex-wrap justify-center gap-3 list-none">
              {contactLinks.map((entry) => {
                const value = entry.data.description?.trim();
                const prefix = entry.data.linkPrefix ?? "";
                const href = value ? `${prefix}${value}` : undefined;
                const iconName = entry.data.icon ?? "fa6-solid:circle-dot";

                return (
                  <li>
                    {href ? (
                      <a
                        href={href}
                        class="inline-flex text-primary transition-all main-duration hover:-translate-y-1"
                        aria-label={entry.data.title}
                        title={entry.data.title}
                      >
                        <span class="inline-flex h-12 w-12 items-center justify-center rounded-full">
                          <Icon icon={iconName} size="lg" className="text-current" />
                        </span>
                      </a>
                    ) : (
                      <div
                        class="inline-flex text-primary"
                        aria-label={entry.data.title}
                        title={entry.data.title}
                      >
                        <span class="faded-bg inline-flex h-12 w-12 items-center justify-center rounded-full">
                          <Icon icon={iconName} size="md" className="text-current" />
                        </span>
                      </div>
                    )}
                  </li>
                );
              })}
            </ul>
          </div>
        )}

        {(title || description) && (
          <header class="mb-6 text-center sm:mb-8">
            {/* {title && (
              <p class="text-[0.7rem] font-semibold uppercase tracking-[0.42em] text-primary/80">
                {title}
              </p>
            )} */}
            {/* {description && (
              <p class="mx-auto mt-2 max-w-[24rem] text-sm text-text/80 sm:text-[0.95rem]">
                {description}
              </p>
            )} */}
          </header>
        )}

        {safeItems.length > 0 && (
          <nav aria-label="Links menu">
            <ul class="grid grid-cols-1 gap-4 list-none sm:gap-5">
              {safeItems.map((item, index) => (
                <li
                  class="h-full"
                  data-animate="fade-in-up"
                  data-animate-once="true"
                  data-animate-delay={String(index * 70)}
                  data-animate-threshold="0.15"
                  data-animate-root-margin="-10% 0px -10% 0px"
                >
                  <LinkCard
                    data={{
                      ...item,
                      ...(showIcons ? {} : { icon: undefined }),
                    }}
                    className="h-full"
                  />
                </li>
              ))}
            </ul>
          </nav>
        )}

        {socialLinks.length > 0 && (
          <div class="mt-7 flex justify-center sm:mt-8">
            <ul class="flex flex-wrap justify-center gap-3.5 list-none sm:gap-4">
              {socialLinks.map((entry) => (
                <li>
                  <SocialIcon
                    title={entry.data.title}
                    url={entry.data.link}
                    icon={entry.data.icon}
                    size="md"
                    client:visible
                  />
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>
  </div>
</Section>
