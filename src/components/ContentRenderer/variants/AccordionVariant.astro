---
// src/components/ContentRenderer/variants/AccordionVariant.astro
/**
 * AccordionVariant
 * Full-width editorial accordion with centered heading and minimal row styling.
 * Uses ContentBridge so React accordions can consume Astro content.
 */

import type { BaseVariantProps } from "../ContentRenderer.types";
import ContentBridge from "../ContentBridge/ContentBridge.astro";
import FaqAccordion from "@/components/LoopTemplates/FaqAccordion";
import Button from "@/components/Button/Button";
import SectionHeader from "@/components/SectionHeader.astro";
import Section from "@/components/Section.astro";
import { shouldShowCollectionCTA } from "../utils/helpers";
import { toArray } from "@/utils/array";

interface Props extends BaseVariantProps {
  allowMultiple?: boolean;
  ctaHref?: string;
  ctaText?: string;
}

const {
  items = [],
  title,
  heading,
  description,
  className = "",
  allowMultiple = false,
  collectionUrl,
  collectionTitle,
  id,
  ctaHref,
  ctaText,
  showButtonSection = true,
} = Astro.props as Props;

const safeItems = toArray(items);
const sectionTitle = title ?? collectionTitle;
const showHeader = Boolean(sectionTitle || heading || description);
---

<Section
  id={id}
  class={`outer-section relative ${className}`.trim()}
>
  <div class="inner-section mx-auto max-w-7xl">
    {
      showHeader && (
        <div class="mx-auto mb-14 max-w-3xl text-center md:mb-16">
          <SectionHeader
            title={sectionTitle}
            heading={heading}
            description={description}
            className="text-center max-w-3xl"
            titleClassName="tracking-[0.25em]"
            headingClassName="h2 mb-4"
            descriptionClassName="large-text text-text/80"
          />
        </div>
      )
    }

    {
      safeItems.length > 0 && (
        <ContentBridge items={safeItems} bridgeId={id}>
          <Fragment slot="default">
            <FaqAccordion
              items={safeItems.map((item, index) => ({
                id: item.id,
                title: item.title || "Untitled",
                description: item.description,
                contentSlotId: `${id}-slot-${index}`,
              }))}
              allowMultiple={allowMultiple}
              className="mx-auto max-w-6xl"
              client:visible
            />
          </Fragment>
        </ContentBridge>
      )
    }

    {
      showButtonSection &&
        shouldShowCollectionCTA(collectionUrl, safeItems.length) &&
        (ctaText || title || collectionTitle) &&
        (ctaHref || collectionUrl) && (
          <div class="buttons-section-center mt-10">
            <Button
              client:visible
              href={ctaHref ?? collectionUrl}
              rightIcon="lu:arrow-right"
              variant="secondary"
              size="lg"
            >
              {ctaText ?? `View All ${(title ?? collectionTitle ?? "").trim()}`}
            </Button>
          </div>
        )
    }
  </div>
</Section>
