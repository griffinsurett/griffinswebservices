---
// PortfolioVideoGridShowcaseVariant
import type { BaseVariantProps } from "../ContentRenderer.types";
import Section from "@/components/Section.astro";
import PortfolioMediaTile from "@/components/LoopComponents/Portfolio/PortfolioMediaTile.astro";
import { animationProps } from "@/integrations/scroll-animations/props";
import { toArray } from "@/utils/array";

interface ProjectItem extends Record<string, any> {
  featuredVideo?: string;
  fullSiteImage?: unknown;
  bannerImage?: unknown;
  image?: unknown;
  featuredImage?: unknown;
}

interface Props extends BaseVariantProps {
  maxItems?: number;
}

const {
  items = [],
  className = "",
  id,
  maxItems = 3,
} = Astro.props as Props;

const gridProjects = (toArray(items) as ProjectItem[])
  .filter((item) => {
    const hasVideo = typeof item.featuredVideo === "string" && item.featuredVideo.length > 0;
    const hasImage =
      item.fullSiteImage || item.bannerImage || item.image || item.featuredImage;
    return Boolean(hasVideo || hasImage);
  })
  .slice(0, maxItems);

if (!gridProjects.length) {
  return;
}
---

<Section id={id} class={`relative ${className}`.trim()}>
  <div class="inner-section">
    <div class="portfolio-video-grid">
      {gridProjects.map((item, index) => (
        <div
          class="portfolio-video-grid__item"
          {...animationProps("fade-in-up", {
            once: false,
            threshold: 0.18,
            rootMargin: "-6% 0px -10% 0px",
            delay: Math.min(index * 80, 240),
          })}
        >
          <PortfolioMediaTile item={item} />
        </div>
      ))}
    </div>
  </div>
</Section>

<style>
  .portfolio-video-grid {
    display: grid;
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }

  .portfolio-video-grid__item {
    display: block;
  }

  @media (min-width: 768px) {
    .portfolio-video-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1200px) {
    .portfolio-video-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
