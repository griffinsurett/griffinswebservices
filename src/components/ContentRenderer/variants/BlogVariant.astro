---
// src/components/ContentRenderer/variants/BlogVariant.astro
/**
 * Blog Variant — article/blog listing (webmaxers editorial cards under a GWS
 * SectionHeading). This is the ONLY blog look now; the old starter-card branch
 * was removed. The heading supports a two-part heading ({ before, text, after })
 * like the homepage's "Stay Informed. Read Our Latest Insights."
 */

import type { BaseVariantProps } from "../ContentRenderer.types";
import ArticleCard from "@/components/LoopComponents/ArticleCard.astro";
import Button from "@/components/Button/Button";
import Section from "@/components/Section.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import { shouldShowCollectionCTA } from "../utils/helpers";
import { toArray } from "@/utils/array";

interface Props extends BaseVariantProps {
  columns?: 1 | 2 | 3;
  /** Small uppercase eyebrow (rendered as the SectionHeading title pill). */
  eyebrow?: string;
  /** Show the "View all" section button. Default true; pass false to hide it. */
  showButtonSection?: boolean;
}

const {
  items = [],
  title,
  heading,
  description,
  className = "",
  columns = 2,
  eyebrow,
  collectionUrl,
  collectionTitle,
  showButtonSection = true,
  id,
} = Astro.props as Props;

const safeItems = toArray(items);
const viewAllText = `View All ${collectionTitle || "Articles"}`;
// Section "View all" CTA shows only when explicitly enabled AND there's a target.
const showCTA = showButtonSection && shouldShowCollectionCTA(collectionUrl, safeItems.length);

const columnClasses = {
  1: "grid-cols-1",
  2: "grid-cols-1 lg:grid-cols-2",
  3: "grid-cols-1 md:grid-cols-2 lg:grid-cols-3",
};
---

<Section id={id} class={`relative overflow-hidden py-4 lg:py-12 ${className}`.trim()}>
  <div class="inner-section">
    {(title || eyebrow || heading || description) && (
      <div class="heading-padding">
        <SectionHeading
          title={eyebrow ?? title}
          heading={heading}
          description={description}
          className="text-section"
        />
      </div>
    )}

    <ul class:list={["grid list-none gap-8", columnClasses[columns]]}>
      {safeItems.map((item: any) => (
        <li>
          <ArticleCard {...item} />
        </li>
      ))}
    </ul>

    {showCTA && (
      <div class="buttons-section-center mt-12">
        <Button variant="secondary" href={collectionUrl} client:visible>
          {viewAllText}
        </Button>
      </div>
    )}
  </div>
</Section>
