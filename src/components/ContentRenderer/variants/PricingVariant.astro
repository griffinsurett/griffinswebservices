---
import type { BaseVariantProps } from "../ContentRenderer.types";
import Section from "@/components/Section.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import Button from "@/components/Button/Button";
import IconListItem from "@/components/LoopComponents/IconListItem";
import SmallChecklistItem from "@/components/LoopComponents/SmallChecklistItem.astro";
import { ctaData } from "@/content/siteData";
import { toArray } from "@/utils/array";

interface PricingItemRecord extends Record<string, any> {
  title?: string;
  description?: string;
  icon?: string;
  url?: string;
  link?: string;
  price?: string;
  pricePrefix?: string;
  priceSuffix?: string;
  tags?: string[];
  features?: string[];
}

interface Props extends BaseVariantProps {
  columns?: 1 | 2 | 3;
}

const {
  items = [],
  title,
  heading,
  description,
  className = "outer-section",
  columns = 3,
  id,
} = Astro.props as Props;

const safeItems = toArray(items) as PricingItemRecord[];

const gridClassMap: Record<1 | 2 | 3, string> = {
  1: "grid grid-cols-1 gap-8",
  2: "grid grid-cols-1 lg:grid-cols-2 gap-8",
  3: "grid grid-cols-1 lg:grid-cols-3 gap-8",
};

const showHeader = Boolean(title || heading || description);

const hasFeaturedTag = (item: PricingItemRecord) =>
  Array.isArray(item?.tags) &&
  item.tags.some((tag) => typeof tag === "string" && tag.toLowerCase() === "featured");

const isHostingItem = (item: PricingItemRecord) => {
  const titleValue = typeof item?.title === "string" ? item.title.toLowerCase() : "";
  return titleValue.includes("hosting") || titleValue.includes("maintenance");
};

const pricingIconClassName =
  "mx-auto border-2 border-primary/35 bg-gradient-to-br from-primary/12 to-primary/5 text-primary";

const isExternalHref = (href?: string) =>
  typeof href === "string" && /^(https?:)?\/\//.test(href);
---

<Section id={id} class={`relative overflow-hidden ${className}`.trim()}>
  <div class="inner-section">
    {showHeader && (
      <div class="mx-auto max-w-4xl">
        <SectionHeader
          title={title}
          heading={heading}
          description={description}
          className="text-section mx-auto"
          headingClassName="h2 mb-6 text-center"
          descriptionClassName="large-text text-center"
        />
      </div>
    )}

    <ul class:list={[gridClassMap[columns], "list-none", showHeader && "mt-12"]}>
      {safeItems.map((item) => {
        const isFeatured = hasFeaturedTag(item);
        const isHosting = isHostingItem(item);
        const price = typeof item.price === "string" && item.price.trim().length > 0
          ? item.price.trim()
          : isHosting
            ? "Custom Monthly Quote"
            : "Custom Quote";

        const buttonHref = item.link ?? item.url ?? ctaData.link;
        const buttonTarget = isExternalHref(buttonHref) ? "_blank" : undefined;
        const buttonRel = isExternalHref(buttonHref) ? "noopener noreferrer" : undefined;
        const features = Array.isArray(item.features)
          ? item.features.filter((feature) => typeof feature === "string" && feature.trim().length > 0)
          : [];
        const pricePrefix = typeof item.pricePrefix === "string" ? item.pricePrefix.trim() : "";
        const priceSuffix = typeof item.priceSuffix === "string" ? item.priceSuffix.trim() : "";

        return (
          <li class:list={["h-full", isFeatured && "pt-5"]}>
            <div class="relative h-full">
              {isFeatured && (
                <div class="absolute left-1/2 top-0 z-20 max-w-[calc(100%-1rem)] -translate-x-1/2 -translate-y-1/2">
                  <span class="inline-flex items-center gap-2 rounded-full border-2 border-primary bg-gradient-to-br from-primary light:to-bg2 dark:to-primary/25 px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.24em] text-bg shadow-lg shadow-primary/20">
                    <span aria-hidden="true">👍</span>
                    <span>Most Popular</span>
                  </span>
                </div>
              )}

              <article
              class:list={[
                "group relative flex h-full flex-col overflow-hidden rounded-3xl card-bg shadow-xl transition-all duration-500",
                isFeatured && "lg:-translate-y-4 lg:scale-[1.03] border-accent/45 shadow-accent/20",
                !isFeatured && "hover:-translate-y-2 hover:border-accent/40",
              ]}
            >
              <div class="inner-card-style inner-card-transition inner-card-color" aria-hidden="true"></div>

              {isFeatured && (
                <>
                  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(94,118,246,0.22),transparent_42%),radial-gradient(circle_at_bottom_left,rgba(94,118,246,0.16),transparent_34%)]" aria-hidden="true"></div>
                  <div class="pointer-events-none absolute -right-10 top-10 h-28 w-28 rounded-full bg-accent/18 blur-3xl" aria-hidden="true"></div>
                </>
              )}

              <div class:list={["relative z-10 flex h-full flex-col items-center p-6 text-center lg:p-8", isFeatured && "pt-12 lg:pt-14"]}>
                <div class="w-full">
                  <IconListItem
                    data={{
                      icon: item.icon,
                      title: item.title,
                      description: item.description,
                    }}
                    layout="vertical"
                    alignment="center"
                    iconSize="xl"
                    iconClassName={pricingIconClassName}
                    titleTag="h3"
                    titleClassName={`relative z-10 mb-3 text-heading text-2xl lg:text-3xl font-semibold`}
                    descriptionClassName="relative z-10 text-base leading-relaxed text-text/85"
                  />
                </div>

                <div class="mt-8 w-full text-center">
                  <p class="flex flex-wrap items-baseline justify-center gap-x-2 gap-y-1 font-semibold tracking-tight text-heading">
                    {pricePrefix && (
                      <span class="text-sm uppercase tracking-[0.24em] text-muted">
                        {pricePrefix}
                      </span>
                    )}
                    <span class="text-3xl">
                      {price}
                    </span>
                    {priceSuffix && (
                      <span class="text-sm uppercase tracking-[0.24em] text-muted">
                        {priceSuffix}
                      </span>
                    )}
                  </p>
                </div>

                {features.length > 0 && (
                  <ul class="mt-8 mx-auto flex w-full max-w-sm flex-col gap-3 text-left">
                    {features.map((feature) => (
                      <SmallChecklistItem
                        as="li"
                        class="items-center gap-2"
                        iconWrapperClassName="faded-bg flex items-center justify-center rounded-full p-1 text-accent flex-shrink-0"
                        iconClassName="h-3 w-3 lg:h-4 lg:w-4"
                        textClassName="text-text text-sm lg:text-base leading-relaxed"
                      >
                        {feature}
                      </SmallChecklistItem>
                    ))}
                  </ul>
                )}

                <div class="mt-auto w-full pt-8 text-center">
                  {isFeatured ? (
                    <div class="mx-auto w-fit">
                      <Button
                        href={buttonHref}
                        variant="primary"
                        rightIcon="lu:arrow-up-right"
                        buttonWrapperClasses="justify-center"
                        className="justify-center text-center"
                        target={buttonTarget}
                        rel={buttonRel}
                      >
                        Get Started
                      </Button>
                    </div>
                  ) : (
                    <div class="mx-auto w-fit">
                      <Button
                        href={buttonHref}
                        variant="secondary"
                        rightIcon="lu:arrow-up-right"
                        buttonWrapperClasses="justify-center"
                        className="justify-center text-center"
                        target={buttonTarget}
                        rel={buttonRel}
                        client:visible
                      >
                        View Details
                      </Button>
                    </div>
                  )}
                </div>
              </div>
              </article>
            </div>
          </li>
        );
      })}
    </ul>
  </div>
</Section>
