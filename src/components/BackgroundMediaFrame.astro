---
import BackgroundMedia from "@/components/BackgroundMedia.astro";

interface Props {
  imageSrc?: any;
  imageClass?: string;
  imageMaxWidth?: number;
  mediaOverlayClass?: string;
  className?: string;
  backgroundMedia?: any;
}

const {
  imageSrc,
  imageClass = "",
  imageMaxWidth = 1600,
  mediaOverlayClass = "bg-bg/70",
  className = "",
  backgroundMedia,
} = Astro.props as Props;

const resolvedBackgroundMedia =
  backgroundMedia ??
  (imageSrc
    ? {
        image: {
          src: imageSrc,
          imageClass,
          maxWidth: imageMaxWidth,
        },
        overlayClass: mediaOverlayClass,
      }
    : null);

if (!resolvedBackgroundMedia) {
  throw new Error("[BackgroundMediaFrame] Provide `imageSrc` or `backgroundMedia`.");
}
---

<div
  class={`relative overflow-hidden rounded-[2.4rem] border border-text/10 bg-bg3 shadow-2xl ${className}`.trim()}
>
  <BackgroundMedia backgroundMedia={resolvedBackgroundMedia} />
  <slot />
</div>
