# .env.example
# Duplicate this file as ".env" and fill in your actual credentials.
# Do NOT commit your ".env" file containing keys to git.

# ── Domain settings
PUBLIC_SITE_DOMAIN="griffinswebservices.com"

# ── OpenAI Configuration (Required for chatbot completion & RAG embeddings)
OPENAI_API_KEY="your_openai_api_key_here"

# ── Supabase Configuration (Optional - for vector knowledge sync and chat logging)
SUPABASE_URL="https://your_project_id.supabase.co"
SUPABASE_ANON_KEY="your_supabase_anon_public_key_here"
# Service role key is required on the server to download/sync files from Supabase Storage buckets
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"
